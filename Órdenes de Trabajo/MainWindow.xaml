<Window x:Class="Órdenes_de_Trabajo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:controls="clr-namespace:Órdenes_de_Trabajo.Controls"
        xmlns:local="clr-namespace:Órdenes_de_Trabajo"
        mc:Ignorable="d"
            Title ="MenúPrincipalÓrdenes" Height="850" Width="1200" 
    TextElement.Foreground="#242731" WindowStyle="ThreeDBorderWindow"  Background="#1F2128"  WindowStartupLocation="CenterScreen" BorderBrush="#242731" >

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="20*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <materialDesign:ColorZone Grid.Column="0" CornerRadius="15 0 0 15" Background="#242731" VerticalAlignment="Stretch">
            <StackPanel Margin="15,49,15,60">
                <WrapPanel Margin="0 10 5 60" HorizontalAlignment="Center" Height="184" Width="185">
                    <Image RenderOptions.BitmapScalingMode="HighQuality" Source="c:\users\dsosa\source\repos\annygiron\taller_mecanico\taller_mecanico\vehículos\osm_logo.png"/>
                </WrapPanel>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731" materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0 -40 0 15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="Home" VerticalAlignment="Center" Foreground="White" Height="25" Width="38" HorizontalAlignment="Center"/>
                        <TextBlock Foreground="White" FontSize="15" Height="16">Pantalla Principal</TextBlock>
                    </WrapPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731" materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0 0 0 15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="PackageVariant" VerticalAlignment="Center" Foreground="White" Height="26" Width="38" HorizontalAlignment="Center"/>
                        <TextBlock Foreground="White" FontSize="15" Width="142" Height="20">Inventario</TextBlock>
                    </WrapPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731" materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0 0 0 15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="CarSportsUtilityVehicle" VerticalAlignment="Center" Foreground="White" Width="39" HorizontalAlignment="Center" Height="25"/>
                        <TextBlock Foreground="White" FontSize="15" Height="19"><Run Text="Vehículos"/></TextBlock>
                    </WrapPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731" materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0 0 0 15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="People" VerticalAlignment="Center" Foreground="White" Height="25" Width="39"/>
                        <TextBlock Foreground="White" FontSize="15" Width="77" Height="18"><Run Text="Clientes"/></TextBlock>
                    </WrapPanel>
                </Button>

                <Expander Background="#242731" Foreground="White" FontFamily="Segoe UI" FontSize="13"
                  BorderThickness="0" Width="Auto" Height="Auto" Margin="0 0 0 15">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Width="250">
                            <materialDesign:PackIcon Kind="BookOpenPageVariant" VerticalAlignment="Center" Margin="5 0 10 0" Foreground="White" Height="18" Width="35"/>
                            <TextBlock Foreground="White" FontSize="15">Contabilidad</TextBlock>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Background="#242731">
                        <Button Background="#242731" BorderThickness="0" Foreground="White" FontSize="15" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Width="250">
                                <materialDesign:PackIcon Kind="CurrencyUsd" VerticalAlignment="Center" Margin="15 0 20 0" Foreground="White"/>
                                <TextBlock Text="Egresos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Background="#242731" BorderThickness="0" Foreground="White" FontSize="15" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Width="250">
                                <materialDesign:PackIcon Kind="CreditCard" VerticalAlignment="Center" Margin="15 0 20 0" Foreground="White"/>
                                <TextBlock Text="Ingresos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Expander>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731" materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0 0 0 15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="OrderBoolAscending" VerticalAlignment="Center" Foreground="White" Height="25" Width="39"/>
                        <TextBlock Foreground="White" FontSize="15" Height="18">Órdenes</TextBlock>
                    </WrapPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731" materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                Height="35" materialDesign:RippleAssist.Feedback="White" VerticalAlignment="Bottom" Margin="0 70 0 15">
                    <WrapPanel Width="175">
                        <materialDesign:PackIcon Kind="LogoutVariant" VerticalAlignment="Center" Foreground="White" Width="39" HorizontalAlignment="Center" Height="21"/>
                        <TextBlock Foreground="White" FontSize="15" Height="21"><Run Text="Cerrar Sesión"/></TextBlock>
                    </WrapPanel>
                </Button>
            </StackPanel>
        </materialDesign:ColorZone>

        <!-- CONTENIDO DERECHO -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- NAVBAR -->
                <Border Background="#1A1D2E" Height="80">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="65,0,40,0">
                            <TextBlock Text="Hola, Oscar Sosa" Foreground="White" FontSize="18" FontWeight="Bold"/>
                            <TextBlock Text="Revisemos tu taller hoy" Foreground="#6B7280" FontSize="12"/>
                        </StackPanel>

                        <Border Background="#252836" CornerRadius="5" VerticalAlignment="Center"
                        Height="40" MaxWidth="700" HorizontalAlignment="Left"
                        Grid.ColumnSpan="2" Margin="243,0,0,0" Width="532">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                                <materialDesign:PackIcon Kind="Magnify" Foreground="#6B7280" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Background="Transparent" Foreground="#6B7280" BorderThickness="0"
                                 VerticalAlignment="Center" FontSize="13" Width="200" CaretBrush="White">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                                            <Setter Property="materialDesign:HintAssist.Hint" Value="Buscar..."/>
                                            <Setter Property="materialDesign:HintAssist.Foreground" Value="#6B7280"/>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Column="2" VerticalAlignment="Center" Margin="16,0">
                            <Button Style="{StaticResource MaterialDesignIconButton}" Foreground="#6B7280" Width="38" Height="38">
                                <materialDesign:PackIcon Kind="BellOutline" Width="22" Height="22"/>
                            </Button>
                            <materialDesign:Badged BadgeColorZoneMode="PrimaryMid" Badge="0"
                                          HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        </Grid>

                        <Rectangle Grid.Column="3" Fill="White" Margin="0,20"/>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,20,0">
                            <Border Width="38" Height="38" CornerRadius="18" ClipToBounds="True"
                            Margin="0,0,10,0" BorderBrush="#3D7EFF" BorderThickness="2"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Oscar Sosa" Foreground="#3D7EFF" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Propietario" Foreground="#6B7280" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer VerticalScrollBarVisibility="Auto" 
              HorizontalScrollBarVisibility="Disabled"
               Grid.Column="1" Margin="0,94,0,0">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="290"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- COLUMNA IZQUIERDA -->
                <StackPanel Grid.Column="0">

                    <!-- CARD CLIENTE -->
                    <materialDesign:Card Background="#252836"
                                 UniformCornerRadius="12"
                                 Padding="18"
                                 Margin="0,0,0,14"
                                 materialDesign:ElevationAssist.Elevation="Dp3">
                        <StackPanel>
                            <TextBlock Text="CLIENTE"
                               Foreground="#6c7293"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>

                            <TextBlock Text="Nombre" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Background="#1e2130"
                             Foreground="White"
                             BorderBrush="#3a3f5c"
                             CaretBrush="White"
                             Margin="0,0,0,10"
                             Height="38"
                             VerticalContentAlignment="Center"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Teléfono" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Background="#1e2130" Foreground="White"
                                     BorderBrush="#3a3f5c" CaretBrush="White"
                                     Height="38" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Tel. Opcional" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Background="#1e2130" Foreground="White"
                                     BorderBrush="#3a3f5c" CaretBrush="White"
                                     Height="38" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Email" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Background="#1e2130" Foreground="White"
                             BorderBrush="#3a3f5c" CaretBrush="White"
                             Height="38" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- CARD VEHÍCULO -->
                    <materialDesign:Card Background="#252836"
                                 UniformCornerRadius="12"
                                 Padding="18"
                                 Margin="0,0,0,14"
                                 materialDesign:ElevationAssist.Elevation="Dp3">
                        <StackPanel>
                            <TextBlock Text="VEHÍCULO"
                               Foreground="#6c7293"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Placa" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Background="#1e2130" Foreground="White"
                                     BorderBrush="#3a3f5c" CaretBrush="White"
                                     Height="38" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Marca" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Background="#1e2130" Foreground="White"
                                      BorderBrush="#3a3f5c" Height="38">
                                        <ComboBoxItem Content="Toyota"/>
                                        <ComboBoxItem Content="Honda"/>
                                        <ComboBoxItem Content="Ford"/>
                                        <ComboBoxItem Content="Chevrolet"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Modelo" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Background="#1e2130" Foreground="White"
                                      BorderBrush="#3a3f5c" Height="38">
                                        <ComboBoxItem Content="Corolla"/>
                                        <ComboBoxItem Content="Civic"/>
                                        <ComboBoxItem Content="F-150"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Motor" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Background="#1e2130" Foreground="White"
                                     BorderBrush="#3a3f5c" CaretBrush="White"
                                     Height="38" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Año" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Background="#1e2130" Foreground="White"
                             BorderBrush="#3a3f5c" CaretBrush="White"
                             Height="38" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- CARD FOTO -->
                    <materialDesign:Card Background="#252836"
                                 UniformCornerRadius="12"
                                 Padding="18"
                                 materialDesign:ElevationAssist.Elevation="Dp3">
                        <StackPanel>
                            <TextBlock Text="FOTO"
                               Foreground="#6c7293"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>
                            <Border Background="#1e2130"
                            BorderBrush="#3a3f5c"
                            BorderThickness="1.5"
                            CornerRadius="8"
                            Height="90"
                            Cursor="Hand">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="CameraPlus"
                                                     Width="26" Height="26"
                                                     Foreground="#6c7293"
                                                     HorizontalAlignment="Center"/>
                                    <TextBlock Text="+ Adjuntar Foto"
                                       Foreground="#6c7293"
                                       FontSize="12"
                                       Margin="0,5,0,0"
                                       HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </materialDesign:Card>

                </StackPanel>

                <!-- COLUMNA DERECHA -->
                <StackPanel Grid.Column="2">

                    <!-- CARD DETALLE DE LA ORDEN -->
                    <materialDesign:Card Background="#252836"
                                 UniformCornerRadius="12"
                                 Padding="18"
                                 Margin="0,0,0,14"
                                 materialDesign:ElevationAssist.Elevation="Dp3">
                        <StackPanel>
                            <TextBlock Text="Detalle de la Orden"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Medium"
                               Margin="0,0,0,14"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Estado" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Background="#2e3250" Foreground="White"
                                      BorderBrush="#4f6ef7" Height="38">
                                        <ComboBoxItem Content="En Espera" IsSelected="True" />
                                        <ComboBoxItem Content="En Proceso"/>
                                        <ComboBoxItem Content="Completado"/>
                                        <ComboBoxItem Content="Cancelado"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Fecha" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                                    <controls:EspañolDatePicker x:Name="dpFecha" Height="38"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="F. Entrega" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                                    <controls:EspañolDatePicker x:Name="dpEntrega" Height="38"/>
                                </StackPanel>

                                <StackPanel Grid.Column="6">
                                    <TextBlock Text="Orden Nº" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Background="#1e2130" Foreground="White"
                                     BorderBrush="#3a3f5c" CaretBrush="White"
                                     Height="38" IsReadOnly="True"
                                     VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Prioridad" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                                    <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Background="#1e2130" Foreground="White"
                                      BorderBrush="#3a3f5c" Height="38">
                                        <ComboBoxItem Content="Normal" IsSelected="True"/>
                                        <ComboBoxItem Content="Alta"/>
                                        <ComboBoxItem Content="Urgente"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Observaciones" Foreground="#6c7293" FontSize="11" Margin="0,0,0,3"/>
                                    <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Background="#1e2130" Foreground="White"
                                     BorderBrush="#3a3f5c" CaretBrush="White"
                                     Height="75"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"
                                     Padding="8"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>
					
					<!-- CARD DETALLE DEL TRABAJO -->
					<materialDesign:Card Background="#252836"
								 UniformCornerRadius="12"
								 Padding="18"
								 Margin="0,0,0,14"
								 MinHeight="350"
								 materialDesign:ElevationAssist.Elevation="Dp3">
						<StackPanel>
							<TextBlock Text="Detalle del Trabajo"
							   Foreground="White"
							   FontSize="14"
							   FontWeight="Medium"
							   Margin="0,0,0,14"/>
							
							<Button Content="+ Agregar Repuestos"
							Style="{StaticResource MaterialDesignOutlinedButton}"
							BorderBrush="#4f6ef7"
							Foreground="#4f6ef7"
							Height="36"
							HorizontalAlignment="Left"
							Padding="16,0"
							Margin="0,0,0,12"
									
							materialDesign:ButtonAssist.CornerRadius="6"/>

							<DataGrid x:Name="dgRepuestos"
							  AutoGenerateColumns="False"
							  Background="#1e2130"
							  Foreground="White"
							  BorderBrush="#3a3f5c"
							  BorderThickness="1"
							  RowBackground="#252836"
							  AlternatingRowBackground="#1e2130"
							  GridLinesVisibility="Horizontal"
							  HorizontalGridLinesBrush="#2e3250"
							  HeadersVisibility="Column"
							  CanUserAddRows="False"
							  MaxHeight="180"
							  materialDesign:DataGridAssist.CellPadding="10 6 10 6"
							  materialDesign:DataGridAssist.ColumnHeaderPadding="10 8 10 8">
								<DataGrid.ColumnHeaderStyle>
									<Style TargetType="DataGridColumnHeader"
								   BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
										<Setter Property="Background" Value="#2e3250"/>
										<Setter Property="Foreground" Value="#a0a8c8"/>
										<Setter Property="FontSize" Value="12"/>
										<Setter Property="FontWeight" Value="Medium"/>
									</Style>
								</DataGrid.ColumnHeaderStyle>
								<DataGrid.Columns>
									<DataGridTextColumn Header="#"        Binding="{Binding Numero}"   Width="40"/>
									<DataGridTextColumn Header="Repuesto" Binding="{Binding Nombre}"   Width="*"/>
									<DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="80"/>
									<DataGridTextColumn Header="Precio"   Binding="{Binding Precio, StringFormat=C}" Width="90"/>
									<DataGridCheckBoxColumn Header="Incl." Binding="{Binding Incluido}" Width="60"/>
								</DataGrid.Columns>
							</DataGrid>

							<!-- SEPARADOR -->
							<Separator Background="#3a3f5c" Margin="0,14,0,14"/>

							<!-- SECCIÓN DE PRECIOS -->
							<Grid Margin="0,0,0,8">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="160"/>
								</Grid.ColumnDefinitions>

								<!-- Precio del Repuesto -->
								<TextBlock Grid.Column="0"
										   Text="PRECIO DEL REPUESTO"
										   Foreground="#a0a8c8"
										   FontSize="11"
										   FontWeight="Medium"
										   VerticalAlignment="Center"/>
								<Border Grid.Column="1"
										Background="#1e2130"
										BorderBrush="#3a3f5c"
										BorderThickness="1"
										CornerRadius="6"
										Padding="10,6">
									<TextBox x:Name="txtPrecioRepuesto"
											 Foreground="White"
											 Background="Transparent"
											 BorderThickness="0"
											 IsReadOnly="True"
											 Text="S/ 0.00"
											 HorizontalAlignment="Right"/>
								</Border>
							</Grid>

							<Grid Margin="0,0,0,8">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="160"/>
								</Grid.ColumnDefinitions>

								<!-- Precio del Servicio -->
								<TextBlock Grid.Column="0"
										   Text="PRECIO DEL SERVICIO"
										   Foreground="#a0a8c8"
										   FontSize="11"
										   FontWeight="Medium"
										   VerticalAlignment="Center"/>
								<Border Grid.Column="1"
										Background="#1e2130"
										BorderBrush="#3a3f5c"
										BorderThickness="1"
										CornerRadius="6"
										Padding="10,6">
									<TextBox x:Name="txtPrecioServicio"
											 Foreground="White"
											 Background="Transparent"
											 BorderThickness="0"
											 Text="S/ 0.00"
											 HorizontalAlignment="Right"/>
								</Border>
							</Grid>

							<!-- SEPARADOR ANTES DEL TOTAL -->
							<Separator Background="#3a3f5c" Margin="0,6,0,8"/>

							<Grid Margin="0,0,0,14">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="160"/>
								</Grid.ColumnDefinitions>

								<!-- Costo Total -->
								<TextBlock Grid.Column="0"
										   Text="COSTO TOTAL"
										   Foreground="White"
										   FontSize="13"
										   FontWeight="Bold"
										   VerticalAlignment="Center"/>
								<Border Grid.Column="1"
										Background="#2e3250"
										BorderBrush="#4f6ef7"
										BorderThickness="1"
										CornerRadius="6"
										Padding="10,6">
									<TextBox x:Name="txtCostoTotal"
											 Foreground="#4f6ef7"
											 Background="Transparent"
											 BorderThickness="0"
											 IsReadOnly="True"
											 FontWeight="Bold"
											 Text="S/ 0.00"
											 HorizontalAlignment="Right"/>
								</Border>
							</Grid>

						</StackPanel>
					</materialDesign:Card>

                    <!-- BARRA DE ACCIONES -->
                    <Border Background="#252836"
                    CornerRadius="12"
                    Padding="18,12">
			        
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                            <Button Content="Cancelar"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            BorderBrush="#6c7293"
                            Foreground="#6c7293"
                            Height="36"
                            Padding="20,0"
                            Margin="0,0,10,0"
                            materialDesign:ButtonAssist.CornerRadius="6"/>

