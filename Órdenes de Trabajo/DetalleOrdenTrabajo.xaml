<Window x:Class="Órdenes_de_Trabajo.DetalleOrdenTrabajo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Órdenes_de_Trabajo"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="" Height="850" Width="1200"
        TextElement.Foreground="#242731" WindowStyle="ThreeDBorderWindow"
        Background="#1F2128" WindowStartupLocation="CenterScreen" BorderBrush="#242731">


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="20*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <materialDesign:ColorZone Grid.Column="0" CornerRadius="0"
                                  Background="#242731" VerticalAlignment="Stretch">
            <StackPanel Margin="15,0,15,0">
                <WrapPanel Margin="0,10,5,60" HorizontalAlignment="Center" Height="184" Width="185">
                    <Image RenderOptions.BitmapScalingMode="HighQuality" Source="/OSM_LOGO.png" Height="199" Width="200"/>
                </WrapPanel>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,-40,0,15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="Home" VerticalAlignment="Center" Foreground="White" Height="25" Width="38"/>
                        <TextBlock Foreground="White" FontSize="15">Pantalla Principal</TextBlock>
                    </WrapPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="PackageVariant" VerticalAlignment="Center" Foreground="White" Height="26" Width="38"/>
                        <TextBlock Foreground="White" FontSize="15">Inventario</TextBlock>
                    </WrapPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="CarSportsUtilityVehicle" VerticalAlignment="Center" Foreground="White" Width="39" Height="25"/>
                        <TextBlock Foreground="White" FontSize="15">Vehículos</TextBlock>
                    </WrapPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="People" VerticalAlignment="Center" Foreground="White" Height="25" Width="39"/>
                        <TextBlock Foreground="White" FontSize="15">Clientes</TextBlock>
                    </WrapPanel>
                </Button>
                <Expander Background="#242731" Foreground="White" FontFamily="Segoe UI" FontSize="13"
                          BorderThickness="0" Margin="0,0,0,15">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Width="250">
                            <materialDesign:PackIcon Kind="BookOpenPageVariant" VerticalAlignment="Center"
                                                     Margin="5,0,10,0" Foreground="White" Height="18" Width="35"/>
                            <TextBlock Foreground="White" FontSize="15">Contabilidad</TextBlock>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Background="#242731">
                        <Button Background="#242731" BorderThickness="0" Foreground="White" FontSize="15" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Width="250">
                                <materialDesign:PackIcon Kind="CurrencyUsd" VerticalAlignment="Center" Margin="15,0,20,0" Foreground="White"/>
                                <TextBlock Text="Egresos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Background="#242731" BorderThickness="0" Foreground="White" FontSize="15" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Width="250">
                                <materialDesign:PackIcon Kind="CreditCard" VerticalAlignment="Center" Margin="15,0,20,0" Foreground="White"/>
                                <TextBlock Text="Ingresos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Expander>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="OrderBoolAscending" VerticalAlignment="Center" Foreground="White" Height="25" Width="39"/>
                        <TextBlock Foreground="White" FontSize="15">Órdenes</TextBlock>
                    </WrapPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,200,0,15">
                    <WrapPanel Width="175">
                        <materialDesign:PackIcon Kind="LogoutVariant" VerticalAlignment="Center" Foreground="White" Width="39" Height="21"/>
                        <TextBlock Foreground="White" FontSize="15">Cerrar Sesión</TextBlock>
                    </WrapPanel>
                </Button>
            </StackPanel>
        </materialDesign:ColorZone>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0" Background="#1A1D2E">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="25,0,20,0">
                        <TextBlock Text="Detalle Orden de Trabajo" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Información completa de la orden" Foreground="#6B7280" FontSize="12"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#252836" CornerRadius="5"
                            VerticalAlignment="Center" Height="40" MaxWidth="400"
                            HorizontalAlignment="Left" Margin="20,0,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                            <materialDesign:PackIcon Kind="Magnify" Foreground="#6B7280" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Background="Transparent" Foreground="#6B7280" BorderThickness="0"
                                     VerticalAlignment="Center" FontSize="13" Width="200" CaretBrush="White">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Setter Property="materialDesign:HintAssist.Hint" Value="Buscar..."/>
                                        <Setter Property="materialDesign:HintAssist.Foreground" Value="#6B7280"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="16,0">
                        <Button Style="{StaticResource MaterialDesignIconButton}" Foreground="#6B7280" Width="38" Height="38">
                            <materialDesign:PackIcon Kind="BellOutline" Width="22" Height="22"/>
                        </Button>
                        <materialDesign:Badged BadgeColorZoneMode="PrimaryMid" Badge="0"
                                               HorizontalAlignment="Right" VerticalAlignment="Top"/>
                    </Grid>
                    <Rectangle Grid.Column="3" Fill="#3D4458" Margin="0,20"/>
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,20,0">
                        <Border Width="38" Height="38" CornerRadius="18" ClipToBounds="True"
                                Margin="0,0,10,0" BorderBrush="#3D7EFF" BorderThickness="2"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Oscar Sosa" Foreground="#3D7EFF" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Propietario" Foreground="#6B7280" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENIDO CON TABS -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#1a1d2e">
                <StackPanel Margin="24">

                    <!-- HEADER DEL VEHÍCULO -->
                    <materialDesign:Card Background="#252836"
                                         UniformCornerRadius="12"
                                         Padding="0"
                                         Margin="0,0,0,16"
                                         materialDesign:ElevationAssist.Elevation="Dp3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="12,0,0,12"
                                    Background="#1e2130" Height="140">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Car" Foreground="#3a3f5c"
                                                             Width="55" Height="55" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Sin imagen" Foreground="#3a3f5c"
                                               FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0">
                                <TextBlock x:Name="txtNombreVehiculo" Text="PORSCHE GT3 RS"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                                <TextBlock x:Name="txtAnioVehiculo" Text="2023"
                                           Foreground="#6c7293" FontSize="13" Margin="0,3,0,12"/>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#2e3250" CornerRadius="20" Padding="12,4" Margin="0,0,8,0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Tag" Foreground="#4f6ef7"
                                                                     Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock x:Name="txtOrdenNum" Text="Orden #001"
                                                       Foreground="#4f6ef7" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                    <Border x:Name="badgeEstado" Background="#1a3a1a" CornerRadius="20" Padding="12,4">
                                        <TextBlock x:Name="txtEstadoOrden" Text="En Espera"
                                                   Foreground="#4CAF50" FontSize="12"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!-- CARD CON TABS -->
                    <materialDesign:Card Background="#252836"
                                         UniformCornerRadius="12"
                                         Padding="0"
                                         materialDesign:ElevationAssist.Elevation="Dp3">
                        <StackPanel>

                            <!-- Barra de tabs -->
                            <Border Background="#1e2130" CornerRadius="12,12,0,0" Padding="20,0">
                                <StackPanel Orientation="Horizontal">

                                    <RadioButton x:Name="tabBasicos" Content="Detalles Básicos"
                                                 IsChecked="True" GroupName="Tabs"
                                                 Checked="Tab_Checked" Tag="Basicos" Margin="0,0,4,0">
                                        <RadioButton.Style>
                                            <Style TargetType="RadioButton">
                                                <Setter Property="Foreground" Value="#6c7293"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Padding" Value="16,14"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="RadioButton">
                                                            <Border x:Name="border" Background="Transparent"
                                                                    BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="border" Property="BorderBrush" Value="#4f6ef7"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </RadioButton.Style>
                                    </RadioButton>

                                    <RadioButton x:Name="tabDescripcion" Content="Descripción"
                                                 GroupName="Tabs" Checked="Tab_Checked"
                                                 Tag="Descripcion" Margin="0,0,4,0">
                                        <RadioButton.Style>
                                            <Style TargetType="RadioButton">
                                                <Setter Property="Foreground" Value="#6c7293"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Padding" Value="16,14"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="RadioButton">
                                                            <Border x:Name="border" Background="Transparent"
                                                                    BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="border" Property="BorderBrush" Value="#4f6ef7"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </RadioButton.Style>
                                    </RadioButton>

                                    <RadioButton x:Name="tabHistorial" Content="Historial"
                                                 GroupName="Tabs" Checked="Tab_Checked" Tag="Historial">
                                        <RadioButton.Style>
                                            <Style TargetType="RadioButton">
                                                <Setter Property="Foreground" Value="#6c7293"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Padding" Value="16,14"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="RadioButton">
                                                            <Border x:Name="border" Background="Transparent"
                                                                    BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="border" Property="BorderBrush" Value="#4f6ef7"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </RadioButton.Style>
                                    </RadioButton>

                                </StackPanel>
                            </Border>

                            <!-- ═══════════════════════ -->
                            <!-- TAB 1: DETALLES BÁSICOS -->
                            <!-- ═══════════════════════ -->
                            <Grid x:Name="panelBasicos" Visibility="Visible" Margin="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="280"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">

                                    <!-- Fila: Placa / Modelo / Fecha / Marca -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="NÚMERO DE PLACA" Foreground="#6c7293"
                                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                            <Border Background="#1e2130" CornerRadius="8" Padding="14,10">
                                                <TextBlock x:Name="lblPlaca" Text="ABC-1234"
                                                           Foreground="White" FontSize="14" FontWeight="Medium"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="MODELO" Foreground="#6c7293"
                                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                            <Border Background="#1e2130" CornerRadius="8" Padding="14,10">
                                                <TextBlock x:Name="lblModelo" Text="GT3 RS"
                                                           Foreground="White" FontSize="14" FontWeight="Medium"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="FECHA" Foreground="#6c7293"
                                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                            <Border Background="#1e2130" CornerRadius="8" Padding="14,10">
                                                <TextBlock x:Name="lblFecha" Text="01/03/2026"
                                                           Foreground="White" FontSize="14" FontWeight="Medium"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="6">
                                            <TextBlock Text="MARCA" Foreground="#6c7293"
                                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                            <Border Background="#1e2130" CornerRadius="8" Padding="14,10">
                                                <TextBlock x:Name="lblMarca" Text="Porsche"
                                                           Foreground="White" FontSize="14" FontWeight="Medium"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Más Info -->
                                    <Border Background="#1e2130" CornerRadius="10" Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="MÁS INFORMACIÓN" Foreground="#6c7293"
                                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,16"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="12"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="12"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Fila 1 -->
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Cliente:"
                                                           Foreground="#6c7293" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="lblCliente"
                                                           Text="Joaquin Obed" Foreground="White" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Row="0" Grid.Column="3" Text="Email:"
                                                           Foreground="#6c7293" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Grid.Row="0" Grid.Column="4" x:Name="lblEmail"
                                                           Text="r13@gmail.com" Foreground="White" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>

                                                <Separator Grid.Row="1" Grid.ColumnSpan="5" Background="#2e3250"/>

                                                <!-- Fila 2 -->
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Teléfono:"
                                                           Foreground="#6c7293" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="lblTelefono"
                                                           Text="12345678" Foreground="White" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Row="2" Grid.Column="3" Text="Año:"
                                                           Foreground="#6c7293" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Grid.Row="2" Grid.Column="4" x:Name="lblAnio"
                                                           Text="2023" Foreground="White" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>

                                                <Separator Grid.Row="3" Grid.ColumnSpan="5" Background="#2e3250"/>

                                                <!-- Fila 3 -->
                                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Tel. Opcional:"
                                                           Foreground="#6c7293" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="lblTelefonoOp"
                                                           Text="91041542" Foreground="White" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Row="4" Grid.Column="3" Text="Motor:"
                                                           Foreground="#6c7293" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Grid.Row="4" Grid.Column="4" x:Name="lblMotor"
                                                           Text="4.0L Boxer-6" Foreground="White" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>

                                <!-- Fotos -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="FOTOS DEL VEHÍCULO" Foreground="#6c7293"
                                               FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>
                                    <Border Background="#1e2130" CornerRadius="10" Height="155"
                                            Margin="0,0,0,8" Cursor="Hand"
                                            BorderBrush="#3a3f5c" BorderThickness="1.5">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="CameraPlus" Foreground="#3a3f5c"
                                                                     Width="30" Height="30" HorizontalAlignment="Center"/>
                                            <TextBlock Text="+ Agregar foto" Foreground="#3a3f5c"
                                                       FontSize="12" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#1e2130" CornerRadius="10" Height="155"
                                            Cursor="Hand" BorderBrush="#3a3f5c" BorderThickness="1.5">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="CameraPlus" Foreground="#3a3f5c"
                                                                     Width="30" Height="30" HorizontalAlignment="Center"/>
                                            <TextBlock Text="+ Agregar foto" Foreground="#3a3f5c"
                                                       FontSize="12" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                            </Grid>

                            <!-- ═══════════════════════ -->
                            <!-- TAB 2: DESCRIPCIÓN      -->
                            <!-- ═══════════════════════ -->
                            <Grid x:Name="panelDescripcion" Visibility="Collapsed" Margin="24">
                                <StackPanel>
                                    <TextBlock Text="DESCRIPCIÓN DEL PROBLEMA" Foreground="#6c7293"
                                               FontSize="10" FontWeight="Bold" Margin="0,0,0,16"/>
                                    <Border Background="#1e2130" CornerRadius="10" Padding="20" MinHeight="300">
                                        <TextBlock x:Name="lblDescripcion"
                                                   Text="DESCRIPCIÓN DE EL PROBLEMA DEL VEHÍCULO"
                                                   Foreground="White" FontSize="15"
                                                   TextWrapping="Wrap"
                                                   LineHeight="24"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- ═══════════════════════ -->
                            <!-- TAB 3: HISTORIAL        -->
                            <!-- ═══════════════════════ -->
                            <Grid x:Name="panelHistorial" Visibility="Collapsed" Margin="24">
                                <StackPanel>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ÓRDENES ANTERIORES" Foreground="#6c7293"
                                                   FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Background="#2e3250" CornerRadius="20" Padding="12,4">
                                            <TextBlock x:Name="txtTotalOrdenes" Text="0 órdenes"
                                                       Foreground="#4f6ef7" FontSize="12"/>
                                        </Border>
                                    </Grid>

                                    <!-- Encabezado tabla -->
                                    <Border Background="#2e3250" CornerRadius="8" Padding="16,10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="No."        Foreground="#a0a8c8" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="Cliente"    Foreground="#a0a8c8" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="2" Text="Fecha"      Foreground="#a0a8c8" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="3" Text="Estado"     Foreground="#a0a8c8" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="Precio"     Foreground="#a0a8c8" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>

                                    <!-- Filas historial -->
                                    <ItemsControl x:Name="icHistorial">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="16,12" Margin="0,0,0,4" CornerRadius="8" Cursor="Hand">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#1e2130"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#2e3250"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="100"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Numero}"
                                                                   Foreground="#6c7293" FontSize="13" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Cliente}" Foreground="White" FontSize="13" FontWeight="Medium"/>
                                                            <TextBlock Text="{Binding Vehiculo}" Foreground="#6c7293" FontSize="11"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding FechaOrden}"
                                                                   Foreground="#c0c8e8" FontSize="13" VerticalAlignment="Center"/>
                                                        <Border Grid.Column="3" CornerRadius="12" Padding="10,4"
                                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#1a3a2a"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                                                            <Setter Property="Background" Value="#3a2a1a"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Estado}" Value="Cancelado">
                                                                            <Setter Property="Background" Value="#3a1a1a"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Estado}" FontSize="11" FontWeight="Medium">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                                                                <Setter Property="Foreground" Value="#FF9800"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Estado}" Value="Cancelado">
                                                                                <Setter Property="Foreground" Value="#f44336"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <TextBlock Grid.Column="4" Text="{Binding Precio}"
                                                                   Foreground="White" FontSize="13" FontWeight="Medium"
                                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </materialDesign:Card>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</Window>