<Window x:Class="InterfazInventario.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Inventario" Height="850" Width="1200"
        TextElement.Foreground="#242731" WindowStyle="ThreeDBorderWindow"
        Background="#1F2128" WindowStartupLocation="CenterScreen" BorderBrush="#242731">


        <Window.Resources>

            <!-- ══════════════════════════════════════════
             ESTILO BASE — TextBox oscuro funcional
             ══════════════════════════════════════════ -->
            <Style x:Key="DarkTextBox" TargetType="TextBox">
                <Setter Property="Background"               Value="#1e2130"/>
                <Setter Property="Foreground"               Value="White"/>
                <Setter Property="CaretBrush"               Value="White"/>
                <Setter Property="BorderBrush"              Value="#3a3f5c"/>
                <Setter Property="BorderThickness"          Value="1"/>
                <Setter Property="Height"                   Value="40"/>
                <Setter Property="Padding"                  Value="10,0"/>
                <Setter Property="FontSize"                 Value="13"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="SelectionBrush"           Value="#4f6ef7"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                                <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Focusable="False"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush"     Value="#4f6ef7"/>
                                    <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="#6070cc"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TextBox precio: sin borde izquierdo (tiene prefijo Q) -->
            <Style x:Key="DarkTextBoxNoBorderLeft" TargetType="TextBox"
               BasedOn="{StaticResource DarkTextBox}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,1,1,1"
                                CornerRadius="0,6,6,0">
                                <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Focusable="False"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="#4f6ef7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TextBox centrado para cantidad -->
            <Style x:Key="DarkTextBoxCentered" TargetType="TextBox"
               BasedOn="{StaticResource DarkTextBox}">
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="FontSize"      Value="15"/>
                <Setter Property="FontWeight"    Value="SemiBold"/>
            </Style>

        </Window.Resources>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="20*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════
             SIDEBAR
             ══════════════════════════════════════════ -->
            <materialDesign:ColorZone Grid.Column="0" CornerRadius="0"
                                  Background="#242731" VerticalAlignment="Stretch">
                <StackPanel Margin="15,0,15,0">
                    <WrapPanel Margin="0,10,5,60" HorizontalAlignment="Center" Height="184" Width="185">
                        <Image RenderOptions.BitmapScalingMode="HighQuality"
                           Source="/OSM_LOGO.png" Height="199" Width="200"/>
                    </WrapPanel>

                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,-40,0,15">
                        <WrapPanel Width="250">
                            <materialDesign:PackIcon Kind="Home" VerticalAlignment="Center"
                                                 Foreground="White" Height="25" Width="38"/>
                            <TextBlock Foreground="White" FontSize="15">Pantalla Principal</TextBlock>
                        </WrapPanel>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15">
                        <WrapPanel Width="250">
                            <materialDesign:PackIcon Kind="PackageVariant" VerticalAlignment="Center"
                                                 Foreground="White" Height="26" Width="38"/>
                            <TextBlock Foreground="White" FontSize="15">Inventario</TextBlock>
                        </WrapPanel>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15">
                        <WrapPanel Width="250">
                            <materialDesign:PackIcon Kind="CarSportsUtilityVehicle" VerticalAlignment="Center"
                                                 Foreground="White" Width="39" Height="25"/>
                            <TextBlock Foreground="White" FontSize="15">Vehículos</TextBlock>
                        </WrapPanel>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15">
                        <WrapPanel Width="250">
                            <materialDesign:PackIcon Kind="People" VerticalAlignment="Center"
                                                 Foreground="White" Height="25" Width="39"/>
                            <TextBlock Foreground="White" FontSize="15">Clientes</TextBlock>
                        </WrapPanel>
                    </Button>

                    <Expander Background="#242731" Foreground="White" FontFamily="Segoe UI"
                          FontSize="13" BorderThickness="0" Margin="0,0,0,15">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal" Width="250">
                                <materialDesign:PackIcon Kind="BookOpenPageVariant" VerticalAlignment="Center"
                                                     Margin="5,0,10,0" Foreground="White" Height="18" Width="35"/>
                                <TextBlock Foreground="White" FontSize="15">Contabilidad</TextBlock>
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Background="#242731">
                            <Button Background="#242731" BorderThickness="0" Foreground="White"
                                FontSize="15" HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Width="250">
                                    <materialDesign:PackIcon Kind="CurrencyUsd" VerticalAlignment="Center"
                                                         Margin="15,0,20,0" Foreground="White"/>
                                    <TextBlock Text="Egresos" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Background="#242731" BorderThickness="0" Foreground="White"
                                FontSize="15" HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal" Width="250">
                                    <materialDesign:PackIcon Kind="CreditCard" VerticalAlignment="Center"
                                                         Margin="15,0,20,0" Foreground="White"/>
                                    <TextBlock Text="Ingresos" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Expander>

                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15">
                        <WrapPanel Width="250">
                            <materialDesign:PackIcon Kind="OrderBoolAscending" VerticalAlignment="Center"
                                                 Foreground="White" Height="25" Width="39"/>
                            <TextBlock Foreground="White" FontSize="15">Órdenes</TextBlock>
                        </WrapPanel>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,200,0,15">
                        <WrapPanel Width="175">
                            <materialDesign:PackIcon Kind="LogoutVariant" VerticalAlignment="Center"
                                                 Foreground="White" Width="39" Height="21"/>
                            <TextBlock Foreground="White" FontSize="15">Cerrar Sesión</TextBlock>
                        </WrapPanel>
                    </Button>
                </StackPanel>
            </materialDesign:ColorZone>

            <!-- ══════════════════════════════════════════
             CONTENIDO PRINCIPAL
             ══════════════════════════════════════════ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TOP BAR -->
                <Border Grid.Row="0" Background="#1A1D2E">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="25,0,20,0">
                            <TextBlock Text="Inventario" Foreground="White"
                                   FontSize="18" FontWeight="Bold"/>
                            <TextBlock Text="Gestión de productos y repuestos"
                                   Foreground="#6B7280" FontSize="12"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="#252836" CornerRadius="5"
                            VerticalAlignment="Center" Height="40" MaxWidth="400"
                            HorizontalAlignment="Left" Margin="20,0,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                                <materialDesign:PackIcon Kind="Magnify" Foreground="#6B7280"
                                                     Width="18" Height="18" VerticalAlignment="Center"
                                                     Margin="0,0,8,0"/>
                                <TextBox Background="Transparent" Foreground="#6B7280"
                                     BorderThickness="0" VerticalAlignment="Center"
                                     FontSize="13" Width="200" CaretBrush="White"/>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Column="2" VerticalAlignment="Center" Margin="16,0">
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                Foreground="#6B7280" Width="38" Height="38">
                                <materialDesign:PackIcon Kind="BellOutline" Width="22" Height="22"/>
                            </Button>
                        </Grid>

                        <Rectangle Grid.Column="3" Fill="#3D4458" Margin="0,20"/>

                        <StackPanel Grid.Column="4" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,20,0">
                            <Border Width="38" Height="38" CornerRadius="18" ClipToBounds="True"
                                Margin="0,0,10,0" BorderBrush="#3D7EFF" BorderThickness="2"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Oscar Sosa" Foreground="#3D7EFF"
                                       FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Propietario" Foreground="#6B7280" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- FORMULARIO -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#1a1d2e">
                    <Grid Margin="30,24,30,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ══════════════════════════════
                         COLUMNA IZQUIERDA
                         ══════════════════════════════ -->
                        <StackPanel Grid.Column="0" Grid.RowSpan="2">
                            <materialDesign:Card Background="#252836" UniformCornerRadius="12"
                                             Padding="22" Margin="0,0,0,16"
                                             materialDesign:ElevationAssist.Elevation="Dp3">
                                <StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Border Background="#2e3250" CornerRadius="8"
                                            Width="36" Height="36" Margin="0,0,12,0">
                                            <materialDesign:PackIcon Kind="PackageVariant" Foreground="#4f6ef7"
                                                                 Width="20" Height="20"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Datos del Producto" Foreground="White"
                                                   FontSize="14" FontWeight="Medium"/>
                                            <TextBlock Text="Información de identificación"
                                                   Foreground="#6c7293" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Nombre -->
                                    <TextBlock Text="Nombre *" Foreground="#6c7293"
                                           FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
                                    <TextBox x:Name="txtNombre"
                                         Style="{StaticResource DarkTextBox}"
                                         Margin="0,0,0,16"/>

                                    <!-- Categoría -->
                                    <TextBlock Text="Categoría *" Foreground="#6c7293"
                                           FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="cmbCategoria"
                                          Height="40" Margin="0,0,0,16"
                                          Background="#1e2130" Foreground="White"
                                          BorderBrush="#3a3f5c" FontSize="13">
                                        <ComboBox.Resources>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Background" Value="#252836"/>
                                            </Style>
                                        </ComboBox.Resources>
                                        <ComboBoxItem Content="Repuestos"/>
                                        <ComboBoxItem Content="Aceites y Lubricantes"/>
                                        <ComboBoxItem Content="Frenos"/>
                                        <ComboBoxItem Content="Filtros"/>
                                        <ComboBoxItem Content="Eléctrico"/>
                                        <ComboBoxItem Content="Suspensión"/>
                                        <ComboBoxItem Content="Motor"/>
                                        <ComboBoxItem Content="Carrocería"/>
                                        <ComboBoxItem Content="Otros"/>
                                    </ComboBox>

                                    <!-- Marca -->
                                    <TextBlock Text="Marca *" Foreground="#6c7293"
                                           FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
                                    <TextBox x:Name="txtMarca"
                                         Style="{StaticResource DarkTextBox}"
                                         Margin="0,0,0,16"/>

                                    <!-- Modelo -->
                                    <TextBlock Text="Modelo (opcional)" Foreground="#6c7293"
                                           FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
                                    <TextBox x:Name="txtModelo"
                                         Style="{StaticResource DarkTextBox}"
                                         Margin="0,0,0,16"/>


                                </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>

                        <!-- ══════════════════════════════
                         COLUMNA DERECHA
                         ══════════════════════════════ -->
                        <StackPanel Grid.Column="2" Grid.RowSpan="2">
                            <materialDesign:Card Background="#252836" UniformCornerRadius="12"
                                             Padding="22" Margin="0,0,0,16"
                                             materialDesign:ElevationAssist.Elevation="Dp3">
                                <StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Border Background="#2e3250" CornerRadius="8"
                                            Width="36" Height="36" Margin="0,0,12,0">
                                            <materialDesign:PackIcon Kind="TagOutline" Foreground="#4f6ef7"
                                                                 Width="20" Height="20"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Detalles y Precio" Foreground="White"
                                                   FontSize="14" FontWeight="Medium"/>
                                            <TextBlock Text="Precio y cantidad del producto"
                                                   Foreground="#6c7293" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Precio -->
                                    <TextBlock Text="Precio *" Foreground="#6c7293"
                                           FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#2e3250"
                                            BorderBrush="#3a3f5c" BorderThickness="1,1,0,1"
                                            CornerRadius="6,0,0,6" Padding="12,0" Height="40">
                                            <TextBlock Text="Q" Foreground="#4f6ef7" FontSize="16"
                                                   FontWeight="Bold" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBox x:Name="txtPrecio"
                                             Grid.Column="1"
                                             Style="{StaticResource DarkTextBoxNoBorderLeft}"/>
                                    </Grid>


                                <!-- ══════════════════════
                                     CANTIDAD
                                     ══════════════════════ -->
                                <TextBlock Text="Cantidad ingresada" Foreground="#6c7293"
                                           FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Botón − -->
                                    <Button Grid.Column="0"
                                            x:Name="btnRestar"
                                            Width="40" Height="40"
                                            Click="BtnRestar_Click"
                                            materialDesign:ButtonAssist.CornerRadius="6"
                                            materialDesign:ElevationAssist.Elevation="Dp0">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                <Setter Property="Background"  Value="#2e3250"/>
                                                <Setter Property="Foreground"  Value="White"/>
                                                <Setter Property="BorderBrush" Value="#3a3f5c"/>
                                            </Style>
                                        </Button.Style>
                                        <materialDesign:PackIcon Kind="Minus" Width="16" Height="16"/>
                                    </Button>

                                    <!-- Cantidad -->
                                    <TextBox x:Name="txtCantidad"
                                             Grid.Column="1"
                                             Margin="8,0"
                                             Text="0"
                                             Style="{StaticResource DarkTextBoxCentered}"/>

                                    <!-- Botón + -->
                                    <Button Grid.Column="2"
                                            x:Name="btnSumar"
                                            Width="40" Height="40"
                                            Click="BtnSumar_Click"
                                            materialDesign:ButtonAssist.CornerRadius="6"
                                            materialDesign:ElevationAssist.Elevation="Dp0">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                <Setter Property="Background"  Value="#2e3250"/>
                                                <Setter Property="Foreground"  Value="White"/>
                                                <Setter Property="BorderBrush" Value="#3a3f5c"/>
                                            </Style>
                                        </Button.Style>
                                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"/>
                                    </Button>
                                </Grid>

                            </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>

                        <!-- ══════════════════════════════
                         BOTONES
                         ══════════════════════════════ -->
                        <materialDesign:Card Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                         Background="#252836" UniformCornerRadius="12"
                                         Padding="20,16" Margin="0,262,0,-245"
                                         materialDesign:ElevationAssist.Elevation="Dp3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                       Foreground="#6c7293" FontSize="12">
                                <Run Text="⚠ "/>
                                <Run Text="Verifica los datos antes de guardar"/>
                                </TextBlock>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button x:Name="btnCancelar" Content="Cancelar"
                                        Height="38" Padding="24,0" Margin="0,0,10,0"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        BorderBrush="#6c7293" Foreground="#6c7293"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Click="BtnCancelar_Click"/>
                                    <Button x:Name="btnActualizar" Content="Actualizar"
                                        Height="38" Padding="24,0" Margin="0,0,10,0"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        BorderBrush="#4f6ef7" Foreground="#4f6ef7"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Click="BtnActualizar_Click"/>
                                    <Button x:Name="btnAgregar"
                                        Height="38" Padding="24,0"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        materialDesign:ElevationAssist.Elevation="Dp0"
                                        Click="BtnAgregar_Click">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                               BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                <Setter Property="Background"  Value="#4f6ef7"/>
                                                <Setter Property="Foreground"  Value="White"/>
                                                <Setter Property="BorderBrush" Value="#4f6ef7"/>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Agregar Producto" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </materialDesign:Card>

                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Window>