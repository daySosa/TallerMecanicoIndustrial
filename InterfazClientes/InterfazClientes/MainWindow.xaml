<Window x:Class="InterfazClientes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InterfazClientes"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#FF0A132D">
        <DataGrid x:Name="DataGridClientes" Margin="359,178,10,47" SelectionChanged="DataGridClientes_SelectionChanged_1" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="DNI" 
                                    Binding="{Binding DNI}" 
                                    Width="*"/>
                <DataGridTextColumn Header="Nombre"
                                Binding="{Binding Nombre}"
                                Width="*"/>

                <DataGridTextColumn Header="Teléfono"
                                Binding="{Binding Telefono}"
                                Width="*"/>

                <DataGridTextColumn Header="Teléfono Opcional"
                                Binding="{Binding TelefonoOpcional}"
                                Width="*"/>

                <DataGridTextColumn Header="Email"
                                Binding="{Binding Email}"
                                Width="*"/>

                <DataGridTextColumn Header="Dirección"
                                Binding="{Binding Direccion}"
                                Width="*"/>

                <DataGridTextColumn Header="Estado Actual"
                                Binding="{Binding EstadoActual}"
                                Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Rectangle HorizontalAlignment="Left" Height="434" Stroke="#FF12224B" VerticalAlignment="Center" Width="176" Fill="#FF12224B" RenderTransformOrigin="1.056,0.555"/>
        <TextBlock HorizontalAlignment="Left" Margin="210,67,0,0" TextWrapping="Wrap" Text="DNI:" VerticalAlignment="Top" Foreground="#FFFDFCFC"/>
        <TextBox x:Name="txtDNI" HorizontalAlignment="Left" Margin="210,88,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBlock HorizontalAlignment="Left" Margin="210,117,0,0" TextWrapping="Wrap" Text="Nombre:" VerticalAlignment="Top" Foreground="#FFFDFCFC"/>
        <TextBox x:Name="txtNombre" HorizontalAlignment="Left" Margin="210,138,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBlock HorizontalAlignment="Left" Margin="210,171,0,0" TextWrapping="Wrap" Text="Teléfono:" VerticalAlignment="Top" Foreground="#FFFDFCFC"/>
        <TextBox x:Name="txtTelefono" HorizontalAlignment="Left" Margin="210,192,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBlock HorizontalAlignment="Left" Margin="210,223,0,0" TextWrapping="Wrap" Text="Teléfono (Opcional):" VerticalAlignment="Top" Foreground="#FFFDFCFC"/>
        <TextBox x:Name="txtTelefonoOpcional" HorizontalAlignment="Left" Margin="210,244,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBlock HorizontalAlignment="Left" Margin="210,275,0,0" TextWrapping="Wrap" Text="Email:" VerticalAlignment="Top" Foreground="#FFFDFCFC"/>
        <TextBox x:Name="txtEmail" HorizontalAlignment="Left" Margin="210,296,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBlock HorizontalAlignment="Left" Margin="210,327,0,0" TextWrapping="Wrap" Text="Dirección:" VerticalAlignment="Top" Foreground="#FFFDFCFC"/>
        <TextBox x:Name="txtDireccion" HorizontalAlignment="Left" Margin="210,348,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="txtBuscar" HorizontalAlignment="Left" Margin="418,80,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="280" Height="19"/>
        <TextBlock HorizontalAlignment="Left" Margin="375,82,0,0" TextWrapping="Wrap" Text="Buscar:" VerticalAlignment="Top" Foreground="#FFFDFCFC"/>
        <Button x:Name="btnAgregar" Content="Agregar" HorizontalAlignment="Left" Margin="382,137,0,0" VerticalAlignment="Top" Width="100"/>
        <Button x:Name="btnActivo" Content="Activo" HorizontalAlignment="Left" Margin="512,137,0,0" VerticalAlignment="Top" Width="100"/>
        <Button x:Name="btnInactivo" Content="Inactivo" HorizontalAlignment="Left" Margin="646,137,0,0" VerticalAlignment="Top" Width="100"/>
        <Button x:Name="btnBuscar" Content="Buscar" HorizontalAlignment="Left" Margin="703,80,0,0" VerticalAlignment="Top" Width="55"/>
        <Button x:Name="btnMenu" Content="Menú Principal" HorizontalAlignment="Left" Margin="50,99,0,0" VerticalAlignment="Top" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="White"/>
        <Button x:Name="btnCerrarSesion" Content="Cerrar Sesión" HorizontalAlignment="Left" Margin="51,383,0,0" VerticalAlignment="Top" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="White"/>
        <Button x:Name="btnConfiguracion" Content="Configuración" HorizontalAlignment="Left" Margin="50,358,0,0" VerticalAlignment="Top" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="White"/>
        <Button x:Name="btnProveedores" Content="Proveedores" HorizontalAlignment="Left" Margin="50,309,0,0" VerticalAlignment="Top" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="White"/>
        <Button x:Name="btnContabilidad" Content="Contabilidad" HorizontalAlignment="Left" Margin="50,277,0,0" VerticalAlignment="Top" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="White"/>
        <Button x:Name="btnOrdenes" Content="Órdenes" HorizontalAlignment="Left" Margin="50,240,0,0" VerticalAlignment="Top" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="White"/>
        <Button x:Name="btnClientes" Content="Clientes" HorizontalAlignment="Left" Margin="51,205,0,0" VerticalAlignment="Top" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="White"/>
        <Button x:Name="btnVehiculo" Content="Vehículo" HorizontalAlignment="Left" Margin="51,171,0,0" VerticalAlignment="Top" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="White"/>
        <Button x:Name="btnInventario" Content="Inventario" HorizontalAlignment="Left" Margin="51,133,0,0" VerticalAlignment="Top" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="White"/>
        <Image Margin="30,-13,654,322" Source="/OSM_LOGO.png" Stretch="Fill"/>
        <Image Margin="22,104,762,314" Source="/ICONO DE MENU.png" Stretch="Fill" RenderTransformOrigin="0.037,0.601">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform X="10" Y="-2"/>
