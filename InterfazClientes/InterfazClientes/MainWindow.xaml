        </Image>
        <Image Margin="26,388,764,29" Source="/PARTE 1 DE ICONO DE CERRAR SESIÓN.png" Stretch="Fill" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform X="10" Y="-2"/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Image Margin="19,393,769,33" Source="/PARTE 2 DE ICONO DE CERRAR SESIÓN.png" Stretch="Fill" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform X="10" Y="-2"/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Rectangle HorizontalAlignment="Left" Height="50" Margin="171,0,0,0" Stroke="#FF12224B" VerticalAlignment="Top" Width="629" Fill="#FF12224B"/>
        <TextBlock HorizontalAlignment="Left" Margin="181,17,0,0" TextWrapping="Wrap" Text="¡Hola, Oscar Sosa!" VerticalAlignment="Top" Foreground="White" FontSize="15" FontWeight="Bold"/>
        <TextBlock HorizontalAlignment="Left" Margin="728,30,0,0" TextWrapping="Wrap" Text="Clientes" VerticalAlignment="Top" Foreground="White" FontSize="10" FontWeight="Bold"/>
    </Grid>
</Window>
