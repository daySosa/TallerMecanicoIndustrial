<Window x:Class="Contabilidad.ComprobanteDePago"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:Contabilidad"
        mc:Ignorable="d"
        Title="ComprobanteDePago" Height="420" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1e2130"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Border Padding="24" Background="#1e2130">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TÍTULO -->
            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,0,20">
                <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4CAF50"
                                         Width="24" Height="24" VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>
                <TextBlock Text="Comprobante de Pago"
                           Foreground="White" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- CONTENIDO -->
            <StackPanel Grid.Row="1">

                <!-- CARD SUPERIOR: MONTO DESTACADO -->
                <Border Background="#0a2a1a" BorderBrush="#4CAF50"
                        BorderThickness="1" CornerRadius="10"
                        Padding="20,16" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="MONTO PAGADO"
                                       Foreground="#4CAF50" FontSize="11"
                                       FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBlock x:Name="lblMonto"
                                       Foreground="White" FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="PAGO ID"
                                       Foreground="#6B7280" FontSize="10"
                                       HorizontalAlignment="Right" Margin="0,0,0,4"/>
                            <TextBlock x:Name="lblPagoID"
                                       Foreground="#4CAF50" FontSize="16"
                                       FontWeight="Bold" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- DETALLES EN GRID -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" MinWidth="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- DNI -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="DNI Cliente:" Foreground="#6B7280"
                               FontSize="12" Margin="0,0,0,14"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="lblDNI"
                               Foreground="White" FontSize="13" FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <!-- Orden ID -->
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="Orden ID:" Foreground="#6B7280"
                               FontSize="12" Margin="0,0,0,14"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" x:Name="lblOrdenID"
                               Foreground="White" FontSize="13" FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <!-- Nombre -->
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Cliente:" Foreground="#6B7280"
                               FontSize="12" Margin="0,0,0,14"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="lblNombre"
                               Foreground="White" FontSize="13" FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <!-- Fecha -->
                    <TextBlock Grid.Row="1" Grid.Column="2"
                               Text="Fecha:" Foreground="#6B7280"
                               FontSize="12" Margin="0,0,0,14"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" x:Name="lblFecha"
                               Foreground="White" FontSize="13"
                               Margin="0,0,0,14"/>

                </Grid>

            </StackPanel>

            <!-- BOTÓN CERRAR -->
            <Button Grid.Row="2"
                    Content="Cerrar"
                    Height="40" Width="140"
                    HorizontalAlignment="Right"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    BorderBrush="#6c7293" Foreground="#6c7293"
                    materialDesign:ButtonAssist.CornerRadius="8"/>

        </Grid>
    </Border>
</Window>