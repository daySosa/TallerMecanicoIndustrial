<Window x:Class="Contabilidad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:Contabilidad"
        mc:Ignorable="d"
        Title="MainWindow" Height="850" Width="1200"
        Background="#1F2128"
        WindowStartupLocation="CenterScreen">


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="20*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== MENÚ IZQUIERDO ===== -->
        <materialDesign:ColorZone Grid.Column="0" CornerRadius="15 0 0 15"
                                  Background="#242731" VerticalAlignment="Stretch">
            <StackPanel Margin="15,0,15,0">

                <WrapPanel Margin="0 10 5 60" HorizontalAlignment="Center" Height="184" Width="185">
                    <Image Source="/Imagenes/OSM_LOGO.png" Height="204" Width="195"/>
                </WrapPanel>

                <!-- PANTALLA PRINCIPAL -->
                <Button x:Name="btnPantallaPrincipal"
                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,-40,0,15"
                        Click="btnPantallaPrincipal_Click">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="Home" VerticalAlignment="Center"
                                                 Foreground="White" Height="25" Width="38" HorizontalAlignment="Center"/>
                        <TextBlock Foreground="White" FontSize="15" Height="16">Pantalla Principal</TextBlock>
                    </WrapPanel>
                </Button>

                <!-- INVENTARIO -->
                <Button x:Name="btnInventario"
                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15"
                        Click="btnInventario_Click">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="PackageVariant" VerticalAlignment="Center"
                                                 Foreground="White" Height="26" Width="38" HorizontalAlignment="Center"/>
                        <TextBlock Foreground="White" FontSize="15" Width="142" Height="20">Inventario</TextBlock>
                    </WrapPanel>
                </Button>

                <!-- VEHÍCULOS -->
                <Button x:Name="btnVehiculos"
                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15"
                        Click="btnVehiculos_Click">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="CarSportsUtilityVehicle" VerticalAlignment="Center"
                                                 Foreground="White" Width="39" HorizontalAlignment="Center" Height="25"/>
                        <TextBlock Foreground="White" FontSize="15" Height="19">Vehículos</TextBlock>
                    </WrapPanel>
                </Button>

                <!-- CLIENTES -->
                <Button x:Name="btnClientes"
                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15"
                        Click="btnClientes_Click">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="People" VerticalAlignment="Center"
                                                 Foreground="White" Height="25" Width="39"/>
                        <TextBlock Foreground="White" FontSize="15" Width="77" Height="18">Clientes</TextBlock>
                    </WrapPanel>
                </Button>

                <!-- CONTABILIDAD EXPANDER -->
                <Expander Background="#242731" Foreground="White" FontFamily="Segoe UI" FontSize="13"
                          BorderThickness="0" Width="Auto" Height="Auto" Margin="0,0,0,15">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Width="250">
                            <materialDesign:PackIcon Kind="BookOpenPageVariant" VerticalAlignment="Center"
                                                     Margin="5,0,10,0" Foreground="White" Height="18" Width="35"/>
                            <TextBlock Foreground="White" FontSize="15">Contabilidad</TextBlock>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Background="#242731">

                        <!-- EGRESOS -->
                        <Button x:Name="btnEgresos"
                                Background="#242731" BorderThickness="0" Foreground="White"
                                FontSize="15" HorizontalContentAlignment="Left"
                                Click="btnEgresos_Click">
                            <StackPanel Orientation="Horizontal" Width="250">
                                <materialDesign:PackIcon Kind="CurrencyUsd" VerticalAlignment="Center"
                                                         Margin="15,0,20,0" Foreground="White"/>
                                <TextBlock Text="Egresos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- INGRESOS -->
                        <Button x:Name="btnIngresos"
                                Background="#242731" BorderThickness="0" Foreground="White"
                                FontSize="15" HorizontalContentAlignment="Left"
                                Click="btnIngresos_Click">
                            <StackPanel Orientation="Horizontal" Width="250">
                                <materialDesign:PackIcon Kind="CreditCard" VerticalAlignment="Center"
                                                         Margin="15,0,20,0" Foreground="White"/>
                                <TextBlock Text="Ingresos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Expander>

                <!-- ÓRDENES -->
                <Button x:Name="btnOrdenes"
                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15"
                        Click="btnOrdenes_Click">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="OrderBoolAscending" VerticalAlignment="Center"
                                                 Foreground="White" Height="25" Width="39"/>
                        <TextBlock Foreground="White" FontSize="15" Height="18">Órdenes</TextBlock>
                    </WrapPanel>
                </Button>

                <!-- CERRAR SESIÓN -->
                <Button x:Name="btnCerrarSesion"
                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="210"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,70,0,15"
                        Click="btnCerrarSesion_Click">
                    <WrapPanel Width="175">
                        <materialDesign:PackIcon Kind="LogoutVariant" VerticalAlignment="Center"
                                                 Foreground="White" Width="39" HorizontalAlignment="Center" Height="21"/>
                        <TextBlock Foreground="White" FontSize="15" Height="21">Cerrar Sesión</TextBlock>
                    </WrapPanel>
                </Button>

            </StackPanel>
        </materialDesign:ColorZone>

        <!-- ===== CONTENIDO PRINCIPAL ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== TOP BAR ===== -->
            <Border Grid.Row="0" Background="#1A1D2E" Height="80">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="25,0,20,0">
                        <TextBlock Text="Contabilidad — Egresos"
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Gestiona los egresos del taller"
                                   Foreground="#6B7280" FontSize="12"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#252836" CornerRadius="5"
                            VerticalAlignment="Center" Height="40" MaxWidth="400"
                            HorizontalAlignment="Left" Margin="20,0,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                            <materialDesign:PackIcon Kind="Magnify" Foreground="#6B7280"
                                                     Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="txtBuscar"
                                     Background="Transparent" Foreground="#6B7280"
                                     BorderThickness="0" VerticalAlignment="Center"
                                     FontSize="13" Width="200" CaretBrush="White"
                                     TextChanged="txtBuscar_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Setter Property="materialDesign:HintAssist.Hint" Value="Buscar gasto..."/>
                                        <Setter Property="materialDesign:HintAssist.Foreground" Value="#6B7280"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </Border>

                    <!-- ===== CAMPANA CON BADGE ===== -->
                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="16,0">
                        <Button x:Name="btnNotificaciones"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Foreground="#6B7280" Width="38" Height="38"
                                Click="btnNotificaciones_Click">
                            <materialDesign:PackIcon Kind="BellOutline" Width="22" Height="22"/>
                        </Button>

                        <!-- BADGE ROJO CON NÚMERO -->
                        <Border x:Name="badgeNotificaciones"
                                Background="#FF4444"
                                CornerRadius="8" Width="16" Height="16"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Visibility="Collapsed">
                            <TextBlock x:Name="txtContadorNotificaciones"
                                       Text="0" Foreground="White"
                                       FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <Rectangle Grid.Column="3" Fill="#3D4458" Margin="0,20"/>

                    <StackPanel Grid.Column="4" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,20,0">
                        <Border Width="38" Height="38" CornerRadius="18" ClipToBounds="True"
                                Margin="0,0,10,0" BorderBrush="#3D7EFF" BorderThickness="2"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Oscar Sosa" Foreground="#3D7EFF" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Propietario" Foreground="#6B7280" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== TOOLBAR: BOTONES ===== -->
            <Grid Grid.Row="1" Margin="20,15,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- AGREGAR -->
                <Button x:Name="btnAgregar"
                        Grid.Column="0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#3D7EFF" Foreground="White"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        materialDesign:ElevationAssist.Elevation="Dp0"
                        Height="38" Padding="16,0" Margin="0,0,10,0"
                        Click="btnAgregar_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Agregar" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>

                <!-- ACTUALIZAR -->
                <Button x:Name="btnActualizar"
                        Grid.Column="1"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#3D7EFF" BorderBrush="#3D7EFF"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Height="38" Padding="16,0" Margin="0,0,10,0"
                        Click="btnActualizar_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Actualizar" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>

                <!-- MOSTRAR COMPROBANTE -->
                <Button x:Name="btnMostrarComprobante"
                        Grid.Column="2"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#6B7280" BorderBrush="#3D4458"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Height="38" Padding="16,0"
                        Click="btnMostrarComprobante_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocumentOutline" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Mostrar Comprobante" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>

            </Grid>

            <!-- ===== CARD CON DATAGRID ===== -->
            <materialDesign:Card Grid.Row="2"
                                 Background="#1E2A3A"
                                 materialDesign:ElevationAssist.Elevation="Dp4"
                                 UniformCornerRadius="10"
                                 Margin="20,0,20,20"
                                 VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,16"
                            BorderBrush="#2A3A4D" BorderThickness="0,0,0,1">
                        <TextBlock Text="Registro de Gastos"
                                   Foreground="White" FontSize="15" FontWeight="Medium"/>
                    </Border>

                    <DataGrid Grid.Row="1" x:Name="dgGastos"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserResizeRows="False" IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2A3A4D"
                              VerticalGridLinesBrush="Transparent"
                              Background="Transparent" Foreground="White"
                              BorderThickness="0" RowBackground="Transparent"
                              AlternatingRowBackground="#162030"
                              ColumnHeaderHeight="40" RowHeight="55"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#8B9BB4"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#2A3A4D"/>
                                <Setter Property="SeparatorVisibility" Value="Collapsed"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A2A3D"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2A3A4D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="{x:Type DataGridCell}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ID" Binding="{Binding Gasto_ID}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="#8B9BB4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Tipo de Gasto" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12" Padding="10,4"
                                                HorizontalAlignment="Left" Margin="12,0" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Tipo_Gasto}" Value="Gasto en Repuesto">
                                                            <Setter Property="Background" Value="#2A1200"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Tipo_Gasto}" Value="Gasto Adicional">
                                                            <Setter Property="Background" Value="#2A1E00"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Tipo_Gasto}" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Tipo_Gasto}" Value="Gasto en Repuesto">
                                                                <Setter Property="Foreground" Value="#FF6B35"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Tipo_Gasto}" Value="Gasto Adicional">
                                                                <Setter Property="Foreground" Value="#F0A500"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Nombre del Gasto" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                            <Border Width="34" Height="34" CornerRadius="17"
                                                    Background="#2A3A4D" Margin="0,0,10,0">
                                                <materialDesign:PackIcon Kind="CurrencyUsd" Foreground="#8B9BB4"
                                                                         Width="18" Height="18"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Nombre_Gasto}"
                                                       Foreground="White" FontSize="13" FontWeight="Medium"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Precio"
                                                Binding="{Binding Precio_Gasto, StringFormat=S/\{0:N2\}}"
                                                Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="#FF6B6B"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Margin" Value="0,0,12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Fecha" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="12,0">
                                            <TextBlock Text="{Binding Fecha_Gasto, StringFormat=MMMM dd\, yyyy}"
                                                       Foreground="White" FontSize="12"/>
                                            <TextBlock Text="{Binding Fecha_Gasto, StringFormat=hh:mm tt}"
                                                       Foreground="#8B9BB4" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

        </Grid>
    </Grid>
</Window>