<Window x:Class="Contabilidad.AgregarPago"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:Contabilidad"
        mc:Ignorable="d"
        Title="AgregarPago" Height="420" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1e2130"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Border Padding="24" Background="#1e2130">
        <StackPanel>

            <TextBlock Text="Nuevo Pago"
                       Foreground="White" FontSize="16" FontWeight="Bold"
                       Margin="0,0,0,24"/>

            <!-- DNI DEL CLIENTE -->
            <TextBlock Text="DNI DEL CLIENTE"
                       Foreground="#a0a8c8" FontSize="11" FontWeight="Medium"
                       Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtDNI"
                         Grid.Column="0"
                         Height="47" Foreground="White" CaretBrush="White"
                         Background="#252836" BorderBrush="#3a3f5c"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Ingresa el DNI..."/>
                <Button Grid.Column="2"
                        Content="Buscar"
                        Height="42" Padding="16,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        BorderBrush="#3D7EFF" Foreground="#3D7EFF"
                        materialDesign:ButtonAssist.CornerRadius="8"/>
            </Grid>

            <!-- NOMBRE DEL CLIENTE (se llena solo) -->
            <TextBlock Text="NOMBRE DEL CLIENTE"
                       Foreground="#a0a8c8" FontSize="11" FontWeight="Medium"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="txtNombreCliente"
                     Height="47" Margin="0,0,0,16"
                     Foreground="#6B7280" IsReadOnly="True"
                     Background="#1a1d2e" BorderBrush="#3a3f5c"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="Se llena automáticamente..."/>

            <!-- FILA: ORDEN ID Y MONTO -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="ID DE LA ORDEN"
                               Foreground="#a0a8c8" FontSize="11" FontWeight="Medium"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="txtOrdenID"
                             Height="47" Foreground="White" CaretBrush="White"
                             Background="#252836" BorderBrush="#3a3f5c"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Ej: 1"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="MONTO A PAGAR"
                               Foreground="#a0a8c8" FontSize="11" FontWeight="Medium"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="txtMonto"
                             Height="47" Foreground="White" CaretBrush="White"
                             Background="#252836" BorderBrush="#3a3f5c"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="0.00"/>
                </StackPanel>
            </Grid>

            <!-- BOTONES -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancelar"
                        Height="40"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        BorderBrush="#6c7293" Foreground="#6c7293"
                        materialDesign:ButtonAssist.CornerRadius="8" Click="Button_Click"/>

                <Button Grid.Column="2" Content="Guardar Pago"
                        Height="40"
                        materialDesign:ButtonAssist.CornerRadius="8" Click="Button_Click_1">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                            <Setter Property="Background" Value="#3D7EFF"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="#3D7EFF"/>
                            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
                        </Style>
                    </Button.Style>
                </Button>

            </Grid>
        </StackPanel>
    </Border>
</Window>