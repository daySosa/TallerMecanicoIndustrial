<Window x:Class="Contabilidad.ComprobantePago"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Contabilidad"
        Title="Comprobante de Pago" Height="430" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Opacity="0"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <DropShadowEffect x:Key="WinShadow" Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.70"/>

        <Style x:Key="DataLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#505880"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="DataValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Window.Resources>

    <Border Effect="{StaticResource WinShadow}" CornerRadius="14">
        <Border CornerRadius="14" ClipToBounds="True" Background="#0f1117">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#13161f"
                        BorderBrush="#1e2235" BorderThickness="0,0,0,1">
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="30" Height="30" CornerRadius="8"
                                    Background="#0f2a1a" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="#4CAF50"
                                                         Width="16" Height="16"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Comprobante de Pago"
                                           Foreground="White" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="Transacción registrada correctamente"
                                           Foreground="#505880" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="24,20,24,10">


                    <Border Background="#0a2a1a" BorderBrush="#1f4d33"
                            BorderThickness="1" CornerRadius="10"
                            Padding="18,14" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MONTO PAGADO"
                                           Foreground="#4CAF50" FontSize="10"
                                           FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBlock x:Name="lblMonto"
                                           Foreground="White" FontSize="26"
                                           FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="PAGO ID"
                                           Foreground="#505880" FontSize="10"
                                           HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <TextBlock x:Name="lblPagoID"
                                           Foreground="#4CAF50" FontSize="15"
                                           FontWeight="Bold" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="#13161f" CornerRadius="10"
                            BorderBrush="#1e2235" BorderThickness="1"
                            Padding="18,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="DNI CLIENTE" Style="{StaticResource DataLabel}"/>
                                <TextBlock x:Name="lblDNI" Style="{StaticResource DataValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="ORDEN ID" Style="{StaticResource DataLabel}"/>
                                <TextBlock x:Name="lblOrdenID" Style="{StaticResource DataValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="CLIENTE" Style="{StaticResource DataLabel}"/>
                                <TextBlock x:Name="lblNombre" Style="{StaticResource DataValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="FECHA" Style="{StaticResource DataLabel}"/>
                                <TextBlock x:Name="lblFecha" Style="{StaticResource DataValue}" FontWeight="Normal"/>
                            </StackPanel>

                        </Grid>
                    </Border>

                </StackPanel>

                <Border Grid.Row="2" Background="#13161f"
                        BorderBrush="#1e2235" BorderThickness="0,1,0,0"
                        Padding="24,14">
                    <Button x:Name="btnCerrar"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#4f6ef7" Foreground="White"
                            BorderBrush="#4f6ef7"
                            materialDesign:ElevationAssist.Elevation="Dp0"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Height="42" FontSize="13" FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            Content="Cerrar"
                            Click="btnCerrar_Click"/>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>