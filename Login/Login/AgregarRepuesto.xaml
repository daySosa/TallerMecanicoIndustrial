<Window x:Class="Órdenes_de_Trabajo.AgregarRepuesto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Órdenes_de_Trabajo"
        mc:Ignorable="d"
        Title="Agregar Repuesto" Height="460" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1e2130">

    <Border Padding="24">
        <StackPanel>

            <TextBlock Text="Agregar Repuesto" Foreground="White"
                       FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="PRODUCTO" Foreground="#a0a8c8"
                       FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
            <ComboBox x:Name="cmbProducto"
                      Height="40" Margin="0,0,0,14"
                      Background="#252836" Foreground="White"
                      BorderBrush="#3a3f5c" BorderThickness="1"
                      DisplayMemberPath="Producto_Nombre"
                      Padding="8,0,10,0"
                      VerticalContentAlignment="Center"
                      SelectionChanged="cmbProducto_SelectionChanged">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#252836"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3a3f5c"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2e3250"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.ItemContainerStyle>
            </ComboBox>

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="CATEGORÍA" Foreground="#a0a8c8"
                               FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
                    <Border Background="#1a1d2e" BorderBrush="#3a3f5c"
                            BorderThickness="1" CornerRadius="6" Padding="10,8">
                        <TextBox x:Name="txtCategoria"
                                 Foreground="#6c7293" Background="Transparent"
                                 BorderThickness="0" IsReadOnly="True"
                                 Text="-" FontSize="13"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="PRECIO UNIT." Foreground="#a0a8c8"
                               FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
                    <Border Background="#1a1d2e" BorderBrush="#3a3f5c"
                            BorderThickness="1" CornerRadius="6" Padding="10,8">
                        <TextBox x:Name="txtPrecioUnitario"
                                 Foreground="#6c7293" Background="Transparent"
                                 BorderThickness="0" IsReadOnly="True"
                                 Text="L 0.00" FontSize="13"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="STOCK" Foreground="#a0a8c8"
                               FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
                    <Border x:Name="borderStock" Background="#1a1d2e" BorderBrush="#3a3f5c"
                            BorderThickness="1" CornerRadius="6" Padding="10,8">
                        <TextBox x:Name="txtStock"
                                 Foreground="#6c7293" Background="Transparent"
                                 BorderThickness="0" IsReadOnly="True"
                                 Text="0" FontSize="13"/>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="CANTIDAD" Foreground="#a0a8c8"
                               FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
                    <Border Background="#252836" BorderBrush="#3a3f5c"
                            BorderThickness="1" CornerRadius="6" Padding="10,8">
                        <TextBox x:Name="txtCantidad"
                                 Foreground="White" Background="Transparent"
                                 BorderThickness="0" Text="1"
                                 FontSize="13" TextChanged="txtCantidad_TextChanged"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="SUBTOTAL" Foreground="#a0a8c8"
                               FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
                    <Border Background="#2e3250" BorderBrush="#4f6ef7"
                            BorderThickness="1" CornerRadius="6" Padding="10,8">
                        <TextBox x:Name="txtSubtotal"
                                 Foreground="#4f6ef7" Background="Transparent"
                                 BorderThickness="0" IsReadOnly="True"
                                 FontWeight="Bold" Text="L 0.00" FontSize="13"/>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancelar"
                        Height="40"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        BorderBrush="#6c7293" Foreground="#6c7293"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Click="btnCancelar_Click"/>

                <Button Grid.Column="2" Content="Agregar Repuesto"
                        Height="40"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Click="btnAgregar_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                            <Setter Property="Background" Value="#4f6ef7"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="#4f6ef7"/>
                            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

        </StackPanel>
    </Border>
</Window>