<Window x:Class="Contabilidad.ComprobanteEgresos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Contabilidad"
        Title="Comprobante de Gasto" Height="500" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <DropShadowEffect x:Key="WinShadow" Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.70"/>

        <Style x:Key="DataLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#505880"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="DataValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Window.Resources>

    <Border Effect="{StaticResource WinShadow}" CornerRadius="14">
        <Border CornerRadius="14" ClipToBounds="True" Background="#0f1117">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ===== HEADER ===== -->
                <Border Grid.Row="0" Background="#13161f"
                        BorderBrush="#1e2235" BorderThickness="0,0,0,1">
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="30" Height="30" CornerRadius="8"
                                    Background="#2a0f0f" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="ReceiptTextOutline" Foreground="#E74C3C"
                                                         Width="16" Height="16"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Comprobante de Gasto"
                                           Foreground="White" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="Detalle del egreso registrado"
                                           Foreground="#505880" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== CONTENIDO ===== -->
                <StackPanel Grid.Row="1" Margin="24,20,24,10">

                    <!-- Información principal del gasto -->
                    <Border Background="#13161f" CornerRadius="10"
                            BorderBrush="#1e2235" BorderThickness="1"
                            Padding="18,16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ID" Style="{StaticResource DataLabel}"/>
                                <TextBlock x:Name="lblID" Style="{StaticResource DataValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="TIPO" Style="{StaticResource DataLabel}"/>
                                <Border x:Name="borderTipo" CornerRadius="10" Padding="8,3"
                                        HorizontalAlignment="Left">
                                    <TextBlock x:Name="lblTipo" FontSize="11" FontWeight="Medium"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="FECHA" Style="{StaticResource DataLabel}"/>
                                <TextBlock x:Name="lblFecha" Style="{StaticResource DataValue}" FontWeight="Normal"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Monto destacado -->
                    <Border Background="#2a0f0f" BorderBrush="#4d1f1f"
                            BorderThickness="1" CornerRadius="10"
                            Padding="18,14" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MONTO DEL GASTO"
                                           Foreground="#E74C3C" FontSize="10"
                                           FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBlock x:Name="lblPrecio"
                                           Foreground="White" FontSize="26"
                                           FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="NOMBRE" Foreground="#505880" FontSize="10"
                                           HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                <TextBlock x:Name="lblNombre"
                                           Foreground="#E74C3C" FontSize="14"
                                           FontWeight="Bold" HorizontalAlignment="Right"
                                           MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Observaciones -->
                    <Border Background="#13161f" CornerRadius="10"
                            BorderBrush="#1e2235" BorderThickness="1"
                            Padding="18,16">
                        <StackPanel>
                            <TextBlock Text="OBSERVACIONES" Style="{StaticResource DataLabel}"/>
                            <TextBlock x:Name="lblObservaciones"
                                       Foreground="#8890b5" FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ===== FOOTER ===== -->
                <Border Grid.Row="2" Background="#13161f"
                        BorderBrush="#1e2235" BorderThickness="0,1,0,0"
                        Padding="24,14">
                    <Button x:Name="btnCerrar"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#4f6ef7" Foreground="White"
                            BorderBrush="#4f6ef7"
                            materialDesign:ElevationAssist.Elevation="Dp0"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Height="42" FontSize="13" FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            Content="Cerrar"
                            Click="btnCerrar_Click"/>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>