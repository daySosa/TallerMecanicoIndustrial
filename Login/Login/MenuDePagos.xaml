<Window x:Class="Contabilidad.MenuDePagos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Contabilidad"
        Title="MenuDePagos" Height="850" Width="1200"
        Background="#1F2128" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#242731">
            <DockPanel LastChildFill="False">

                <Border DockPanel.Dock="Top" Padding="20,20,20,10">
                    <Image RenderOptions.BitmapScalingMode="HighQuality"
                           Source="/Imagenes/OSM_LOGO.png" Height="120"/>
                </Border>

                <Rectangle DockPanel.Dock="Top" Height="1" Fill="#2e3250" Margin="16,0,16,10"/>

                <StackPanel DockPanel.Dock="Top" Margin="10,0">

                    <Button x:Name="btnPantallaPrincipal" Height="40" Margin="0,5"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Cursor="Hand"
                            Click="btnPantallaPrincipal_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="8" Padding="10,0">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="MouseOver">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="bg"
                                                        Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                        To="#2e3250" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Normal">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="bg"
                                                        Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                        To="Transparent" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Home" Foreground="#8890b5"
                                                     Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Pantalla Principal" Foreground="#8890b5" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnInventario" Height="40" Margin="0,10"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Cursor="Hand"
                            Click="btnInventario_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="8" Padding="10,0">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="MouseOver">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="bg"
                                                        Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                        To="#2e3250" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Normal">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="bg"
                                                        Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                        To="Transparent" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PackageVariant" Foreground="#8890b5"
                                                     Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Inventario" Foreground="#8890b5" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnVehículos" Height="40" Margin="0,10"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Cursor="Hand"
                            Click="btnVehículos_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="8" Padding="10,0">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="MouseOver">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="bg"
                                                        Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                        To="#2e3250" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Normal">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="bg"
                                                        Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                        To="Transparent" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CarSportsUtilityVehicle" Foreground="#8890b5"
                                                     Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Vehículos" Foreground="#8890b5" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnClientes" Height="40" Margin="0,10"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Cursor="Hand"
                            Click="btnClientes_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="8" Padding="10,0">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="MouseOver">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="bg"
                                                        Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                        To="#2e3250" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Normal">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="bg"
                                                        Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                        To="Transparent" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="People" Foreground="#8890b5"
                                                     Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Clientes" Foreground="#8890b5" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnÓrdenes" Height="40" Margin="0,10"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Cursor="Hand"
                            Click="btnÓrdenes_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="8" Padding="10,0">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="MouseOver">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="bg"
                                                        Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                        To="#2e3250" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Normal">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="bg"
                                                        Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                        To="Transparent" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="OrderBoolAscending" Foreground="#8890b5"
                                                     Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Órdenes" Foreground="#8890b5" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnUsuario" Height="40" Margin="0,10"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Cursor="Hand"
                            Click="btnUsuario_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="8" Padding="10,0">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="MouseOver">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="bg"
                                                        Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                        To="#2e3250" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Normal">
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="bg"
                                                        Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                        To="Transparent" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountCog" Foreground="#8890b5"
                                                     Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Usuarios" Foreground="#8890b5" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Expander Background="Transparent" Foreground="#8890b5"
                              BorderThickness="0" Margin="-8,5,0,2">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal" Margin="-4,0,0,0">
                                <materialDesign:PackIcon Kind="BookOpenPageVariant" Foreground="#8890b5"
                                                         Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Contabilidad" Foreground="#8890b5" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Margin="28,4,0,4">
                            <Button Height="36" Background="Transparent" BorderThickness="0"
                                    HorizontalContentAlignment="Left" Cursor="Hand"
                                    Click="btnEgresos_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="Transparent" CornerRadius="8" Padding="10,0">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CurrencyUsd" Foreground="#8890b5"
                                                             Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Egresos" Foreground="#8890b5" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Border  CornerRadius="8" Padding="10,8" Margin="0,2">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CreditCard" Foreground="#8890b5"
                                                             Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Ingresos" Foreground="#8890b5" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Expander>

                </StackPanel>

                <Rectangle DockPanel.Dock="Bottom" Height="1" Fill="#2e3250" Margin="16,0,16,0"/>


                <Button DockPanel.Dock="Bottom" Height="40" Margin="10,4,10,8"
                        Background="Transparent" BorderThickness="0"
                        HorizontalContentAlignment="Left" Cursor="Hand"
                        Click="btnCerrarSesion_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="8" Padding="10,0">
                                <ContentPresenter VerticalAlignment="Center"/>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="MouseOver">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="bg"
                                                    Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                    To="#3d1b1b" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Normal">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="bg"
                                                    Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                    To="Transparent" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="LogoutVariant" Foreground="#E74C3C"
                                                 Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Cerrar Sesión" Foreground="#E74C3C" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Rectangle DockPanel.Dock="Bottom" Height="1" Fill="#2e3250" Margin="16,0,16,0"/>

                <Border DockPanel.Dock="Bottom" Margin="12,8,12,12"
                        Background="#1e2130" CornerRadius="10"
                        BorderBrush="#2e3250" BorderThickness="1"
                        Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                Background="#2e3250" Margin="0,0,10,0">
                            <TextBlock x:Name="txtIniciales" Text="OS"
                                       Foreground="#4f6ef7" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="txtNombreUsuario" Text="Oscar Sosa"
                                       Foreground="White" FontSize="12" FontWeight="Medium"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="txtRolUsuario" Text="Propietario"
                                       Foreground="#4f6ef7" FontSize="10"/>
                        </StackPanel>

                        <Ellipse Grid.Column="2" Width="8" Height="8"
                                 Fill="#4CAF50" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1A1D2E" Height="70">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="25,0,20,0">
                        <TextBlock Text="Contabilidad — Ingresos" Foreground="White" FontSize="17" FontWeight="Bold"/>
                        <TextBlock Text="Gestiona los pagos recibidos" Foreground="#6B7280" FontSize="11"/>
                    </StackPanel>

                    <Border Background="#252836" CornerRadius="8"
                            VerticalAlignment="Center" Height="38" MaxWidth="340"
                            HorizontalAlignment="Left" Margin="290,0,0,0" Grid.ColumnSpan="2" Width="490">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                            <materialDesign:PackIcon Kind="Magnify" Foreground="#6B7280"
                                                     Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="txtBuscar"
                                     Background="Transparent" Foreground="White"
                                     BorderThickness="0" VerticalAlignment="Center"
                                     FontSize="13" Width="200" CaretBrush="White"
                                     materialDesign:HintAssist.Hint="Buscar pago..."
                                     materialDesign:HintAssist.Foreground="#6B7280"
                                     TextChanged="txtBuscar_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}"/>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="16,0,20,0">
                        <Button x:Name="btnNotificaciones"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Foreground="#6B7280" Width="38" Height="38"
                                Click="btnNotificaciones_Click">
                            <materialDesign:PackIcon Kind="BellOutline" Width="22" Height="22"/>
                        </Button>
                        <Border x:Name="badgeNotificaciones" Background="#FF4444" CornerRadius="8"
                                Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Visibility="Collapsed">
                            <TextBlock x:Name="txtContadorNotificaciones" Text="0" Foreground="White"
                                       FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Popup x:Name="popupNotificaciones"
                               PlacementTarget="{Binding ElementName=btnNotificaciones}"
                               Placement="Bottom" StaysOpen="False"
                               AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="#252836" CornerRadius="10"
                                    BorderBrush="#2A3A4D" BorderThickness="1"
                                    Width="360" MaxHeight="480">
                                <Grid Margin="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="BellOutline" Foreground="White"
                                                                     Width="18" Height="18"
                                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Notificaciones" Foreground="White"
                                                       FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" x:Name="badgeContadorPopup"
                                                Background="#FF4444" CornerRadius="10"
                                                Padding="8,2" VerticalAlignment="Center"
                                                Visibility="Collapsed">
                                            <TextBlock x:Name="txtContadorPopup" Text="0" Foreground="White"
                                                       FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                    <Rectangle Grid.Row="2" Height="1" Fill="#2A3A4D"/>
                                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" MaxHeight="320">
                                        <StackPanel x:Name="panelNotificaciones"/>
                                    </ScrollViewer>
                                    <Button Grid.Row="6" x:Name="btnMarcarTodas"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="#3D7EFF" BorderBrush="#3D7EFF"
                                            materialDesign:ButtonAssist.CornerRadius="8"
                                            Height="36" FontSize="12" Visibility="Collapsed"
                                            Click="btnMarcarTodas_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CheckAll" Width="16" Height="16"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Marcar todas como leídas" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20,14,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnAgregar" Grid.Column="0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#3D7EFF" Foreground="White"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        materialDesign:ElevationAssist.Elevation="Dp0"
                        Height="38" Padding="16,0" Margin="0,0,10,0"
                        Click="btnAgregar_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Agregar Pago" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#2E7D32" Foreground="White"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        materialDesign:ElevationAssist.Elevation="Dp0"
                        Height="38" Padding="16,0" Margin="0,0,10,0"
                        Click="btnReportes_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilePdfBox" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Reportes" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnMostrarComprobantes" Grid.Column="2"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#6B7280" BorderBrush="#3D4458"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Height="38" Padding="16,0"
                        Click="btnMostrarComprobantes_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocumentOutline" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Ver Comprobante" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>

            <materialDesign:Card Grid.Row="2" Background="#1E2A3A"
                                 materialDesign:ElevationAssist.Elevation="Dp4"
                                 UniformCornerRadius="10" Margin="20,0,20,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,14"
                            BorderBrush="#2A3A4D" BorderThickness="0,0,0,1">
                        <TextBlock Text="Registro de Pagos" Foreground="White" FontSize="14" FontWeight="Medium"/>
                    </Border>

                    <DataGrid Grid.Row="1" x:Name="dgPagos"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserResizeRows="False" CanUserReorderColumns="False"
                              CanUserResizeColumns="False"
                              IsReadOnly="True" SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2A3A4D"
                              VerticalGridLinesBrush="Transparent"
                              Background="Transparent" Foreground="White"
                              BorderThickness="0" RowBackground="Transparent"
                              AlternatingRowBackground="#162030"
                              ColumnHeaderHeight="40" RowHeight="52"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              EnableRowVirtualization="True"
                              MouseDoubleClick="dgPagos_MouseDoubleClick"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#8B9BB4"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#2A3A4D"/>
                                <Setter Property="SeparatorVisibility" Value="Collapsed"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A2A3D"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2A3A4D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="{x:Type DataGridCell}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Pago_ID}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#8B9BB4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Cliente" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                            <Border Width="32" Height="32" CornerRadius="16"
                                                    Background="#2A3A4D" Margin="0,0,10,0">
                                                <materialDesign:PackIcon Kind="Account" Foreground="#8B9BB4"
                                                                         Width="16" Height="16"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Cliente_Nombres}"
                                                           Foreground="White" FontSize="13" FontWeight="Medium"/>
                                                <TextBlock Text="{Binding Cliente_DNI, StringFormat='DNI: {0}'}"
                                                           Foreground="#8B9BB4" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Orden ID" Binding="{Binding Orden_ID}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#8B9BB4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Monto"
                                                Binding="{Binding Precio_Pago, StringFormat='L {0:N2}'}"
                                                Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="12,0,0,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Fecha" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Fecha_Pago, StringFormat='dd/MM/yyyy'}"
                                                   Foreground="White" FontSize="12"
                                                   VerticalAlignment="Center" Margin="12,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

        </Grid>
    </Grid>
</Window>