<Window x:Class="Contabilidad.MenuDePagos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:Contabilidad"
        mc:Ignorable="d"
        Title="MenuDePagos" Height="850" Width="1200"
        Background="#1F2128"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="20*"/>
        </Grid.ColumnDefinitions>

        <materialDesign:ColorZone Grid.Column="0" CornerRadius="15 0 0 15"
                                  Background="#242731" VerticalAlignment="Stretch">
            <StackPanel Margin="15,0,15,0">

                <WrapPanel Margin="0,10,5,60" HorizontalAlignment="Center" Height="184" Width="185">
                    <Image RenderOptions.BitmapScalingMode="HighQuality"
                           Source="/Imagenes/OSM_LOGO.png" Height="184"/>
                </WrapPanel>

                <Button x:Name="btnPantallaPrincipal" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,-40,0,15" Click="btnPantallaPrincipal_Click">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="Home" VerticalAlignment="Center" Foreground="White" Height="25" Width="38"/>
                        <TextBlock Foreground="White" FontSize="15">Pantalla Principal</TextBlock>
                    </WrapPanel>
                </Button>

                <Button x:Name="btnInventario" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15" Click="btnInventario_Click">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="PackageVariant" VerticalAlignment="Center" Foreground="White" Height="26" Width="38"/>
                        <TextBlock Foreground="White" FontSize="15">Inventario</TextBlock>
                    </WrapPanel>
                </Button>

                <Button x:Name="btnVehículos" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15" Click="btnVehículos_Click">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="CarSportsUtilityVehicle" VerticalAlignment="Center" Foreground="White" Width="39" Height="25"/>
                        <TextBlock Foreground="White" FontSize="15">Vehículos</TextBlock>
                    </WrapPanel>
                </Button>

                <Button x:Name="btnClientes" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15" Click="btnClientes_Click">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="People" VerticalAlignment="Center" Foreground="White" Height="25" Width="39"/>
                        <TextBlock Foreground="White" FontSize="15">Clientes</TextBlock>
                    </WrapPanel>
                </Button>

                <Expander Background="#242731" Foreground="White" FontFamily="Segoe UI" FontSize="13"
                          BorderThickness="0" Width="Auto" Margin="0,0,0,15">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Width="250">
                            <materialDesign:PackIcon Kind="BookOpenPageVariant" VerticalAlignment="Center"
                                                     Margin="5,0,10,0" Foreground="White" Height="18" Width="35"/>
                            <TextBlock Foreground="White" FontSize="15">Contabilidad</TextBlock>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Background="#242731">
                        <Button Background="#242731" BorderThickness="0" Foreground="White"
                                FontSize="15" HorizontalContentAlignment="Left" Click="btnEgresos_Click">
                            <StackPanel Orientation="Horizontal" Width="250">
                                <materialDesign:PackIcon Kind="CurrencyUsd" VerticalAlignment="Center" Margin="15,0,20,0" Foreground="White"/>
                                <TextBlock Text="Egresos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Background="#3D7EFF" BorderThickness="0" Foreground="White"
                                FontSize="15" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Width="250">
                                <materialDesign:PackIcon Kind="CreditCard" VerticalAlignment="Center" Margin="15,0,20,0" Foreground="White"/>
                                <TextBlock Text="Ingresos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Expander>

                <Button x:Name="btnÓrdenes" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15" Click="btnÓrdenes_Click">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="OrderBoolAscending" VerticalAlignment="Center" Foreground="White" Height="25" Width="39"/>
                        <TextBlock Foreground="White" FontSize="15">Órdenes</TextBlock>
                    </WrapPanel>
                </Button>

                <Button x:Name="btnCerrarSesión" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White"
                        VerticalAlignment="Bottom" Margin="0,70,0,15" Click="btnCerrarSesion_Click">
                    <WrapPanel Width="175">
                        <materialDesign:PackIcon Kind="LogoutVariant" VerticalAlignment="Center" Foreground="White" Width="39" Height="21"/>
                        <TextBlock Foreground="White" FontSize="15">Cerrar Sesión</TextBlock>
                    </WrapPanel>
                </Button>

            </StackPanel>
        </materialDesign:ColorZone>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1A1D2E" Height="80">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="25,0,20,0">
                        <TextBlock Text="Contabilidad - Ingresos" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Gestiona los pagos recibidos" Foreground="#6B7280" FontSize="12"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#252836" CornerRadius="5"
                            VerticalAlignment="Center" Height="40" MaxWidth="400"
                            HorizontalAlignment="Left" Margin="20,0,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                            <materialDesign:PackIcon Kind="Magnify" Foreground="#6B7280"
                                                     Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="txtBuscar"
                                     Background="Transparent" Foreground="#6B7280"
                                     BorderThickness="0" VerticalAlignment="Center"
                                     FontSize="13" Width="200" CaretBrush="White"
                                     TextChanged="txtBuscar_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Setter Property="materialDesign:HintAssist.Hint" Value="Buscar pago..."/>
                                        <Setter Property="materialDesign:HintAssist.Foreground" Value="#6B7280"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="16,0">
                        <Button x:Name="btnNotificaciones"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Foreground="#6B7280" Width="38" Height="38"
                                Click="btnNotificaciones_Click">
                            <materialDesign:PackIcon Kind="BellOutline" Width="22" Height="22"/>
                        </Button>
                        <Border x:Name="badgeNotificaciones" Background="#FF4444" CornerRadius="8"
                                Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Visibility="Collapsed">
                            <TextBlock x:Name="txtContadorNotificaciones" Text="0" Foreground="White"
                                       FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Popup x:Name="popupNotificaciones"
                               PlacementTarget="{Binding ElementName=btnNotificaciones}"
                               Placement="Bottom" StaysOpen="False"
                               AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="#252836" CornerRadius="10"
                                    BorderBrush="#2A3A4D" BorderThickness="1"
                                    Width="360" MaxHeight="480"
                                    Effect="{DynamicResource MaterialDesignShadowDepth3}">
                                <Grid Margin="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="BellOutline" Foreground="White"
                                                                     Width="18" Height="18"
                                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Notificaciones" Foreground="White"
                                                       FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" x:Name="badgeContadorPopup"
                                                Background="#FF4444" CornerRadius="10"
                                                Padding="8,2" VerticalAlignment="Center"
                                                Visibility="Collapsed">
                                            <TextBlock x:Name="txtContadorPopup" Text="0" Foreground="White"
                                                       FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                    <Rectangle Grid.Row="2" Height="1" Fill="#2A3A4D"/>
                                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" MaxHeight="320">
                                        <StackPanel x:Name="panelNotificaciones"/>
                                    </ScrollViewer>
                                    <Button Grid.Row="6" x:Name="btnMarcarTodas"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="#3D7EFF" BorderBrush="#3D7EFF"
                                            materialDesign:ButtonAssist.CornerRadius="8"
                                            Height="36" FontSize="12" Visibility="Collapsed"
                                            Click="btnMarcarTodas_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CheckAll" Width="16" Height="16"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Marcar todas como leídas" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>

                    <Rectangle Grid.Column="3" Fill="#3D4458" Margin="0,20"/>

                    <StackPanel Grid.Column="4" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,20,0">
                        <Border Width="38" Height="38" CornerRadius="18" ClipToBounds="True"
                                Margin="0,0,10,0" BorderBrush="#3D7EFF" BorderThickness="2"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Oscar Sosa" Foreground="#3D7EFF" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Propietario" Foreground="#6B7280" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20,15,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnAgregar" Grid.Column="0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#3D7EFF" Foreground="White"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        materialDesign:ElevationAssist.Elevation="Dp0"
                        Height="38" Padding="16,0" Margin="0,0,10,0"
                        Click="btnAgregar_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Agregar Pago" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#2E7D32" Foreground="White"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Height="38" Padding="16,0" Margin="10,0,20,0"
                        Click="btnReportes_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilePdfBox" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Reportes" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnMostrarComprobantes" Grid.Column="2"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#6B7280" BorderBrush="#3D4458"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Height="38" Padding="16,0"
                        Click="btnMostrarComprobantes_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocumentOutline" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Mostrar Comprobante" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Grid>

            <materialDesign:Card Grid.Row="2"
                                 Background="#1E2A3A"
                                 materialDesign:ElevationAssist.Elevation="Dp4"
                                 UniformCornerRadius="10"
                                 Margin="20,0,20,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,16"
                            BorderBrush="#2A3A4D" BorderThickness="0,0,0,1">
                        <TextBlock Text="Registro de Pagos"
                                   Foreground="White" FontSize="15" FontWeight="Medium"/>
                    </Border>

                    <DataGrid Grid.Row="1" x:Name="dgPagos"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserResizeRows="False" CanUserReorderColumns="False"
                              CanUserResizeColumns="False"
                              IsReadOnly="True" SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2A3A4D"
                              VerticalGridLinesBrush="Transparent"
                              Background="Transparent" Foreground="White"
                              BorderThickness="0" RowBackground="Transparent"
                              AlternatingRowBackground="#162030"
                              ColumnHeaderHeight="40" RowHeight="55"
                              MouseDoubleClick="dgPagos_MouseDoubleClick"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              materialDesign:DataGridAssist.CellPadding="0"
                              materialDesign:DataGridAssist.ColumnHeaderPadding="12,0">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#8B9BB4"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#2A3A4D"/>
                                <Setter Property="SeparatorVisibility" Value="Collapsed"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A2A3D"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2A3A4D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="{x:Type DataGridCell}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Pago_ID}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="#8B9BB4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Cliente" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                            <Border Width="34" Height="34" CornerRadius="17"
                                                    Background="#2A3A4D" Margin="0,0,10,0">
                                                <materialDesign:PackIcon Kind="Account" Foreground="#8B9BB4"
                                                                         Width="18" Height="18"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Cliente_Nombres}"
                                                           Foreground="White" FontSize="13" FontWeight="Medium"/>
                                                <TextBlock Text="{Binding Cliente_DNI, StringFormat='DNI: {0}'}"
                                                           Foreground="#8B9BB4" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Orden ID" Binding="{Binding Orden_ID}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="#8B9BB4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Monto"
                    Binding="{Binding Precio_Pago, StringFormat='L {0:N2}'}"
                    Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="12,0,0,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Fecha" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="12,0">
                                            <TextBlock Text="{Binding Fecha_Pago, StringFormat=MMMM dd\, yyyy}"
                                                       Foreground="White" FontSize="12"/>
                                            <TextBlock Text="{Binding Fecha_Pago, StringFormat=hh:mm tt}"
                                                       Foreground="#8B9BB4" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

        </Grid>
    </Grid>
</Window>