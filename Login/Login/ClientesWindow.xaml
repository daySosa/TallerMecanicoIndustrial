<Window x:Class="InterfazClientes.ClientesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:InterfazClientes"
        Title="Clientes" Height="720" Width="950"
        TextElement.Foreground="#242731" WindowStyle="ThreeDBorderWindow"
        Background="#1F2128" WindowStartupLocation="CenterScreen" BorderBrush="#242731">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="#1a1d2e">
        <Grid Margin="30,24,30,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Grid.RowSpan="2">
                <materialDesign:Card Background="#252836" UniformCornerRadius="12"
                                     Padding="22" Margin="0,0,0,16"
                                     materialDesign:ElevationAssist.Elevation="Dp3">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#2e3250" CornerRadius="8"
                                    Width="36" Height="36" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="AccountOutline"
                                                         Foreground="#4f6ef7" Width="20" Height="20"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Datos del Cliente" Foreground="White"
                                           FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Información de identificación"
                                           Foreground="#6c7293" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="DNI Hondureño (13 dígitos sin guiones)"
                                   Foreground="#6c7293" FontSize="11" FontWeight="Medium" Margin="0,0,0,4"/>
                        
                        <TextBox x:Name="txtDPI"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Background="#1e2130" Foreground="White"
                                 BorderBrush="#3a3f5c" CaretBrush="White"
                                 Height="40" VerticalContentAlignment="Center"
                                 Padding="10,0" Margin="0,0,0,16"
                                 MaxLength="13"
                                 materialDesign:HintAssist.Hint="Ej: 0801199012345"
                                 PreviewTextInput="txtDPI_PreviewTextInput"/>

                        <TextBlock Text="Nombre" Foreground="#6c7293" FontSize="11"
                                   FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtNombre"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Background="#1e2130" Foreground="White"
                                 BorderBrush="#3a3f5c" CaretBrush="White"
                                 Height="40" VerticalContentAlignment="Center"
                                 Padding="10,0" Margin="0,0,0,16"
                                 materialDesign:HintAssist.Hint="Nombres del cliente"/>

                        <TextBlock Text="Apellido" Foreground="#6c7293" FontSize="11"
                                   FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtApellido"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Background="#1e2130" Foreground="White"
                                 BorderBrush="#3a3f5c" CaretBrush="White"
                                 Height="40" VerticalContentAlignment="Center"
                                 Padding="10,0" Margin="0,0,0,16"
                                 materialDesign:HintAssist.Hint="Apellidos del cliente"/>

                        <TextBlock Text="Teléfono" Foreground="#6c7293" FontSize="11"
                                   FontWeight="Medium" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#2e3250"
                                    BorderBrush="#3a3f5c" BorderThickness="1,1,0,1"
                                    CornerRadius="4,0,0,4" Padding="10,0" Height="40">
                                <materialDesign:PackIcon Kind="Phone" Foreground="#4f6ef7"
                                                         Width="16" Height="16" VerticalAlignment="Center"/>
                            </Border>
                            <TextBox x:Name="txtTelefono" Grid.Column="1"
         Style="{StaticResource MaterialDesignOutlinedTextBox}"
         Background="#1e2130" Foreground="White"
         BorderBrush="#3a3f5c" CaretBrush="White"
         Height="40" VerticalContentAlignment="Center"
         Padding="10,0"
         MaxLength="9"
         materialDesign:HintAssist.Hint="Ej: 9999-9999"
         materialDesign:TextFieldAssist.CharacterCounterVisibility="Collapsed"
         PreviewTextInput="txtTelefono_PreviewTextInput"
         TextChanged="txtTelefono_TextChanged"/>
                        </Grid>

                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>

            <StackPanel Grid.Column="2" Grid.RowSpan="2">
                <materialDesign:Card Background="#252836" UniformCornerRadius="12"
                                     Padding="22" Margin="0,0,0,16"
                                     materialDesign:ElevationAssist.Elevation="Dp3">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#2e3250" CornerRadius="8"
                                    Width="36" Height="36" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="CardAccountDetailsOutline"
                                                         Foreground="#4f6ef7" Width="20" Height="20"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Contacto y Ubicación" Foreground="White"
                                           FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Correo, dirección y estado del cliente"
                                           Foreground="#6c7293" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Correo Electrónico" Foreground="#6c7293" FontSize="11"
                                   FontWeight="Medium" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#2e3250"
                                    BorderBrush="#3a3f5c" BorderThickness="1,1,0,1"
                                    CornerRadius="4,0,0,4" Padding="10,0" Height="40">
                                <materialDesign:PackIcon Kind="Email" Foreground="#4f6ef7"
                                                         Width="16" Height="16" VerticalAlignment="Center"/>
                            </Border>
                            <TextBox x:Name="txtCorreo" Grid.Column="1"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Background="#1e2130" Foreground="White"
                                     BorderBrush="#3a3f5c" CaretBrush="White"
                                     Height="40" VerticalContentAlignment="Center"
                                     Padding="10,0"
                                     materialDesign:HintAssist.Hint="correo@ejemplo.com"/>
                        </Grid>

                        <TextBlock Text="Dirección" Foreground="#6c7293" FontSize="11"
                                   FontWeight="Medium" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#2e3250"
                                    BorderBrush="#3a3f5c" BorderThickness="1,1,0,1"
                                    CornerRadius="4,0,0,4" Padding="10,0" Height="40">
                                <materialDesign:PackIcon Kind="MapMarker" Foreground="#4f6ef7"
                                                         Width="16" Height="16" VerticalAlignment="Center"/>
                            </Border>
                            <TextBox x:Name="txtDireccion" Grid.Column="1"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Background="#1e2130" Foreground="White"
                                     BorderBrush="#3a3f5c" CaretBrush="White"
                                     Height="40" VerticalContentAlignment="Center"
                                     Padding="10,0"
                                     materialDesign:HintAssist.Hint="Ciudad, Colonia..."/>
                        </Grid>

                        <Separator Background="#2e3250" Margin="0,6,0,18"/>

                        <Border Background="#1e2130" CornerRadius="10" Padding="16,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                                 x:Name="iconEstado" Foreground="#4CAF50"
                                                                 Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Estado del Cliente" Foreground="White"
                                                   FontSize="13" FontWeight="Medium"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtEstadoLabel" Text="El cliente está activo"
                                               Foreground="#4CAF50" FontSize="11"/>
                                </StackPanel>
                                <ToggleButton x:Name="toggleActivo" Grid.Column="1"
                                              IsChecked="True"
                                              Checked="ToggleActivo_Checked"
                                              Unchecked="ToggleActivo_Unchecked"
                                              VerticalAlignment="Center">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Width" Value="54"/>
                                            <Setter Property="Height" Value="30"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Grid>
                                                            <Border x:Name="switchBg" Background="#4CAF50"
                                                                    CornerRadius="15" Width="54" Height="30"/>
                                                            <Border x:Name="switchThumb" Background="White"
                                                                    CornerRadius="12" Width="24" Height="24"
                                                                    HorizontalAlignment="Right" Margin="0,0,3,0">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="Black" Opacity="0.2"
                                                                                      BlurRadius="4" ShadowDepth="1"/>
                                                                </Border.Effect>
                                                            </Border>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="False">
                                                                <Setter TargetName="switchBg" Property="Background" Value="#3a3f5c"/>
                                                                <Setter TargetName="switchThumb" Property="HorizontalAlignment" Value="Left"/>
                                                                <Setter TargetName="switchThumb" Property="Margin" Value="3,0,0,0"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                            </Grid>
                        </Border>

                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>

            <materialDesign:Card Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                 Background="#252836" UniformCornerRadius="12"
                                 Padding="20,16"
                                 materialDesign:ElevationAssist.Elevation="Dp3" Margin="0,239,0,-238">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="#6c7293" FontSize="12">
                        <Run Text="⚠ "/>
                        <Run Text="Verifica los datos antes de guardar"/>
                    </TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Cancelar"
                                Height="38" Padding="24,0" Margin="0,0,10,0"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="#6c7293" Foreground="#6c7293"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Click="BtnCancelar_Click"/>
                        <Button x:Name="btnActualizar" Content="Actualizar"
                                Height="38" Padding="24,0" Margin="0,0,10,0"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="#4f6ef7" Foreground="#4f6ef7"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Click="BtnActualizar_Click"/>
                        <Button x:Name="btnAgregar" Height="38" Padding="24,0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                materialDesign:ElevationAssist.Elevation="Dp0"
                                Click="BtnAgregar_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                    <Setter Property="Background" Value="#4f6ef7"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#4f6ef7"/>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Agregar Cliente" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

        </Grid>
    </ScrollViewer>
</Window>