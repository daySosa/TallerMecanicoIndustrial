                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="2" Background="#0f1117" CornerRadius="8"
                                                    BorderBrush="#1e2235" BorderThickness="1" Padding="14,10">
                                                <StackPanel>
                                                    <TextBlock Text="SERVICIO" Foreground="#505880"
                                                               FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
