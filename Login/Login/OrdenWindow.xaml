                                                            <Style TargetType="ComboBoxItem">
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="Background" Value="#1e2235"/>
                                                                <Setter Property="Padding" Value="10,7"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#2e3250"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ComboBox.ItemContainerStyle>
                                                        <ComboBoxItem Content="Normal"/>
                                                        <ComboBoxItem Content="Alta"/>
                                                        <ComboBoxItem Content="Urgente"/>
                                                    </ComboBox>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Observaciones" Foreground="#505880"
                                                           FontSize="11" Margin="0,0,0,4"/>
                                                <Border Background="#1e2235" CornerRadius="7"
                                                        BorderBrush="#252840" BorderThickness="1">
                                                    <TextBox x:Name="txtObservaciones"
                                                             Background="Transparent" Foreground="White"
                                                             CaretBrush="White" BorderThickness="0"
                                                             Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                                             VerticalScrollBarVisibility="Auto"
                                                             VerticalContentAlignment="Top" Padding="9,8"
                                                             FontSize="12"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Height="12" Background="Transparent"/>

                                <!-- DETALLE DEL TRABAJO -->
                                <Border Background="#13161f" CornerRadius="12"
                                        BorderBrush="#1e2235" BorderThickness="1" Padding="16">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <materialDesign:PackIcon Kind="Wrench"
                                                                     Foreground="#4f6ef7" Width="16" Height="16"
                                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
