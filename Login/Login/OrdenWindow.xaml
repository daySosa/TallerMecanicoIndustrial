<Window x:Class="Órdenes_de_Trabajo.OrdenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Órdenes_de_Trabajo"
        Title="Nueva Orden de Trabajo" Height="750" Width="1280"
        MinHeight="600" MinWidth="1150"
        TextElement.Foreground="White"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        StateChanged="Window_StateChanged"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <DropShadowEffect x:Key="WinShadow" Color="#000000" BlurRadius="48" ShadowDepth="0" Opacity="0.75"/>
    </Window.Resources>

    <Grid>
        <Border CornerRadius="14" Effect="{StaticResource WinShadow}">
            <Border CornerRadius="14" ClipToBounds="True" Background="#0f1117">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <Border Grid.Row="0" Background="#13161f" Height="58"
                            BorderBrush="#1e2235" BorderThickness="0,0,0,1">
                        <Grid Margin="20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtTituloVentana"
                                           Text="Nueva Orden de Trabajo"
                                           Foreground="White" FontSize="15" FontWeight="Bold"/>
                                <TextBlock Text="Completa los datos para registrar la orden"
                                           Foreground="#505880" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Foreground="#505880" Width="34" Height="34"
                                        Click="btnCancelar_Click">
                                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- BODY -->
                    <Grid Grid.Row="1" Margin="18,16,18,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ═══ COLUMNA IZQUIERDA ═══ -->
                        <DockPanel Grid.Column="0" LastChildFill="True">

                            <!-- ACCIONES (anclado abajo) -->
                            <Border DockPanel.Dock="Bottom" Background="#13161f" CornerRadius="12"
                                    BorderBrush="#1e2235" BorderThickness="1" Padding="14" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="ACCIONES" Foreground="#353a58"
                                               FontSize="9" FontWeight="Bold" Margin="0,0,0,10"/>

                                    <Button x:Name="btnAñadir"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            Background="#4f6ef7" Foreground="White"
                                            BorderBrush="#4f6ef7"
                                            materialDesign:ButtonAssist.CornerRadius="8"
                                            materialDesign:ElevationAssist.Elevation="Dp0"
                                            Height="38" Margin="0,0,0,8"
                                            Click="btnAniadir_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Plus" Width="15" Height="15"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Añadir Orden" VerticalAlignment="Center" FontSize="12"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="btnActualizar"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            BorderBrush="#F0A500" Foreground="#F0A500"
                                            materialDesign:ButtonAssist.CornerRadius="8"
                                            Height="38" Margin="0,0,0,8"
                                            Click="btnActualizar_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Pencil" Width="15" Height="15"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Actualizar" VerticalAlignment="Center" FontSize="12"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                            BorderBrush="#1e2235" Foreground="#505880"
                                            materialDesign:ButtonAssist.CornerRadius="8"
                                            Height="38"
                                            Click="btnCancelar_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Close" Width="15" Height="15"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Cancelar" VerticalAlignment="Center" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- SCROLL con buscar + tipo vehículo -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>

                                    <!-- BUSCAR CLIENTE / VEHÍCULO -->
                                    <Border Background="#13161f" CornerRadius="12"
                                            BorderBrush="#1e2235" BorderThickness="1" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="BUSCAR CLIENTE / VEHÍCULO"
                                                       Foreground="#353a58" FontSize="9" FontWeight="Bold"
                                                       Margin="0,0,0,10"/>

                                            <!-- Tabs DNI / Placa -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="tabDNI" Grid.Column="0"
                                                        Background="#4f6ef7" CornerRadius="7,0,0,7"
                                                        Padding="0,7" Cursor="Hand"
                                                        MouseLeftButtonDown="TabDNI_Click">
                                                    <TextBlock Text="Por DNI" Foreground="White"
                                                               FontSize="12" FontWeight="Medium"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border x:Name="tabPlaca" Grid.Column="1"
                                                        Background="#1e2235" CornerRadius="0,7,7,0"
                                                        Padding="0,7" Cursor="Hand"
                                                        MouseLeftButtonDown="TabPlaca_Click">
                                                    <TextBlock x:Name="txtTabPlaca" Text="Por Placa"
                                                               Foreground="#505880" FontSize="12"
                                                               FontWeight="Medium" HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>

                                            <!-- Label + contador -->
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="lblBuscar" Text="DNI del Cliente"
                                                           Foreground="#505880" FontSize="11"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock x:Name="txtContador" Grid.Column="1"
                                                           Text="0 / 13" Foreground="#353a58"
                                                           FontSize="10" VerticalAlignment="Center"/>
                                            </Grid>

                                            <!-- Campo búsqueda + botón -->
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="#1e2235"
                                                            CornerRadius="7" BorderBrush="#252840" BorderThickness="1">
                                                        <TextBox x:Name="txtBuscar"
                                                                 Background="Transparent" Foreground="White"
                                                                 CaretBrush="White" BorderThickness="0"
                                                                 Padding="9,0" Height="34"
                                                                 VerticalContentAlignment="Center"
                                                                 FontSize="12" MaxLength="13"
                                                                 TextChanged="txtBuscar_TextChanged">
                                                            <TextBox.Style>
                                                                <Style TargetType="TextBox"
                                                                       BasedOn="{StaticResource MaterialDesignTextBox}">
                                                                    <Setter Property="materialDesign:HintAssist.Hint"
                                                                            Value="Ingresa DNI..."/>
                                                                    <Setter Property="materialDesign:HintAssist.Foreground"
                                                                            Value="#505880"/>
                                                                </Style>
                                                            </TextBox.Style>
                                                        </TextBox>
                                                    </Border>
                                                    <Button Grid.Column="2" Content="Buscar"
                                                            Height="34" Padding="10,0"
                                                            Click="BtnBuscar_Click"
                                                            materialDesign:ButtonAssist.CornerRadius="7"
                                                            materialDesign:ElevationAssist.Elevation="Dp0">
                                                        <Button.Style>
                                                            <Style TargetType="Button"
                                                                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                                <Setter Property="Background" Value="#4f6ef7"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="BorderBrush" Value="#4f6ef7"/>
                                                                <Setter Property="FontSize" Value="12"/>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>

                                                <!-- Autocompletado -->
                                                <Border Grid.Row="1" x:Name="borderAutocompletado"
                                                        Background="#1e2235" CornerRadius="0,0,7,7"
                                                        BorderBrush="#252840" BorderThickness="1,0,1,1"
                                                        Visibility="Collapsed" Margin="0,-2,38,0">
                                                    <ListBox x:Name="lstAutocompletado"
                                                             Background="Transparent" BorderThickness="0"
                                                             MaxHeight="120" Foreground="White"
                                                             SelectionChanged="lstAutocompletado_SelectionChanged">
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="Padding" Value="10,6"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="FontSize" Value="12"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#2e3250"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                    </ListBox>
                                                </Border>
                                            </Grid>

                                            <!-- Info Cliente -->
                                            <Border x:Name="borderClienteInfo" Background="#0f1117"
                                                    CornerRadius="8" Padding="10"
                                                    Visibility="Collapsed" Margin="0,10,0,0"
                                                    BorderBrush="#1e2235" BorderThickness="1">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                        <materialDesign:PackIcon Kind="AccountCheck"
                                                                                 Foreground="#4CAF50"
                                                                                 Width="14" Height="14"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,6,0"/>
                                                        <TextBlock Text="CLIENTE" Foreground="#4CAF50"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="txtClienteNombre" Foreground="White"
                                                               FontSize="12" FontWeight="Medium"
                                                               Margin="0,0,0,6" TextWrapping="Wrap"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Teléfono" Foreground="#505880"
                                                                       FontSize="9" Margin="0,0,0,2"/>
                                                            <TextBlock x:Name="txtClienteTelefono"
                                                                       Foreground="White" FontSize="11"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="Email" Foreground="#505880"
                                                                       FontSize="9" Margin="0,0,0,2"/>
                                                            <TextBlock x:Name="txtClienteEmail"
                                                                       Foreground="White" FontSize="11"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <!-- Selector vehículos (cuando hay varios) -->
                                            <Border x:Name="borderSelectorVehiculo" Background="#0f1117"
                                                    CornerRadius="8" Padding="10"
                                                    Visibility="Collapsed" Margin="0,8,0,0"
                                                    BorderBrush="#1e2235" BorderThickness="1">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                        <materialDesign:PackIcon Kind="Car"
                                                                                 Foreground="#4f6ef7"
                                                                                 Width="14" Height="14"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,6,0"/>
                                                        <TextBlock Text="SELECCIONAR VEHÍCULO"
                                                                   Foreground="#4f6ef7" FontSize="9"
                                                                   FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <ListBox x:Name="lstVehiculos"
                                                             Background="Transparent" BorderThickness="0"
                                                             MaxHeight="100" Foreground="White"
                                                             SelectionChanged="lstVehiculos_SelectionChanged">
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="Padding" Value="8,5"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="FontSize" Value="11"/>
                                                                <Setter Property="Margin" Value="0,1"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#1e2235"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter Property="Background" Value="#2e3250"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <materialDesign:PackIcon Kind="Car"
                                                                                             Foreground="#4f6ef7"
                                                                                             Width="13" Height="13"
                                                                                             VerticalAlignment="Center"
                                                                                             Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding PlacaYModelo}"
                                                                               Foreground="White" FontSize="11"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </StackPanel>
                                            </Border>

                                            <!-- Info Vehículo -->
                                            <Border x:Name="borderVehiculoInfo" Background="#0f1117"
                                                    CornerRadius="8" Padding="10"
                                                    Visibility="Collapsed" Margin="0,8,0,0"
                                                    BorderBrush="#1e2235" BorderThickness="1">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                        <materialDesign:PackIcon Kind="Car"
                                                                                 Foreground="#4f6ef7"
                                                                                 Width="14" Height="14"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,6,0"/>
                                                        <TextBlock Text="VEHÍCULO" Foreground="#4f6ef7"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="txtVehiculoNombre" Foreground="White"
                                                               FontSize="12" FontWeight="Medium"
                                                               Margin="0,0,0,6" TextWrapping="Wrap"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Tipo · Año" Foreground="#505880"
                                                                       FontSize="9" Margin="0,0,0,2"/>
                                                            <TextBlock x:Name="txtVehiculoTipo"
                                                                       Foreground="White" FontSize="11"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="Placa" Foreground="#505880"
                                                                       FontSize="9" Margin="0,0,0,2"/>
                                                            <TextBlock x:Name="txtVehiculoPropietario"
                                                                       Foreground="White" FontSize="11"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <!-- Error -->
                                            <Border x:Name="borderError" Background="#2a0d0d"
                                                    CornerRadius="8" Padding="10,7"
                                                    Visibility="Collapsed" Margin="0,8,0,0"
                                                    BorderBrush="#3a1a1a" BorderThickness="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="AlertCircle"
                                                                             Foreground="#f44336"
                                                                             Width="14" Height="14"
                                                                             VerticalAlignment="Center"
                                                                             Margin="0,0,6,0"/>
                                                    <TextBlock x:Name="txtError" Foreground="#f44336"
                                                               FontSize="11" VerticalAlignment="Center"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Border Height="12" Background="Transparent"/>

                                    <!-- TIPO DE VEHÍCULO -->
                                    <Border Background="#13161f" CornerRadius="12"
                                            BorderBrush="#1e2235" BorderThickness="1" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="TIPO DE VEHÍCULO"
                                                       Foreground="#353a58" FontSize="9" FontWeight="Bold"
                                                       Margin="0,0,0,10"/>
                                            <TextBlock Text="Autos" Foreground="#505880"
                                                       FontSize="9" Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="5"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="5"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="btnTipoSedan" Grid.Column="0"
                                                        Background="#2e3250" CornerRadius="8"
                                                        Padding="4,8" Cursor="Hand"
                                                        MouseLeftButtonDown="TipoVehiculo_Click" Tag="sedan">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Canvas Width="40" Height="22" HorizontalAlignment="Center" Margin="0,0,0,3">
                                                            <Rectangle Canvas.Left="2" Canvas.Top="9" Width="36" Height="11" Fill="#4f6ef7" RadiusX="3" RadiusY="3"/>
                                                            <Path Fill="#6c8fff" Data="M9,9 L13,2 L27,2 L31,9 Z"/>
                                                            <Ellipse Canvas.Left="4" Canvas.Top="16" Width="8" Height="8" Fill="#1e2235" Stroke="#505880" StrokeThickness="1.2"/>
                                                            <Ellipse Canvas.Left="28" Canvas.Top="16" Width="8" Height="8" Fill="#1e2235" Stroke="#505880" StrokeThickness="1.2"/>
                                                            <Path Fill="#0f1117" Opacity="0.6" Data="M14,8.5 L15,2.5 L25,2.5 L26,8.5 Z"/>
                                                        </Canvas>
                                                        <TextBlock Text="Sedán" Foreground="#8890b5"
                                                                   FontSize="9" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border x:Name="btnTipoSUV" Grid.Column="2"
                                                        Background="#1e2235" CornerRadius="8"
                                                        Padding="4,8" Cursor="Hand"
                                                        MouseLeftButtonDown="TipoVehiculo_Click" Tag="suv">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Canvas Width="40" Height="22" HorizontalAlignment="Center" Margin="0,0,0,3">
                                                            <Rectangle Canvas.Left="2" Canvas.Top="7" Width="36" Height="13" Fill="#4f6ef7" RadiusX="3" RadiusY="3"/>
                                                            <Path Fill="#6c8fff" Data="M7,7 L9,1 L31,1 L33,7 Z"/>
                                                            <Ellipse Canvas.Left="3" Canvas.Top="16" Width="10" Height="10" Fill="#1e2235" Stroke="#505880" StrokeThickness="1.2"/>
                                                            <Ellipse Canvas.Left="27" Canvas.Top="16" Width="10" Height="10" Fill="#1e2235" Stroke="#505880" StrokeThickness="1.2"/>
                                                            <Path Fill="#0f1117" Opacity="0.6" Data="M11,6.5 L12,1.5 L28,1.5 L29,6.5 Z"/>
                                                        </Canvas>
                                                        <TextBlock Text="SUV" Foreground="#8890b5"
                                                                   FontSize="9" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border x:Name="btnTipoPickup" Grid.Column="4"
                                                        Background="#1e2235" CornerRadius="8"
                                                        Padding="4,8" Cursor="Hand"
                                                        MouseLeftButtonDown="TipoVehiculo_Click" Tag="pickup">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Canvas Width="40" Height="22" HorizontalAlignment="Center" Margin="0,0,0,3">
                                                            <Rectangle Canvas.Left="2" Canvas.Top="7" Width="17" Height="13" Fill="#4f6ef7" RadiusX="3" RadiusY="3"/>
                                                            <Path Fill="#6c8fff" Data="M4,7 L5,1 L17,1 L19,7 Z"/>
                                                            <Rectangle Canvas.Left="19" Canvas.Top="10" Width="19" Height="10" Fill="#3a4dbf" RadiusX="2" RadiusY="2"/>
                                                            <Ellipse Canvas.Left="2" Canvas.Top="16" Width="9" Height="9" Fill="#1e2235" Stroke="#505880" StrokeThickness="1.2"/>
                                                            <Ellipse Canvas.Left="28" Canvas.Top="16" Width="9" Height="9" Fill="#1e2235" Stroke="#505880" StrokeThickness="1.2"/>
                                                            <Path Fill="#0f1117" Opacity="0.6" Data="M5,6.5 L6.5,1.5 L16,1.5 L17.5,6.5 Z"/>
                                                        </Canvas>
                                                        <TextBlock Text="Pickup" Foreground="#8890b5"
                                                                   FontSize="9" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <TextBlock Text="Motos" Foreground="#505880"
                                                       FontSize="9" Margin="0,0,0,6"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="5"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="5"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="btnTipoMoto" Grid.Column="0"
                                                        Background="#1e2235" CornerRadius="8"
                                                        Padding="4,8" Cursor="Hand"
                                                        MouseLeftButtonDown="TipoVehiculo_Click" Tag="moto">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Canvas Width="40" Height="22" HorizontalAlignment="Center" Margin="0,0,0,3">
                                                            <Ellipse Canvas.Left="1" Canvas.Top="8" Width="14" Height="14" Fill="#1e2235" Stroke="#4f6ef7" StrokeThickness="1.5"/>
                                                            <Ellipse Canvas.Left="25" Canvas.Top="8" Width="14" Height="14" Fill="#1e2235" Stroke="#4f6ef7" StrokeThickness="1.5"/>
                                                            <Line X1="8" Y1="15" X2="32" Y2="15" Stroke="#4f6ef7" StrokeThickness="2"/>
                                                            <Path Fill="#4f6ef7" Data="M14,15 L18,5 L28,5 L32,15 Z"/>
                                                            <Line X1="27" Y1="5" X2="35" Y2="2" Stroke="#6c8fff" StrokeThickness="1.5"/>
                                                        </Canvas>
                                                        <TextBlock Text="Moto" Foreground="#8890b5"
                                                                   FontSize="9" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border x:Name="btnTipoMototaxi" Grid.Column="2"
                                                        Background="#1e2235" CornerRadius="8"
                                                        Padding="4,8" Cursor="Hand"
                                                        MouseLeftButtonDown="TipoVehiculo_Click" Tag="mototaxi">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Canvas Width="40" Height="22" HorizontalAlignment="Center" Margin="0,0,0,3">
                                                            <Ellipse Canvas.Left="0" Canvas.Top="9" Width="12" Height="12" Fill="#1e2235" Stroke="#4f6ef7" StrokeThickness="1.5"/>
                                                            <Ellipse Canvas.Left="14" Canvas.Top="12" Width="11" Height="11" Fill="#1e2235" Stroke="#4f6ef7" StrokeThickness="1.5"/>
                                                            <Ellipse Canvas.Left="28" Canvas.Top="12" Width="11" Height="11" Fill="#1e2235" Stroke="#4f6ef7" StrokeThickness="1.5"/>
                                                            <Rectangle Canvas.Left="12" Canvas.Top="4" Width="27" Height="10" Fill="#3a4dbf" RadiusX="3" RadiusY="3"/>
                                                            <Line X1="6" Y1="14" X2="20" Y2="10" Stroke="#4f6ef7" StrokeThickness="1.5"/>
                                                        </Canvas>
                                                        <TextBlock Text="Mototaxi" Foreground="#8890b5"
                                                                   FontSize="9" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="4" Background="Transparent" CornerRadius="8"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>

                        <!-- ═══ COLUMNA DERECHA ═══ -->
