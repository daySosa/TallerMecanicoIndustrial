<Window x:Class="Login.ReportesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Login"
        Title="ReportesWindow" Height="340" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <DropShadowEffect x:Key="WinShadow" Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.70"/>
    </Window.Resources>

    <Border Effect="{StaticResource WinShadow}" CornerRadius="14">
        <Border CornerRadius="14" ClipToBounds="True" Background="#0f1117">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#13161f"
                        BorderBrush="#1e2235" BorderThickness="0,0,0,1">
                    <Grid Margin="20,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="iconBackground" Width="30" Height="30" CornerRadius="8"
                                    Background="#1a1d35" Margin="0,0,12,0">
                                <materialDesign:PackIcon x:Name="iconModulo" Kind="FileChartOutline"
                                                         Foreground="#4f6ef7"
                                                         Width="16" Height="16"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Generar Reporte"
                                           Foreground="White" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="Exporta la información en PDF"
                                           Foreground="#505880" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="24,24,24,10" VerticalAlignment="Center">

                    <Border x:Name="cardModulo" Background="#13161f" CornerRadius="10"
                            BorderBrush="#1e2235" BorderThickness="1"
                            Padding="18,18" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="MÓDULO SELECCIONADO"
                                       Foreground="#505880" FontSize="10"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtModulo"
                                       Foreground="White" FontSize="20"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Se generará un archivo PDF con la información registrada en este módulo."
                               Foreground="#8890b5" FontSize="11"
                               TextWrapping="Wrap" Margin="2,10,2,0"/>

                </StackPanel>

                <Border Grid.Row="2" Background="#13161f"
                        BorderBrush="#1e2235" BorderThickness="0,1,0,0"
                        Padding="24,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="btnCancelar"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="#8890b5" BorderBrush="#252840"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Height="42" Content="Cancelar"
                                Click="BtnCancelar_Click"/>

                        <Button Grid.Column="2" x:Name="btnGenerarPDF"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#4f6ef7" Foreground="White"
                                BorderBrush="#4f6ef7"
                                materialDesign:ElevationAssist.Elevation="Dp0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Height="42" FontSize="13" FontWeight="SemiBold"
                                Click="BtnGenerarPDF_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FilePdfBox" Width="16" Height="16"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Generar PDF" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>