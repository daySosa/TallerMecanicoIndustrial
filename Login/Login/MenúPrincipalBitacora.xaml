<Window x:Class="Órdenes_de_Trabajo.MenúPrincipalBitacora"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Órdenes_de_Trabajo"
        Title="Bitácora" Height="850" Width="1200"
        TextElement.Foreground="White"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Opacity="0"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <DropShadowEffect x:Key="WinShadow" Color="#000000" BlurRadius="48" ShadowDepth="0" Opacity="0.75"/>

        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="9" Padding="12,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="bg"
                                                Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                To="#1e2235" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="bg"
                                                Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                To="Transparent" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarButtonActive" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#1e2235" CornerRadius="9" Padding="12,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarButtonLogout" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="9" Padding="12,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="bg"
                                                Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                To="#3d1b1b" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="bg"
                                                Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                To="Transparent" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterTextBox" TargetType="TextBox">
            <Setter Property="Height"                   Value="36"/>
            <Setter Property="Background"               Value="#1e2235"/>
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="CaretBrush"               Value="White"/>
            <Setter Property="BorderBrush"              Value="#252840"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"     Value="#4f6ef7"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border CornerRadius="14" Effect="{StaticResource WinShadow}">
            <Border CornerRadius="14" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#13161f"
                            BorderBrush="#1e2235" BorderThickness="0,0,1,0">
                        <DockPanel LastChildFill="False">

                            <Border DockPanel.Dock="Top" Padding="24,22,24,10">
                                <StackPanel>
                                    <Image RenderOptions.BitmapScalingMode="HighQuality"
                                           Source="/Imagenes/OSM_LOGO.png" Height="70"
                                           HorizontalAlignment="Center"/>
                                    <TextBlock Text="OSM TALLER" Foreground="#4f6ef7"
                                               FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Rectangle DockPanel.Dock="Top" Height="1" Fill="#1e2235" Margin="16,0,16,12"/>

                            <TextBlock DockPanel.Dock="Top" Text="MENÚ PRINCIPAL"
                                       Foreground="#353a58" FontSize="9" FontWeight="Bold"
                                       Margin="24,0,0,8"/>

                            <StackPanel DockPanel.Dock="Top" Margin="10,0">

                                <Button Style="{StaticResource SidebarButton}" Margin="0,2"
                                        Click="btnHome_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ViewDashboardOutline" Foreground="#8890b5"
                                                                 Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="Pantalla Principal" Foreground="#8890b5"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource SidebarButton}" Margin="0,2"
                                        Click="btnInventario_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="PackageVariant" Foreground="#8890b5"
                                                                 Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="Inventario" Foreground="#8890b5"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource SidebarButton}" Margin="0,2"
                                        Click="btnVehiculos_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CarSportsUtilityVehicle" Foreground="#8890b5"
                                                                 Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="Vehículos" Foreground="#8890b5"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource SidebarButton}" Margin="0,2"
                                        Click="btnClientes_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountGroupOutline" Foreground="#8890b5"
                                                                 Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="Clientes" Foreground="#8890b5"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource SidebarButton}" Margin="0,2"
                                        Click="btnOrdenes_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ClipboardListOutline" Foreground="#8890b5"
                                                                 Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="Órdenes" Foreground="#8890b5"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="btnUsuarios" Style="{StaticResource SidebarButton}" Margin="0,2" Click="btnUsuarios_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountCogOutline" Foreground="#8890b5"
                                                                 Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="Usuarios" Foreground="#8890b5"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="btnBitacora" Style="{StaticResource SidebarButtonActive}" Margin="0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="NotebookOutline" Foreground="White"
                                                                 Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="Bitácora" Foreground="White"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Expander x:Name="expanderContabilidad" Background="Transparent" Foreground="#8890b5"
                                    BorderThickness="0" Margin="-8,2,0,2">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal" Margin="-4,0,0,0" Width="200">
                                            <materialDesign:PackIcon Kind="BookOpenPageVariant" Foreground="#8890b5"
                                                                     Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Text="Contabilidad" Foreground="#8890b5"
                                                       FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Expander.Header>
                                    <StackPanel Margin="30,2,0,2">
                                        <Button Style="{StaticResource SidebarButton}" Height="36" Margin="0,1"
                                                Click="btnEgresos_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ArrowDownCircleOutline" Foreground="#8890b5"
                                                                         Width="15" Height="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Text="Egresos" Foreground="#8890b5"
                                                           FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource SidebarButton}" Height="36" Margin="0,1"
                                                Click="btnIngresos_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ArrowUpCircleOutline" Foreground="#8890b5"
                                                                         Width="15" Height="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Text="Ingresos" Foreground="#8890b5"
                                                           FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Expander>

                            </StackPanel>

                            <Rectangle DockPanel.Dock="Bottom" Height="1" Fill="#1e2235" Margin="16,0,16,0"/>
                            <Button DockPanel.Dock="Bottom" Style="{StaticResource SidebarButtonLogout}"
                                    Margin="10,4,10,8" Click="btnCerrarSesion_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="LogoutVariant" Foreground="#E74C3C"
                                                             Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Cerrar Sesión" Foreground="#E74C3C"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Rectangle DockPanel.Dock="Bottom" Height="1" Fill="#1e2235" Margin="16,0,16,0"/>

                            <Border DockPanel.Dock="Bottom" Margin="12,8,12,12"
                                    Background="#0f1117" CornerRadius="10"
                                    BorderBrush="#1e2235" BorderThickness="1"
                                    Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Margin="0,0,10,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#2a3580" Offset="0"/>
                                                <GradientStop Color="#1c2455" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock x:Name="txtIniciales" Text=""
                                                   Foreground="#7986f7" FontSize="13" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="txtNombreUsuario" Text=""
                                                   Foreground="White" FontSize="12" FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="txtRolUsuario" Text=""
                                                   Foreground="#4f6ef7" FontSize="10"/>
                                    </StackPanel>
                                    <Ellipse Grid.Column="2" Width="8" Height="8"
                                             Fill="#4CAF50" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                        </DockPanel>
                    </Border>

                    <!-- ═══════════ CONTENIDO PRINCIPAL ═══════════ -->
                    <Grid Grid.Column="1" Background="#0f1117">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#13161f" Height="68"
                                BorderBrush="#1e2235" BorderThickness="0,0,0,1">
                            <Grid Margin="24,0,20,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Bitácora del Sistema" Foreground="White"
                                               FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="Registro de actividad y acciones del sistema"
                                               Foreground="#505880" FontSize="11"/>
                                </StackPanel>

                                <Border Grid.Column="1" Background="#1e2235" CornerRadius="8"
                                        VerticalAlignment="Center" Height="36"
                                        MaxWidth="380" HorizontalAlignment="Center"
                                        BorderBrush="#252840" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                        <materialDesign:PackIcon Kind="Magnify" Foreground="#505880"
                                                                 Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox x:Name="txtBuscar" Background="Transparent" Foreground="White"
                                                 BorderThickness="0" VerticalAlignment="Center"
                                                 FontSize="13" Width="290" CaretBrush="White"
                                                 TextChanged="txtBuscar_TextChanged">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                                                    <Setter Property="materialDesign:HintAssist.Hint" Value="Buscar en bitácora..."/>
                                                    <Setter Property="materialDesign:HintAssist.Foreground" Value="#505880"/>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Column="2" VerticalAlignment="Center" Margin="0,0,4,0">
                                    <Button x:Name="btnNotificaciones"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Foreground="#505880" Width="36" Height="36"
                                            Click="btnNotificaciones_Click">
                                        <materialDesign:PackIcon Kind="BellOutline" Width="20" Height="20"/>
                                    </Button>
                                    <Border x:Name="badgeNotificaciones" Background="#E74C3C" CornerRadius="8"
                                            Width="16" Height="16"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Visibility="Collapsed">
                                        <TextBlock x:Name="txtContadorNotificaciones" Text="0"
                                                   Foreground="White" FontSize="9" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Popup x:Name="popupNotificaciones"
                                           PlacementTarget="{Binding ElementName=btnNotificaciones}"
                                           Placement="Bottom" StaysOpen="False"
                                           AllowsTransparency="True" PopupAnimation="Fade">
                                        <Border Background="#13161f" CornerRadius="12"
                                                BorderBrush="#1e2235" BorderThickness="1"
                                                Width="360" MaxHeight="480">
                                            <Grid Margin="16">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="10"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="10"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="10"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="BellOutline" Foreground="White"
                                                                                 Width="16" Height="16"
                                                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Notificaciones" Foreground="White"
                                                                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" x:Name="badgeContadorPopup"
                                                            Background="#E74C3C" CornerRadius="10"
                                                            Padding="8,2" VerticalAlignment="Center"
                                                            Visibility="Collapsed">
                                                        <TextBlock x:Name="txtContadorPopup" Text="0"
                                                                   Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                    </Border>
                                                </Grid>
                                                <Rectangle Grid.Row="2" Height="1" Fill="#1e2235"/>
                                                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" MaxHeight="320">
                                                    <StackPanel x:Name="panelNotificaciones"/>
                                                </ScrollViewer>
                                                <Button Grid.Row="6" x:Name="btnMarcarTodas"
                                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                                        Foreground="#4f6ef7" BorderBrush="#4f6ef7"
                                                        materialDesign:ButtonAssist.CornerRadius="8"
                                                        Height="36" FontSize="12" Visibility="Collapsed"
                                                        Click="btnMarcarTodas_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="CheckAll" Width="16" Height="16"
                                                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Marcar todas como leídas" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="24,20,24,24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#13161f" CornerRadius="12"
                                        BorderBrush="#1e2235" BorderThickness="1" Padding="16,14">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Background="#1a1d35" CornerRadius="7"
                                                    Width="32" Height="32" Margin="0,0,10,0">
                                                <materialDesign:PackIcon Kind="NotebookOutline" Foreground="#4f6ef7"
                                                                         Width="16" Height="16"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Total Registros" Foreground="#505880"
                                                       FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="tbTotalRegistros" Text="0"
                                                   Foreground="White" FontSize="22" FontWeight="Bold"/>
                                        <TextBlock Text="eventos registrados" Foreground="#353a58" FontSize="10" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="#13161f" CornerRadius="12"
                                        BorderBrush="#1e2235" BorderThickness="1" Padding="16,14">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Background="#1a2b1a" CornerRadius="7"
                                                    Width="32" Height="32" Margin="0,0,10,0">
                                                <materialDesign:PackIcon Kind="CalendarToday" Foreground="#4CAF50"
                                                                         Width="16" Height="16"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Hoy" Foreground="#505880"
                                                       FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="tbRegistrosHoy" Text="0"
                                                   Foreground="White" FontSize="22" FontWeight="Bold"/>
                                        <TextBlock Text="eventos del día" Foreground="#353a58" FontSize="10" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4" Background="#13161f" CornerRadius="12"
                                        BorderBrush="#1e2235" BorderThickness="1" Padding="16,14">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Background="#1a1d35" CornerRadius="7"
                                                    Width="32" Height="32" Margin="0,0,10,0">
                                                <materialDesign:PackIcon Kind="AccountCheckOutline" Foreground="#4f6ef7"
                                                                         Width="16" Height="16"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Usuarios Activos" Foreground="#505880"
                                                       FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="tbUsuariosActivos" Text="0"
                                                   Foreground="White" FontSize="22" FontWeight="Bold"/>
                                        <TextBlock Text="con actividad reciente" Foreground="#353a58" FontSize="10" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="6" Background="#13161f" CornerRadius="12"
                                        BorderBrush="#1e2235" BorderThickness="1" Padding="16,14">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Background="#2a1a00" CornerRadius="7"
                                                    Width="32" Height="32" Margin="0,0,10,0">
                                                <materialDesign:PackIcon Kind="StarOutline" Foreground="#F0A500"
                                                                         Width="16" Height="16"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Módulo Más Activo" Foreground="#505880"
                                                       FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="tbModuloActivo" Text="—"
                                                   Foreground="White" FontSize="22" FontWeight="Bold"/>
                                        <TextBlock Text="mayor cantidad de eventos" Foreground="#353a58" FontSize="10" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                            </Grid>

                            <Border Grid.Row="1" Background="#13161f" CornerRadius="12"
                                    BorderBrush="#1e2235" BorderThickness="1"
                                    Padding="16,12" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="FilterVariant" Foreground="#4f6ef7"
                                                                 Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Filtros" Foreground="White"
                                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Usuario" Foreground="#505880" FontSize="10" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtFiltroUsuario" Style="{StaticResource FilterTextBox}"
                                                 TextChanged="txtFiltroUsuario_TextChanged"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Módulo" Foreground="#505880" FontSize="10" Margin="0,0,0,4"/>
                                        <Border Background="#1e2235" CornerRadius="6"
                                                BorderBrush="#252840" BorderThickness="1" Height="36">
                                            <ComboBox x:Name="cmbFiltroModulo"
                                                      Background="Transparent" Foreground="White"
                                                      BorderThickness="0" FontSize="12"
                                                      Padding="10,0" VerticalContentAlignment="Center"
                                                      Style="{StaticResource MaterialDesignComboBox}">
                                                <ComboBoxItem Content="Todos" IsSelected="True"/>
                                                <ComboBoxItem Content="Inventario"/>
                                                <ComboBoxItem Content="Clientes"/>
                                                <ComboBoxItem Content="Vehículos"/>
                                                <ComboBoxItem Content="Órdenes"/>
                                                <ComboBoxItem Content="Usuarios"/>
                                                <ComboBoxItem Content="Contabilidad"/>
                                            </ComboBox>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="6">
                                        <TextBlock Text="Desde" Foreground="#505880" FontSize="10" Margin="0,0,0,4"/>
                                        <Border Background="#1e2235" CornerRadius="6"
                                                BorderBrush="#252840" BorderThickness="1" Height="36">
                                            <DatePicker x:Name="dtpDesde"
                                                        Background="Transparent" Foreground="White"
                                                        BorderThickness="0" Padding="8,0"
                                                        VerticalContentAlignment="Center" FontSize="12"
                                                        Style="{StaticResource MaterialDesignDatePicker}"
                                                        materialDesign:HintAssist.Foreground="#505880"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="8">
                                        <TextBlock Text="Hasta" Foreground="#505880" FontSize="10" Margin="0,0,0,4"/>
                                        <Border Background="#1e2235" CornerRadius="6"
                                                BorderBrush="#252840" BorderThickness="1" Height="36">
                                            <DatePicker x:Name="dtpHasta"
                                                        Background="Transparent" Foreground="White"
                                                        BorderThickness="0" Padding="8,0"
                                                        VerticalContentAlignment="Center" FontSize="12"
                                                        Style="{StaticResource MaterialDesignDatePicker}"
                                                        materialDesign:HintAssist.Foreground="#505880"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="10" Orientation="Horizontal"
                                                VerticalAlignment="Bottom">
                                        <Button Content="Limpiar"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Foreground="#8890b5" BorderBrush="#1e2235"
                                                materialDesign:ButtonAssist.CornerRadius="8"
                                                Height="36" Padding="14,0" Margin="0,0,8,0"
                                                Click="btnLimpiarFiltros_Click"/>
                                        <Button Content="Aplicar"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                Background="#4f6ef7" Foreground="White"
                                                materialDesign:ButtonAssist.CornerRadius="8"
                                                materialDesign:ElevationAssist.Elevation="Dp0"
                                                Height="36" Padding="14,0"
                                                Click="btnAplicarFiltros_Click"/>
                                    </StackPanel>

                                </Grid>
                            </Border>

                            <Border Grid.Row="2" CornerRadius="12"
                                    Background="#13161f" BorderBrush="#1e2235" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Padding="18,14"
                                            BorderBrush="#1e2235" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="NotebookOutline" Foreground="#4f6ef7"
                                                                         Width="16" Height="16"
                                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Registro de Actividad" Foreground="White"
                                                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="#1a1d35" CornerRadius="6"
                                                    Padding="10,4" VerticalAlignment="Center">
                                                <TextBlock x:Name="tbTotalEventos" Text="0 eventos"
                                                           Foreground="#4f6ef7" FontSize="11"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <DataGrid Grid.Row="1" x:Name="dgBitacora"
                                              AutoGenerateColumns="False" CanUserAddRows="False"
                                              CanUserDeleteRows="False" CanUserResizeRows="False"
                                              CanUserReorderColumns="False" CanUserResizeColumns="False"
                                              IsReadOnly="True" SelectionMode="Single"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#1e2235"
                                              Background="Transparent" Foreground="White"
                                              BorderThickness="0" RowBackground="Transparent"
                                              AlternatingRowBackground="#0d1020"
                                              ColumnHeaderHeight="38" RowHeight="52"
                                              EnableRowVirtualization="True"
                                              EnableColumnVirtualization="True"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              VirtualizingPanel.ScrollUnit="Pixel"
                                              materialDesign:DataGridAssist.CellPadding="0"
                                              materialDesign:DataGridAssist.ColumnHeaderPadding="12,0">

                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background"                 Value="Transparent"/>
                                                <Setter Property="Foreground"                 Value="#505880"/>
                                                <Setter Property="FontSize"                   Value="11"/>
                                                <Setter Property="FontWeight"                 Value="Medium"/>
                                                <Setter Property="Padding"                    Value="12,0"/>
                                                <Setter Property="BorderThickness"            Value="0,0,0,1"/>
                                                <Setter Property="BorderBrush"                Value="#1e2235"/>
                                                <Setter Property="SeparatorVisibility"        Value="Collapsed"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>

                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Cursor"     Value="Arrow"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1a1d35"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#1e2235"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>

                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Background"               Value="Transparent"/>
                                                <Setter Property="BorderThickness"          Value="0"/>
                                                <Setter Property="Padding"                  Value="0"/>
                                                <Setter Property="VerticalAlignment"        Value="Stretch"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background"      Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.CellStyle>

                                        <DataGrid.Columns>

                                            <DataGridTemplateColumn Header="Fecha y Hora" Width="140">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel VerticalAlignment="Center" Margin="12,0">
                                                            <TextBlock Text="{Binding Bitacora_Fecha, StringFormat='dd/MM/yyyy'}"
                                                                       Foreground="White" FontSize="12"/>
                                                            <TextBlock Text="{Binding Bitacora_Fecha, StringFormat='hh:mm tt'}"
                                                                       Foreground="#505880" FontSize="11"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="Usuario" Width="180">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                                            <Border Width="32" Height="32" CornerRadius="16"
                                                                    Background="#1e2235" Margin="0,0,10,0">
                                                                <materialDesign:PackIcon Kind="Account" Foreground="#4f6ef7"
                                                                                         Width="16" Height="16"
                                                                                         HorizontalAlignment="Center"
                                                                                         VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Bitacora_Usuario}"
                                                                           Foreground="White" FontSize="12" FontWeight="Medium"
                                                                           TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                                                                <TextBlock Text="{Binding Bitacora_Rol}"
                                                                           Foreground="#505880" FontSize="11"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="Módulo" Width="130">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="6" Padding="10,4"
                                                                Background="#1a1d35"
                                                                HorizontalAlignment="Left"
                                                                Margin="12,0" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal">
                                                                <materialDesign:PackIcon Kind="CubeOutline"
                                                                                         Foreground="#4f6ef7"
                                                                                         Width="12" Height="12"
                                                                                         VerticalAlignment="Center"
                                                                                         Margin="0,0,5,0"/>
                                                                <TextBlock Text="{Binding Bitacora_Modulo}"
                                                                           Foreground="#4f6ef7" FontSize="11" FontWeight="Medium"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="Acción" Width="130">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="6" Padding="10,4"
                                                                HorizontalAlignment="Left"
                                                                Margin="12,0" VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#1a1d35"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Bitacora_Accion}" Value="Crear">
                                                                            <Setter Property="Background" Value="#0d1f15"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Bitacora_Accion}" Value="Editar">
                                                                            <Setter Property="Background" Value="#2a1e00"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Bitacora_Accion}" Value="Eliminar">
                                                                            <Setter Property="Background" Value="#1f0d0d"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Bitacora_Accion}" Value="Consultar">
                                                                            <Setter Property="Background" Value="#1a1d35"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Bitacora_Accion}" FontSize="11" FontWeight="Medium">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#4f6ef7"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Bitacora_Accion}" Value="Crear">
                                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Bitacora_Accion}" Value="Editar">
                                                                                <Setter Property="Foreground" Value="#F0A500"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Bitacora_Accion}" Value="Eliminar">
                                                                                <Setter Property="Foreground" Value="#E74C3C"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Bitacora_Accion}" Value="Consultar">
                                                                                <Setter Property="Foreground" Value="#4f6ef7"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="Descripción" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel VerticalAlignment="Center" Margin="12,0">
                                                            <TextBlock Text="{Binding Bitacora_Descripcion}"
                                                                       Foreground="#8890b5" FontSize="12"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>