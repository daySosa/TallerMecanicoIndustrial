<Window x:Class="Órdenes_de_Trabajo.MenúPrincipalOrdenes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:Órdenes_de_Trabajo"
        mc:Ignorable="d"
        Title="MenúPrincipalÓrdenes" Height="850" Width="1200"
        TextElement.Foreground="#242731" WindowStyle="ThreeDBorderWindow"
        Background="#1F2128" WindowStartupLocation="CenterScreen" BorderBrush="#242731">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="20*"/>
        </Grid.ColumnDefinitions>

        <materialDesign:ColorZone Grid.Column="0" CornerRadius="15 0 0 15"
                                  Background="#242731" VerticalAlignment="Stretch">
            <StackPanel Margin="15,0,15,0">

                <WrapPanel Margin="0,10,5,60" HorizontalAlignment="Center" Height="184" Width="185">
                    <Image RenderOptions.BitmapScalingMode="HighQuality" Source="/Imagenes/OSM_LOGO.png" Height="184"/>
                </WrapPanel>

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto" Height="35"
                        materialDesign:RippleAssist.Feedback="White" Margin="0,-40,0,15"
                        Click="btnHome_Click">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="Home" VerticalAlignment="Center" Foreground="White" Height="25" Width="38"/>
                        <TextBlock Foreground="White" FontSize="15">Pantalla Principal</TextBlock>
                    </WrapPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto" Height="35"
                        materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15"
                        Click="btnInventario_Click">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="PackageVariant" VerticalAlignment="Center" Foreground="White" Height="26" Width="38"/>
                        <TextBlock Foreground="White" FontSize="15">Inventario</TextBlock>
                    </WrapPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto" Height="35"
                        materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15"
                        Click="btnVehiculos_Click">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="CarSportsUtilityVehicle" VerticalAlignment="Center" Foreground="White" Width="39" Height="25"/>
                        <TextBlock Foreground="White" FontSize="15">Vehículos</TextBlock>
                    </WrapPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto" Height="35"
                        materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15"
                        Click="btnClientes_Click">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="People" VerticalAlignment="Center" Foreground="White" Height="25" Width="39"/>
                        <TextBlock Foreground="White" FontSize="15">Clientes</TextBlock>
                    </WrapPanel>
                </Button>

                <Expander Background="#242731" Foreground="White" FontFamily="Segoe UI" FontSize="13"
                          BorderThickness="0" Margin="0,0,0,15">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Width="250">
                            <materialDesign:PackIcon Kind="BookOpenPageVariant" VerticalAlignment="Center"
                                                     Margin="5,0,10,0" Foreground="White" Height="18" Width="35"/>
                            <TextBlock Foreground="White" FontSize="15">Contabilidad</TextBlock>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Background="#242731">
                        <Button Background="#242731" BorderThickness="0" Foreground="White"
                                FontSize="15" HorizontalContentAlignment="Left" Click="btnEgresos_Click">
                            <StackPanel Orientation="Horizontal" Width="250">
                                <materialDesign:PackIcon Kind="CurrencyUsd" VerticalAlignment="Center" Margin="15,0,20,0" Foreground="White"/>
                                <TextBlock Text="Egresos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Background="#242731" BorderThickness="0" Foreground="White"
                                FontSize="15" HorizontalContentAlignment="Left" Click="btnIngresos_Click">
                            <StackPanel Orientation="Horizontal" Width="250">
                                <materialDesign:PackIcon Kind="CreditCard" VerticalAlignment="Center" Margin="15,0,20,0" Foreground="White"/>
                                <TextBlock Text="Ingresos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Expander>

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto" Height="35"
                        materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="OrderBoolAscending" VerticalAlignment="Center" Foreground="White" Height="25" Width="39"/>
                        <TextBlock Foreground="White" FontSize="15" FontWeight="SemiBold">Órdenes</TextBlock>
                    </WrapPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto" Height="35"
                        materialDesign:RippleAssist.Feedback="White" VerticalAlignment="Bottom" Margin="0,70,0,15"
                        Click="btnCerrarSesion_Click">
                    <WrapPanel Width="175">
                        <materialDesign:PackIcon Kind="LogoutVariant" VerticalAlignment="Center" Foreground="White" Width="39" Height="21"/>
                        <TextBlock Foreground="White" FontSize="15">Cerrar Sesión</TextBlock>
                    </WrapPanel>
                </Button>

            </StackPanel>
        </materialDesign:ColorZone>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1A1D2E" Height="80">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="25,0,20,0">
                        <TextBlock Text="Hola, Oscar Sosa" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Revisemos tu taller hoy" Foreground="#6B7280" FontSize="12"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#252836" CornerRadius="5"
                            VerticalAlignment="Center" Height="40" MaxWidth="400"
                            HorizontalAlignment="Left" Margin="100,0,0,0" Width="400">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                            <materialDesign:PackIcon Kind="Magnify" Foreground="#6B7280"
                                                     Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="txtBuscar" Background="Transparent" Foreground="#6B7280"
                                     BorderThickness="0" VerticalAlignment="Center"
                                     FontSize="13" Width="200" CaretBrush="White"
                                     TextChanged="txtBuscar_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Setter Property="materialDesign:HintAssist.Hint" Value="Buscar..."/>
                                        <Setter Property="materialDesign:HintAssist.Foreground" Value="#6B7280"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="16,0">
                        <Button x:Name="btnNotificaciones"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Foreground="#6B7280" Width="38" Height="38"
                                Click="btnNotificaciones_Click">
                            <materialDesign:PackIcon Kind="BellOutline" Width="22" Height="22"/>
                        </Button>

                        <Border x:Name="badgeNotificaciones"
                                Background="#FF4444" CornerRadius="8"
                                Width="16" Height="16"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Visibility="Collapsed">
                            <TextBlock x:Name="txtContadorNotificaciones"
                                       Text="0" Foreground="White"
                                       FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <Popup x:Name="popupNotificaciones"
                               PlacementTarget="{Binding ElementName=btnNotificaciones}"
                               Placement="Bottom" StaysOpen="False"
                               AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="#252836" CornerRadius="10"
                                    BorderBrush="#2A3A4D" BorderThickness="1"
                                    Width="360" MaxHeight="480"
                                    Effect="{DynamicResource MaterialDesignShadowDepth3}">
                                <Grid Margin="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="BellOutline" Foreground="White"
                                                                     Width="18" Height="18"
                                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Notificaciones" Foreground="White"
                                                       FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" x:Name="badgeContadorPopup"
                                                Background="#FF4444" CornerRadius="10"
                                                Padding="8,2" VerticalAlignment="Center"
                                                Visibility="Collapsed">
                                            <TextBlock x:Name="txtContadorPopup"
                                                       Text="0" Foreground="White"
                                                       FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                    <Rectangle Grid.Row="2" Height="1" Fill="#2A3A4D"/>
                                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" MaxHeight="320">
                                        <StackPanel x:Name="panelNotificaciones"/>
                                    </ScrollViewer>
                                    <Button Grid.Row="6" x:Name="btnMarcarTodas"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="#3D7EFF" BorderBrush="#3D7EFF"
                                            materialDesign:ButtonAssist.CornerRadius="8"
                                            Height="36" FontSize="12"
                                            Visibility="Collapsed"
                                            Click="btnMarcarTodas_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CheckAll" Width="16" Height="16"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Marcar todas como leídas" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>

                    <Rectangle Grid.Column="3" Fill="#3D4458" Margin="0,20"/>

                    <StackPanel Grid.Column="4" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,20,0">
                        <Border Width="38" Height="38" CornerRadius="18" ClipToBounds="True"
                                Margin="0,0,10,0" BorderBrush="#3D7EFF" BorderThickness="2"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Oscar Sosa" Foreground="#3D7EFF" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Propietario" Foreground="#6B7280" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20,15,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#3D7EFF" Foreground="White"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Height="38" Padding="16,0"
                        Click="BtnNuevaOrden_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Nueva Orden" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#2E7D32" Foreground="White"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Height="38" Padding="16,0" Margin="10,0,10,0"
                    Click="btnReportes_Click">  
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilePdfBox" Width="18" Height="18"
                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Reportes" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>


                <Button x:Name="btnFiltrar" Grid.Column="2"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#6B7280" BorderBrush="#3D4458"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Height="38" Padding="14,0"
                        Click="btnFiltrar_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterVariant" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Filtrar" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Grid>

            <materialDesign:Card Grid.Row="2" Background="#1E2A3A"
                                 materialDesign:ElevationAssist.Elevation="Dp4"
                                 UniformCornerRadius="10" Margin="20,0,20,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,16" BorderBrush="#2A3A4D" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Órdenes de Trabajo" Foreground="White" FontSize="15" FontWeight="Medium"/>
                            <Border Background="#1A3050" CornerRadius="4" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="tbTotalOrdenes" Text="0 órdenes" Foreground="#4A9EFF" FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1" x:Name="dgOrdenes"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserResizeRows="False" CanUserReorderColumns="False"
                              CanUserResizeColumns="False"
                              IsReadOnly="True" SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2A3A4D"
                              Background="Transparent" Foreground="White"
                              BorderThickness="0" RowBackground="Transparent"
                              AlternatingRowBackground="#162030"
                              ColumnHeaderHeight="40" RowHeight="55"
                              SelectionChanged="dgOrdenes_SelectionChanged"
                              materialDesign:DataGridAssist.CellPadding="0"
                              materialDesign:DataGridAssist.ColumnHeaderPadding="12,0">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#8B9BB4"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#2A3A4D"/>
                                <Setter Property="SeparatorVisibility" Value="Collapsed"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A2A3D"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2A3A4D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="{x:Type DataGridCell}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="No." Binding="{Binding Orden_ID}" Width="55">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#8B9BB4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                        <Setter Property="FontSize" Value="12"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Cliente" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                            <Border Width="30" Height="30" CornerRadius="15"
                                                    Background="#2A3A4D" Margin="0,0,8,0">
                                                <materialDesign:PackIcon Kind="Account" Foreground="#8B9BB4"
                                                                         Width="16" Height="16"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Cliente_NombreCompleto}"
                                                           Foreground="White" FontSize="12" FontWeight="Medium"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                                                <TextBlock Text="{Binding Vehiculo_Placa}"
                                                           Foreground="#8B9BB4" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Repuesto" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="12,0">
                                            <TextBlock Text="{Binding Producto_Nombre}"
                                                       Foreground="White" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Producto_Categoria}"
                                                       Foreground="#8B9BB4" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Fecha Orden" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="12,0">
                                            <TextBlock Text="{Binding Fecha, StringFormat='dd/MM/yyyy'}"
                                                       Foreground="White" FontSize="12"/>
                                            <TextBlock Text="{Binding Fecha, StringFormat='hh:mm tt'}"
                                                       Foreground="#8B9BB4" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="F. Entrega"
                                               Binding="{Binding Fecha_Entrega, StringFormat='dd/MM/yyyy'}"
                                               Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#C0CCDA"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                        <Setter Property="FontSize" Value="12"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Estado" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12" Padding="10,4"
                                                HorizontalAlignment="Left" Margin="12,0" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1A2A1A"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Estado}" Value="En Espera">
                                                            <Setter Property="Background" Value="#2A1E00"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Estado}" Value="En Proceso">
                                                            <Setter Property="Background" Value="#1A1A2A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Estado}" Value="Sin Empezar">
                                                            <Setter Property="Background" Value="#2A2A2A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Estado}" Value="Finalizado">
                                                            <Setter Property="Background" Value="#0A2A0A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Estado}" FontSize="11" FontWeight="Medium">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Estado}" Value="En Espera">
                                                                <Setter Property="Foreground" Value="#F0A500"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Estado}" Value="En Proceso">
                                                                <Setter Property="Foreground" Value="#4A9EFF"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Estado}" Value="Sin Empezar">
                                                                <Setter Property="Foreground" Value="#8B9BB4"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Estado}" Value="Finalizado">
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Servicio"
                                               Binding="{Binding Servicio_Precio, StringFormat='L {0:N2}'}"
                                               Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#C0CCDA"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                        <Setter Property="FontSize" Value="12"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Total"
                                               Binding="{Binding OrdenPrecio_Total, StringFormat='L {0:N2}'}"
                                               Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <Popup x:Name="popupFiltros"
               Grid.Column="1"
               PlacementTarget="{Binding ElementName=btnFiltrar}"
               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Background="#252836" CornerRadius="10"
                    Padding="20" MinWidth="280"
                    Effect="{DynamicResource MaterialDesignShadowDepth3}">
                <StackPanel>
                    <TextBlock Text="Filtrar Órdenes" Foreground="White"
                               FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <TextBlock Text="Cliente" Foreground="#8B9BB4" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtFiltroCliente" Height="38" Margin="0,0,0,14">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Background" Value="#1A1D2E"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="CaretBrush" Value="White"/>
                                <Setter Property="BorderBrush" Value="#3D4458"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding" Value="10,0"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6">
                                                <ScrollViewer x:Name="PART_ContentHost"
                                                              Margin="{TemplateBinding Padding}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                              Focusable="False"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#3D7EFF"/>
                                                    <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBlock Text="Estado" Foreground="#8B9BB4" FontSize="12" Margin="0,0,0,6"/>
                    <ComboBox x:Name="cmbFiltroEstado" Height="38" Margin="0,0,0,20"
                              Background="#1A1D2E" Foreground="White"
                              BorderBrush="#3D4458" BorderThickness="1"
                              FontSize="13" Padding="8,0,0,0"
                              VerticalContentAlignment="Center">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#252836"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3a3f5c"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2e3250"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBoxItem Content="Todos" IsSelected="True"/>
                        <ComboBoxItem Content="Sin Empezar"/>
                        <ComboBoxItem Content="En Espera"/>
                        <ComboBoxItem Content="En Proceso"/>
                        <ComboBoxItem Content="Finalizado"/>
                    </ComboBox>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Limpiar"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="#6B7280" BorderBrush="#3D4458"
                                Height="36" Click="btnLimpiarFiltros_Click"/>
                        <Button Grid.Column="2" Content="Aplicar"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#3D7EFF" Foreground="White"
                                materialDesign:ButtonAssist.CornerRadius="6"
                                Height="36" Click="btnAplicarFiltros_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Popup>

    </Grid>
</Window>