<Window x:Class="Contabilidad.AgregarGasto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:Contabilidad"
        mc:Ignorable="d"
        Title="AgregarGasto" Height="590" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1e2130"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <Style x:Key="BtnCancelarStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#6c7293"/>
            <Setter Property="Foreground" Value="#6c7293"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
        </Style>
    </Window.Resources>

    <Border Padding="24">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock x:Name="txtTitulo"
                           Text="Nuevo Gasto"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,24"/>

                <TextBlock Text="TIPO DE GASTO"
                           Foreground="#a0a8c8"
                           FontSize="11"
                           FontWeight="Medium"
                           Margin="0,0,0,6"/>
                <ComboBox x:Name="cmbTipoGasto"
                          Height="47"
                          Margin="0,0,0,16"
                          Foreground="White"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          materialDesign:HintAssist.Hint="Selecciona un tipo">
                    <ComboBoxItem Content="Gasto en Repuesto"/>
                    <ComboBoxItem Content="Gasto Adicional"/>
                </ComboBox>

                <TextBlock Text="NOMBRE DEL GASTO"
                           Foreground="#a0a8c8"
                           FontSize="11"
                           FontWeight="Medium"
                           Margin="0,0,0,6"/>

                <TextBox x:Name="txtNombreGasto"
                     Height="50"
                     Margin="0,0,0,16"
                     Foreground="White"
                     CaretBrush="White"
                     Background="#252836"
                     BorderBrush="#3a3f5c"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="Ej: Compra de aceite, Pago de luz..."
                     PreviewTextInput="txtNombreGasto_PreviewTextInput" />

                <TextBlock Text="PRECIO"
                           Foreground="#a0a8c8"
                           FontSize="11"
                           FontWeight="Medium"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="txtPrecio"
                            Height="47"
                            Margin="0,0,0,16"
                            Foreground="White"
                            CaretBrush="White"
                            Background="#252836"
                            BorderBrush="#3a3f5c"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            materialDesign:HintAssist.Hint="L 0.00"
                            LostFocus="txtPrecio_LostFocus"
                            GotFocus="txtPrecio_GotFocus"/>

                <TextBlock Text="OBSERVACIONES"
                           Foreground="#a0a8c8"
                           FontSize="11"
                           FontWeight="Medium"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="txtObservaciones"
                         Height="100"
                         Margin="0,0,0,24"
                         Foreground="White"
                         CaretBrush="White"
                         Background="#252836"
                         BorderBrush="#3a3f5c"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Escribe los detalles del gasto..."/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnCancelar" Grid.Column="0"
                            Content="Cancelar"
                            Height="40"
                            Style="{StaticResource BtnCancelarStyle}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            materialDesign:RippleAssist.Feedback="#6c7293"
                            Click="btnCancelar_Click"/>

                    <Button Grid.Column="2"
                            x:Name="btnGuardar"
                            Content="Guardar Gasto"
                            Height="40"
                            Background="#3D7EFF"
                            Foreground="White"
                            BorderBrush="#3D7EFF"
                            BorderThickness="0"
                            FontSize="14"
                            FontWeight="SemiBold"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            materialDesign:ElevationAssist.Elevation="Dp0"
                            materialDesign:RippleAssist.Feedback="White"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="btnGuardar_Click"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>