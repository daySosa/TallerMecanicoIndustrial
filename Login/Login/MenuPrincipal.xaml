<Window x:Class="Dasboard_Prueba.MenuPrincipal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:Dasboard_Prueba"
        Title="Menú Principal" Height="850" Width="1200"
        TextElement.Foreground="White"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <DropShadowEffect x:Key="WinShadow" Color="#000000" BlurRadius="48" ShadowDepth="0" Opacity="0.75"/>

        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="9" Padding="12,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="bg"
                                                Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                To="#1e2235" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="bg"
                                                Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                To="Transparent" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarButtonLogout" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="9" Padding="12,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="bg"
                                                Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                To="#3d1b1b" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="bg"
                                                Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                To="Transparent" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="14" Effect="{StaticResource WinShadow}">
        <Border CornerRadius="14" ClipToBounds="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#13161f"
                        BorderBrush="#1e2235" BorderThickness="0,0,1,0">
                    <DockPanel LastChildFill="False">

                        <Border DockPanel.Dock="Top" Padding="24,22,24,10">
                            <StackPanel>
                                <Image RenderOptions.BitmapScalingMode="HighQuality"
                                       Source="/Imagenes/OSM_LOGO.png" Height="70"
                                       HorizontalAlignment="Center"/>
                                <TextBlock Text="OSM TALLER" Foreground="#4f6ef7"
                                           FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <Rectangle DockPanel.Dock="Top" Height="1" Fill="#1e2235" Margin="16,0,16,12"/>

                        <TextBlock DockPanel.Dock="Top" Text="MENÚ PRINCIPAL"
                                   Foreground="#353a58" FontSize="9" FontWeight="Bold"
                                   Margin="24,0,0,8"/>

                        <StackPanel DockPanel.Dock="Top" Margin="10,0">

                            <Button Style="{StaticResource SidebarButton}" Margin="0,2">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewDashboardOutline" Foreground="#8890b5"
                                                             Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Pantalla Principal" Foreground="#8890b5"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SidebarButton}" Margin="0,2"
                                    Click="btnInventario_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PackageVariant" Foreground="#8890b5"
                                                             Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Inventario" Foreground="#8890b5"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SidebarButton}" Margin="0,2"
                                    Click="btnVehiculos_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CarSportsUtilityVehicle" Foreground="#8890b5"
                                                             Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Vehículos" Foreground="#8890b5"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SidebarButton}" Margin="0,2"
                                    Click="btnClientes_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountGroupOutline" Foreground="#8890b5"
                                                             Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Clientes" Foreground="#8890b5"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SidebarButton}" Margin="0,2"
                                    Click="btnOrdenes_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ClipboardListOutline" Foreground="#8890b5"
                                                             Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Órdenes" Foreground="#8890b5"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="btnUsuarios" Style="{StaticResource SidebarButton}" Margin="0,2" Click="btnUsuarios_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountCogOutline" Foreground="#8890b5"
                                   Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Usuarios" Foreground="#8890b5"
                                                FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="btnBitacora" Style="{StaticResource SidebarButton}" Margin="0,2" Click="btnBitacora_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="NotebookOutline" Foreground="#8890b5"
                                   Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Bitácora" Foreground="#8890b5"
                                                FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Expander x:Name="expanderContabilidad" Background="Transparent" Foreground="#8890b5"
                            BorderThickness="0" Margin="-8,2,0,2">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal" Margin="-4,0,0,0" Width="200">
                                        <materialDesign:PackIcon Kind="BookOpenPageVariant" Foreground="#8890b5"
                                                                 Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="Contabilidad" Foreground="#8890b5"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="30,2,0,2">
                                    <Button Style="{StaticResource SidebarButton}" Height="36" Margin="0,1"
                                            Click="btnEgresos_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ArrowDownCircleOutline" Foreground="#8890b5"
                                                                     Width="15" Height="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="Egresos" Foreground="#8890b5"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SidebarButton}" Height="36" Margin="0,1"
                                            Click="btnIngresos_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ArrowUpCircleOutline" Foreground="#8890b5"
                                                                     Width="15" Height="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="Ingresos" Foreground="#8890b5"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Expander>

                        </StackPanel>

                        <Rectangle DockPanel.Dock="Bottom" Height="1" Fill="#1e2235" Margin="16,0,16,0"/>
                        <Button DockPanel.Dock="Bottom" Style="{StaticResource SidebarButtonLogout}"
                                Margin="10,4,10,8" Click="btnCerrarSesion_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="LogoutVariant" Foreground="#E74C3C"
                                                         Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Cerrar Sesión" Foreground="#E74C3C"
                                           FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Rectangle DockPanel.Dock="Bottom" Height="1" Fill="#1e2235" Margin="16,0,16,0"/>

                        <Border DockPanel.Dock="Bottom" Margin="12,8,12,12"
                                Background="#0f1117" CornerRadius="10"
                                BorderBrush="#1e2235" BorderThickness="1"
                                Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Margin="0,0,10,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2a3580" Offset="0"/>
                                            <GradientStop Color="#1c2455" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock x:Name="txtInicialesAvatar" Text="US" Foreground="#7986f7"
                                               FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="txtNombreUsuario" Text="" Foreground="White"
                                               FontSize="14" FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="txtRolUsuario" Text="Propietario"
                                               Foreground="#4f6ef7" FontSize="10"/>
                                </StackPanel>
                                <Ellipse Grid.Column="2" Width="8" Height="8"
                                         Fill="#4CAF50" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </DockPanel>
                </Border>

                <Grid Grid.Column="1" Background="#0f1117">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#13161f" Height="68"
                            BorderBrush="#1e2235" BorderThickness="0,0,0,1">
                        <Grid Margin="24,0,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="txtSaludoHeader" Text="Hola" Foreground="White"
                                           FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Revisemos tu taller hoy" Foreground="#505880" FontSize="11"/>
                            </StackPanel>

                            <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,4,0">
                                <Button x:Name="btnNotificaciones"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        Foreground="#505880" Width="36" Height="36"
                                        Click="btnNotificaciones_Click">
                                    <materialDesign:PackIcon Kind="BellOutline" Width="20" Height="20"/>
                                </Button>
                                <Border x:Name="badgeNotificaciones" Background="#E74C3C" CornerRadius="8"
                                        Width="16" Height="16"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="txtContadorNotificaciones" Text="0"
                                               Foreground="White" FontSize="9" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Popup x:Name="popupNotificaciones"
                                       PlacementTarget="{Binding ElementName=btnNotificaciones}"
                                       Placement="Bottom" StaysOpen="False"
                                       AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="#13161f" CornerRadius="12"
                                            BorderBrush="#1e2235" BorderThickness="1"
                                            Width="360" MaxHeight="480">
                                        <Grid Margin="16">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="BellOutline" Foreground="White"
                                                                             Width="16" Height="16"
                                                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Notificaciones" Foreground="White"
                                                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" x:Name="badgeContadorPopup"
                                                        Background="#E74C3C" CornerRadius="10"
                                                        Padding="8,2" VerticalAlignment="Center"
                                                        Visibility="Collapsed">
                                                    <TextBlock x:Name="txtContadorPopup" Text="0"
                                                               Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                            <Rectangle Grid.Row="2" Height="1" Fill="#1e2235"/>
                                            <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" MaxHeight="320">
                                                <StackPanel x:Name="panelNotificaciones"/>
                                            </ScrollViewer>
                                            <Button Grid.Row="6" x:Name="btnMarcarTodas"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    Foreground="#4f6ef7" BorderBrush="#4f6ef7"
                                                    materialDesign:ButtonAssist.CornerRadius="8"
                                                    Height="36" FontSize="12" Visibility="Collapsed"
                                                    Click="btnMarcarTodas_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="CheckAll" Width="16" Height="16"
                                                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Marcar todas como leídas" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="24,20,24,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="145"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" CornerRadius="12" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1e2a5e" Offset="0"/>
                                        <GradientStop Color="#151b42" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#4f6ef7" BlurRadius="18" Opacity="0.12" ShadowDepth="0"/>
                                </Border.Effect>
                                <Grid Margin="18,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="72"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#252840" CornerRadius="7" Width="28" Height="28" Margin="0,0,8,0">
                                                <materialDesign:PackIcon Kind="CurrencyUsd" Foreground="#7986f7"
                                                                         Width="16" Height="16"
                                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Balance Total" Foreground="#8890b5"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="txtBalanceTotal" Text="L 0.00" Foreground="White"
                                                   FontSize="22" FontWeight="Bold" Margin="0,8,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <materialDesign:PackIcon Kind="TrendingUp" Foreground="#4CAF50"
                                                                     Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="Ingresos totales" Foreground="#4CAF50" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <lvc:CartesianChart Grid.Column="1" VerticalAlignment="Bottom" Height="55"
                                                        Hoverable="False" DataTooltip="{x:Null}">
                                        <lvc:CartesianChart.Series>
                                            <lvc:ColumnSeries Values="{Binding BalanceValues}" Fill="#4f6ef7" StrokeThickness="0"/>
                                        </lvc:CartesianChart.Series>
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis ShowLabels="False">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator StrokeThickness="0"/>
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis ShowLabels="False">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator StrokeThickness="0"/>
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                    </lvc:CartesianChart>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" CornerRadius="12" Margin="5,0"
                                    Background="#13161f" BorderBrush="#1e2235" BorderThickness="1">
                                <Grid Margin="18,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="72"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#1e2235" CornerRadius="7" Width="28" Height="28" Margin="0,0,8,0">
                                                <materialDesign:PackIcon Kind="ClipboardListOutline" Foreground="#8890b5"
                                                                         Width="16" Height="16"
                                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Total Órdenes" Foreground="#8890b5"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="txtTotalOrdenes" Text="0" Foreground="White"
                                                   FontSize="26" FontWeight="Bold" Margin="0,8,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <materialDesign:PackIcon Kind="TrendingUp" Foreground="#4CAF50"
                                                                     Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="Órdenes registradas" Foreground="#4CAF50" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <lvc:CartesianChart Grid.Column="1" VerticalAlignment="Bottom" Height="55"
                                                        Hoverable="False" DataTooltip="{x:Null}">
                                        <lvc:CartesianChart.Series>
                                            <lvc:ColumnSeries Values="{Binding OrderValues}" Fill="#4f6ef7" StrokeThickness="0"/>
                                        </lvc:CartesianChart.Series>
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis ShowLabels="False">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator StrokeThickness="0"/>
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis ShowLabels="False">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator StrokeThickness="0"/>
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                    </lvc:CartesianChart>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" CornerRadius="12" Margin="10,0,0,0"
                                    Background="#13161f" BorderBrush="#1e2235" BorderThickness="1">
                                <Grid Margin="18,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="72"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#1e2235" CornerRadius="7" Width="28" Height="28" Margin="0,0,8,0">
                                                <materialDesign:PackIcon Kind="TagOutline" Foreground="#8890b5"
                                                                         Width="16" Height="16"
                                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Gastos Totales" Foreground="#8890b5"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="txtGastosTotales" Text="L 0.00" Foreground="White"
                                                   FontSize="22" FontWeight="Bold" Margin="0,8,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <materialDesign:PackIcon Kind="TrendingDown" Foreground="#E74C3C"
                                                                     Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="Gastos registrados" Foreground="#E74C3C" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <lvc:CartesianChart Grid.Column="1" VerticalAlignment="Bottom" Height="55"
                                                        Hoverable="False" DataTooltip="{x:Null}">
                                        <lvc:CartesianChart.Series>
                                            <lvc:ColumnSeries Values="{Binding GastosValues}" Fill="#E74C3C" StrokeThickness="0"/>
                                        </lvc:CartesianChart.Series>
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis ShowLabels="False">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator StrokeThickness="0"/>
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis ShowLabels="False">
                                                <lvc:Axis.Separator>
                                                    <lvc:Separator StrokeThickness="0"/>
                                                </lvc:Axis.Separator>
                                            </lvc:Axis>
                                        </lvc:CartesianChart.AxisY>
                                    </lvc:CartesianChart>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" CornerRadius="12" Margin="0,0,12,0"
                                    Background="#13161f" BorderBrush="#1e2235" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Padding="18,14"
                                            BorderBrush="#1e2235" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ClockOutline" Foreground="#4f6ef7"
                                                                         Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Órdenes Recientes" Foreground="White"
                                                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="#1a1d35" CornerRadius="6"
                                                    Padding="10,4" VerticalAlignment="Center">
                                                <TextBlock x:Name="tbTotalOrdenes" Text="0 órdenes"
                                                           Foreground="#4f6ef7" FontSize="11"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <DataGrid Grid.Row="1" x:Name="dgOrdenes"
                                              AutoGenerateColumns="False" CanUserAddRows="False"
                                              CanUserDeleteRows="False" CanUserResizeRows="False"
                                              CanUserReorderColumns="False" CanUserResizeColumns="False"
                                              IsReadOnly="True" SelectionMode="Single"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#1e2235"
                                              Background="Transparent" Foreground="White"
                                              BorderThickness="0" RowBackground="Transparent"
                                              AlternatingRowBackground="#0d1020"
                                              ColumnHeaderHeight="38" RowHeight="60"
                                              EnableRowVirtualization="True"
                                              EnableColumnVirtualization="True"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              ScrollViewer.CanContentScroll="True"
                                              materialDesign:DataGridAssist.CellPadding="52"
                                              materialDesign:DataGridAssist.ColumnHeaderPadding="12,0">

                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#505880"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="FontWeight" Value="Medium"/>
                                                <Setter Property="Padding" Value="12,0"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="BorderBrush" Value="#1e2235"/>
                                                <Setter Property="SeparatorVisibility" Value="Collapsed"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>

                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1a1d35"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>

                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="VerticalAlignment" Value="Stretch"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.CellStyle>

                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="No." Binding="{Binding Orden_ID}" Width="50">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#505880"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="Padding" Value="12,0"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTemplateColumn Header="Cliente" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                                            <Border Width="32" Height="32" CornerRadius="16"
                                                                    Background="#1e2235" Margin="0,0,10,0">
                                                                <materialDesign:PackIcon Kind="Account" Foreground="#505880"
                                                                                         Width="16" Height="16"
                                                                                         HorizontalAlignment="Center"
                                                                                         VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Cliente_NombreCompleto}"
                                                                           Foreground="White" FontSize="13" FontWeight="Medium"/>
                                                                <TextBlock Text="{Binding Vehiculo_Placa}"
                                                                           Foreground="#505880" FontSize="11"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="Fecha" Width="120">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel VerticalAlignment="Center" Margin="12,0">
                                                            <TextBlock Text="{Binding Fecha, StringFormat='dd/MM/yyyy'}"
                                                                       Foreground="White" FontSize="12"/>
                                                            <TextBlock Text="{Binding Fecha, StringFormat='HH:mm'}"
                                                                       Foreground="#505880" FontSize="11"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="Estado" Width="110">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="6" Padding="10,4"
                                                                HorizontalAlignment="Left"
                                                                Margin="12,0" VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#0d1f15"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Estado}" Value="En Espera">
                                                                            <Setter Property="Background" Value="#1f1a00"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Estado}" Value="En Proceso">
                                                                            <Setter Property="Background" Value="#0d1525"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Estado}" Value="Sin Empezar">
                                                                            <Setter Property="Background" Value="#1e2235"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Estado}" Value="Finalizado">
                                                                            <Setter Property="Background" Value="#0d1f15"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Estado}" FontSize="11" FontWeight="Medium">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Estado}" Value="En Espera">
                                                                                <Setter Property="Foreground" Value="#F0A500"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Estado}" Value="En Proceso">
                                                                                <Setter Property="Foreground" Value="#4f6ef7"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Estado}" Value="Sin Empezar">
                                                                                <Setter Property="Foreground" Value="#505880"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Estado}" Value="Finalizado">
                                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="Total"
                                                                Binding="{Binding OrdenPrecio_Total, StringFormat='L {0:N2}'}"
                                                                Width="100">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="Padding" Value="12,0"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Top">

                                <Border CornerRadius="12" Margin="0,0,0,12"
                                        Background="#13161f" BorderBrush="#1e2235" BorderThickness="1"
                                        Padding="16">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ChartBar" Foreground="#4f6ef7"
                                                                         Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Resumen de Ingresos" Foreground="White"
                                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ComboBox Grid.Column="1" x:Name="cmbRango"
                                                      Width="120" Height="26"
                                                      Background="#1e2235" Foreground="White"
                                                      BorderBrush="#252840" FontSize="11"
                                                      VerticalContentAlignment="Center"
                                                      SelectionChanged="cmbRango_SelectionChanged">
                                                <ComboBoxItem Content="Últimos 3 meses" Tag="3"/>
                                                <ComboBoxItem Content="Últimos 6 meses" Tag="6"/>
                                                <ComboBoxItem Content="Últimos 12 meses" Tag="12"/>
                                                <ComboBoxItem Content="Todos" Tag="0"/>
                                            </ComboBox>
                                        </Grid>
                                        <lvc:CartesianChart Height="90" Hoverable="False" DataTooltip="{x:Null}">
                                            <lvc:CartesianChart.Series>
                                                <lvc:ColumnSeries Values="{Binding IngresosSemanalValues}"
                                                                  Fill="#4f6ef7" StrokeThickness="0"
                                                                  MaxColumnWidth="16" ColumnPadding="4"/>
                                            </lvc:CartesianChart.Series>
                                            <lvc:CartesianChart.AxisX>
                                                <lvc:Axis Labels="{Binding IngresosSemanalLabels}"
                                                          Foreground="#505880" FontSize="9">
                                                    <lvc:Axis.Separator>
                                                        <lvc:Separator StrokeThickness="0"/>
                                                    </lvc:Axis.Separator>
                                                </lvc:Axis>
                                            </lvc:CartesianChart.AxisX>
                                            <lvc:CartesianChart.AxisY>
                                                <lvc:Axis ShowLabels="False">
                                                    <lvc:Axis.Separator>
                                                        <lvc:Separator StrokeThickness="0"/>
                                                    </lvc:Axis.Separator>
                                                </lvc:Axis>
                                            </lvc:CartesianChart.AxisY>
                                        </lvc:CartesianChart>
                                    </StackPanel>
                                </Border>

                                <Border CornerRadius="12"
                                        Background="#13161f" BorderBrush="#1e2235" BorderThickness="1"
                                        Padding="16">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <TextBlock x:Name="txtMesAnio" Foreground="White"
                                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button x:Name="btnAnterior"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Foreground="#505880" Width="26" Height="26"
                                                        Click="btnAnterior_Click">
                                                    <materialDesign:PackIcon Kind="ChevronLeft" Width="14" Height="14"/>
                                                </Button>
                                                <Button x:Name="btnSiguiente"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Foreground="#505880" Width="26" Height="26"
                                                        Click="btnSiguiente_Click">
                                                    <materialDesign:PackIcon Kind="ChevronRight" Width="14" Height="14"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <UniformGrid x:Name="gridDiasHeader" Columns="7" Margin="0,0,0,4"/>

                                        <UniformGrid x:Name="gridDias" Columns="7"/>

                                        <Rectangle Height="1" Fill="#1e2235" Margin="0,12,0,10"/>
                                        <TextBlock x:Name="txtTituloOrdenesDia" Text="Selecciona un día con órdenes"
                                                   Foreground="#505880" FontSize="11" Margin="0,0,0,8"/>
                                        <StackPanel x:Name="panelOrdenesDia"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Grid>

                    </Grid>

                </Grid>

            </Grid>
        </Border>
    </Border>
</Window>