<Window x:Class="Login.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:PresentationOptions="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
        Title="Login" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Opacity="0"
        MouseDown="Window_Drag"
        Loaded="Window_Loaded">

    <Window.Resources>
        <SolidColorBrush x:Key="BrushFondoOverlay" Color="#0B1120" Opacity="0.70"/>
        <SolidColorBrush x:Key="BrushTarjeta" Color="#03002E" Opacity="0.55"/>
        <SolidColorBrush x:Key="BrushBordeSutil" Color="#FFFFFF" Opacity="0.12"/>
        <SolidColorBrush x:Key="BrushInputFondo" Color="#FFFFFF" Opacity="0.07"/>
        <SolidColorBrush x:Key="BrushAcento" Color="#38BDF8"/>
        <SolidColorBrush x:Key="BrushTextoSecundario" Color="#94A3B8"/>
        <SolidColorBrush x:Key="BrushTextoTerciario" Color="#64748B"/>
        <SolidColorBrush x:Key="BrushPrimario" Color="#02006C"/>

        <Storyboard x:Key="FadeInVentana">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                              From="0" To="1" Duration="0:0:0.25"/>
        </Storyboard>

        <Style x:Key="EstiloTextBoxInput" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="materialDesign:HintAssist.Foreground" Value="{StaticResource BrushTextoTerciario}"/>
        </Style>

        <Style x:Key="EstiloBotonLink" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="TextoBoton"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{StaticResource BrushTextoTerciario}"
                                   FontSize="11" Background="Transparent"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="TextoBoton"
                                                            Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                                            To="#38BDF8" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="TextoBoton"
                                                            Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                                            To="#64748B" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="TextoBoton" Property="TextBlock.TextDecorations" Value="Underline"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="0" ClipToBounds="True">
        <Grid>

            <Image Source="/Imagenes/fondo_login.png"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   CacheMode="BitmapCache"/>

            <Rectangle Fill="{StaticResource BrushFondoOverlay}"/>

            <Ellipse Width="1198" Height="900"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Opacity="0.25">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#1E293B" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Border Width="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="20"
                    Padding="40,36"
                    Background="{StaticResource BrushTarjeta}"
                    BorderBrush="{StaticResource BrushBordeSutil}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.55" BlurRadius="45" ShadowDepth="0"/>
                </Border.Effect>

                <StackPanel>

                    <Border Width="78" Height="78" CornerRadius="50"
                            Background="{StaticResource BrushTarjeta}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Image Source="/Imagenes/OSM_LOGO.png"
                               Width="90" Height="90"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <TextBlock Text="OSM TALLER"
                               Foreground="White" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <TextBlock Text="Inicia sesión para continuar"
                               Foreground="{StaticResource BrushTextoSecundario}" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,0,0,28"/>

                    <Border x:Name="borderCorreo"
                            CornerRadius="10"
                            BorderThickness="1"
                            Height="46" Margin="0,0,0,4"
                            Background="{StaticResource BrushInputFondo}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0"
                                                     Kind="EmailOutline"
                                                     Foreground="{StaticResource BrushAcento}"
                                                     Width="18" Height="18"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                            <TextBox x:Name="txtCorreo"
                                     AutomationProperties.Name="Correo electrónico"
                                     Grid.Column="1"
                                     Style="{StaticResource EstiloTextBoxInput}"
                                     Padding="0,0,10,0"
                                     materialDesign:HintAssist.Hint="Correo electrónico"
                                     GotFocus="TxtCorreo_GotFocus"
                                     LostFocus="TxtCorreo_LostFocus"
                                     TextChanged="TxtCorreo_TextChanged"/>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="txtErrorCorreo" Text=""
                             Foreground="#F87171" FontSize="11"
                             TextWrapping="Wrap"
                             Margin="4,4,0,8" Visibility="Collapsed"/>

                    <Border x:Name="borderContrasena"
                            CornerRadius="10"
                            Height="46" Margin="0,4,0,4"
                            BorderThickness="1"
                            Background="{StaticResource BrushInputFondo}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="95*"/>
                                <ColumnDefinition Width="29*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon
                                                     Kind="LockOutline"
                                                     Foreground="{StaticResource BrushAcento}"
                                                     Width="18" Height="18"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                            <PasswordBox x:Name="txtContrasena"
                                         AutomationProperties.Name="Contraseña"
                                         Grid.Column="1" Grid.ColumnSpan="2"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="White"
                                         FontSize="13"
                                         Padding="0"
                                         VerticalContentAlignment="Center"
                                         GotFocus="TxtContrasena_GotFocus"
                                         LostFocus="TxtContrasena_LostFocus"/>
                            <TextBox x:Name="txtContrasenaVisible"
                                     AutomationProperties.Name="Contraseña visible"
                                     Grid.Column="1" Grid.ColumnSpan="2"
                                     Style="{StaticResource EstiloTextBoxInput}"
                                     Padding="0,0,10,0"
                                     materialDesign:HintAssist.Hint="••••••••"
                                     Visibility="Collapsed"
                                     GotFocus="TxtContrasena_GotFocus"
                                     LostFocus="TxtContrasena_LostFocus"/>
                            <Button Grid.Column="3"
                                    x:Name="btnVerContrasena"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand" Width="38" Height="38"
                                    Margin="3"
                                    Click="BtnVerContrasena_Click">
                                <materialDesign:PackIcon x:Name="iconOjo"
                                                         Kind="EyeOutline"
                                                         Foreground="{StaticResource BrushTextoSecundario}"
                                                         Width="18" Height="18"/>
                            </Button>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="txtErrorContrasena" Text=""
                               Foreground="#F87171" FontSize="11"
                               Margin="4,4,0,0" Visibility="Collapsed"/>

                    <TextBlock x:Name="txtContador"
                               Visibility="Collapsed"
                               Foreground="#f44336"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="4,4,0,0"
                               TextWrapping="Wrap"/>

                    <Grid Margin="0,18,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="chkRecordar"
                                  Grid.Column="0"
                                  Content="Recordar"
                                  Foreground="#CBD5E1" FontSize="11"
                                  VerticalAlignment="Center">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
                                    <Setter Property="materialDesign:CheckBoxAssist.CheckBoxSize" Value="15"/>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>

                        <Button Grid.Column="1"
                                Content="¿Olvidó su contraseña?"
                                Style="{StaticResource EstiloBotonLink}"
                                Click="BtnOlvidoContrasena_Click"
                                HorizontalAlignment="Right"/>
                    </Grid>

                    <Button x:Name="btnLogin"
                            Height="46"
                            FontSize="14" FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="BtnLogin_Click"
                            materialDesign:ButtonAssist.CornerRadius="10"
                            materialDesign:ElevationAssist.Elevation="Dp0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="Background" Value="{StaticResource BrushPrimario}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BrushPrimario}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="#0284C7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock x:Name="txtBotonLogin" Text="Iniciar Sesión" FontSize="14" FontWeight="SemiBold"/>
                    </Button>

                    <TextBlock Text="© 2026 Taller Mecánico"
                               Foreground="{StaticResource BrushTextoTerciario}" FontSize="10"
                               HorizontalAlignment="Center" Margin="0,22,0,0"/>

                </StackPanel>
            </Border>

            <Button x:Name="btnCerrarApp"
                    Content="✕"
                    Width="34" Height="34"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,18,18,0"
                    FontSize="14"
                    Foreground="{StaticResource BrushTextoSecundario}"
                    Cursor="Hand"
                    Click="BtnCerrarApp_Click"
                    Panel.ZIndex="99">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="fondo" CornerRadius="8" Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="fondo"
                                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                        To="#F87171" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Setter Property="Foreground" Value="#F87171"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>