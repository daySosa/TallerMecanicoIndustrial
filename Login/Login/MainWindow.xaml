<Window x:Class="Login.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="Login" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_Drag">

    <Border CornerRadius="0" ClipToBounds="True">
        <Grid>

            <Image Source="/Imagenes/fondo_login.png"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <Rectangle Fill="#0B1120" Opacity="0.70"/>

            <Ellipse Width="1198" Height="900"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Opacity="0.25">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#1E293B" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Border Width="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="20"
                    Padding="40,36">
                <Border.Background>
                    <SolidColorBrush Color="#03002E" Opacity="0.55"/>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#FFFFFF" Opacity="0.12"/>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.55" BlurRadius="45" ShadowDepth="0"/>
                </Border.Effect>

                <StackPanel>

                    <Border Width="78" Height="78" CornerRadius="50"
                            Background="#03002E" Opacity="0.55"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Image Source="/Imagenes/OSM_LOGO.png"
                               Width="90" Height="90"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <TextBlock Text="OSM TALLER"
                               Foreground="White" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <TextBlock Text="Inicia sesión para continuar"
                               Foreground="#94A3B8" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,0,0,28"/>

                    <Border x:Name="borderCorreo"
                            CornerRadius="10"
                            BorderThickness="1"
                            Height="46" Margin="0,0,0,4">
                        <Border.Background>
                            <SolidColorBrush Color="#FFFFFF" Opacity="0.07"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#FFFFFF" Opacity="0.12"/>
                        </Border.BorderBrush>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0"
                                                     Kind="EmailOutline"
                                                     Foreground="#38BDF8"
                                                     Width="18" Height="18"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                            <TextBox x:Name="txtCorreo"
                                     AutomationProperties.Name="Correo electrónico"
                                     Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     FontSize="13"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,10,0"
                                     CaretBrush="White"
                                     GotFocus="TxtCorreo_GotFocus"
                                     LostFocus="TxtCorreo_LostFocus"
                                     TextChanged="txtCorreo_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox"
                                           BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Setter Property="materialDesign:HintAssist.Hint" Value="Correo electrónico"/>
                                        <Setter Property="materialDesign:HintAssist.Foreground" Value="#64748B"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="txtErrorCorreo" Text=""
                             Foreground="#F87171" FontSize="11"
                             TextWrapping="Wrap"
                             Margin="4,4,0,8" Visibility="Collapsed"/>

                    <Border x:Name="borderContrasena"
                            CornerRadius="10"
                            Height="46" Margin="0,4,0,4">
                        <Border.Background>
                            <SolidColorBrush Color="#FFFFFF" Opacity="0.07"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#FFFFFF" Opacity="0.12"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="95*"/>
                                <ColumnDefinition Width="29*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon
                                                     Kind="LockOutline"
                                                     Foreground="#38BDF8"
                                                     Width="18" Height="18"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                            <PasswordBox x:Name="txtContrasena"
                                         AutomationProperties.Name="Contraseña"
                                         Grid.Column="1"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="White"
                                         FontSize="13"
                                         Padding="0"
                                         VerticalContentAlignment="Center"
                                         GotFocus="TxtContrasena_GotFocus"
                                         LostFocus="TxtContrasena_LostFocus"
                                         Visibility="Visible" Grid.ColumnSpan="2"/>
                            <TextBox x:Name="txtContrasenaVisible"
                                     AutomationProperties.Name="Contraseña visible"
                                     Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     FontSize="13"
                                     Padding="0,0,10,0"
                                     VerticalContentAlignment="Center"
                                     CaretBrush="White"
                                     Visibility="Collapsed"
                                     GotFocus="TxtContrasena_GotFocus"
                                     LostFocus="TxtContrasena_LostFocus" Grid.ColumnSpan="2">
                                <TextBox.Style>
                                    <Style TargetType="TextBox"
                                           BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Setter Property="materialDesign:HintAssist.Hint" Value="••••••••"/>
                                        <Setter Property="materialDesign:HintAssist.Foreground" Value="#64748B"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <Button Grid.Column="3"
                                    x:Name="btnVerContrasena"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand" Width="38" Height="38"
                                    Click="BtnVerContrasena_Click" Margin="3,3,3,3">
                                <materialDesign:PackIcon x:Name="iconOjo"
                                                         Kind="EyeOutline"
                                                         Foreground="#94A3B8"
                                                         Width="18" Height="18"/>
                            </Button>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="txtErrorContrasena" Text=""
                               Foreground="#F87171" FontSize="11"
                               Margin="4,4,0,0" Visibility="Collapsed"/>

                    <Grid Margin="0,18,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="chkRecordar"
                                  Grid.Column="0"
                                  Content="Recordar"
                                  Foreground="#CBD5E1" FontSize="11"
                                  VerticalAlignment="Center">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox"
                                       BasedOn="{StaticResource MaterialDesignCheckBox}">
                                    <Setter Property="materialDesign:CheckBoxAssist.CheckBoxSize" Value="15"/>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>

                        <Button Grid.Column="1"
                                Content="¿Olvidó su contraseña?"
                                Click="BtnOlvidoContrasena_Click"
                                Cursor="Hand"
                                HorizontalAlignment="Right">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock x:Name="TextoBoton"
                                                           Text="¿Olvidó su contraseña?"
                                                           Foreground="#64748B"
                                                           FontSize="11"
                                                           Cursor="Hand"
                                                           Background="Transparent"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="TextoBoton" Property="Foreground" Value="#38BDF8"/>
                                                        <Setter TargetName="TextoBoton" Property="TextBlock.TextDecorations" Value="Underline"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>



                    <Button Height="46"
                            FontSize="14" FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="BtnLogin_Click"
                            materialDesign:ButtonAssist.CornerRadius="10"
                            materialDesign:ElevationAssist.Elevation="Dp0">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="Background" Value="#02006C"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#02006C"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#02006C"/>
                                        <Setter Property="BorderBrush" Value="#0284C7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Iniciar Sesión" FontSize="14" FontWeight="SemiBold"/>
                    </Button>

                    <TextBlock Text="© 2026 Taller Mecánico"
                               Foreground="#64748B" FontSize="10"
                               HorizontalAlignment="Center" Margin="0,22,0,0"/>

                </StackPanel>
            </Border>

            <Button x:Name="btnCerrarApp"
                    Content="✕"
                    Width="34" Height="34"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,18,18,0"
                    FontSize="14"
                    Foreground="#94A3B8"
                    Cursor="Hand"
                    Click="BtnCerrarApp_Click"
                    Panel.ZIndex="99">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="fondo" CornerRadius="8" Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="fondo" Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#F87171" Opacity="0.15"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Foreground" Value="#F87171"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>