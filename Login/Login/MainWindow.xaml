<Window x:Class="Login.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="Login" Height="850" Width="1200" WindowStartupLocation="CenterScreen" Background="Transparent"
        MouseDown="Window_Drag">

    <Border CornerRadius="16" ClipToBounds="True">
        
        <Grid>

            <Image Source="/fondo_login.png"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <Border Width="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="18"
                    Padding="36,30"
                    BorderThickness="1">
                <Border.Background>
                    <SolidColorBrush Color="#7A8BA0" Opacity="0.55"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.5"
                                      BlurRadius="40" ShadowDepth="0"/>
                </Border.Effect>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#ffffff" Opacity="0.15"/>
                </Border.BorderBrush>

                <StackPanel>


                    <Image Source="/OSM_Logo_AR.png"
                           Height="90" Width="90"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="0,0,0,2"/>


                    <TextBlock Text="Bienvenido!"
                               Foreground="White" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Ingrese sus Credenciales para acceder a su cuenta"
                               Foreground="#dce3f0" FontSize="11"
                               TextWrapping="Wrap" TextAlignment="Center"
                               HorizontalAlignment="Center" Margin="0,0,0,22"/>

                    <TextBlock Text="Correo Electrónico" Foreground="White"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Border x:Name="borderCorreo"
                            Background="White" CornerRadius="8"
                            BorderBrush="Transparent" BorderThickness="1.5"
                            Height="42" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0"
                                                     Kind="EmailOutline"
                                                     Foreground="#5D5FEF"
                                                     Width="17" Height="17"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                            <TextBox x:Name="txtCorreo"
                                     Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#333"
                                     FontSize="13"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,10,0"
                                     CaretBrush="#333"
                                     GotFocus="TxtCorreo_GotFocus"
                                     LostFocus="TxtCorreo_LostFocus">
                                <TextBox.Style>
                                    <Style TargetType="TextBox"
                                           BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Setter Property="materialDesign:HintAssist.Hint"
                                                Value="Example@email.com"/>
                                        <Setter Property="materialDesign:HintAssist.Foreground"
                                                Value="#aaa"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="txtErrorCorreo" Text=""
                               Foreground="#f44336" FontSize="11"
                               Margin="4,0,0,8" Visibility="Collapsed"/>


                    <TextBlock Text="Contraseña" Foreground="White"
                               FontSize="11" FontWeight="SemiBold" Margin="0,4,0,5"/>
                    <Border x:Name="borderContrasena"
                            Background="White" CornerRadius="8"
                            BorderBrush="Transparent" BorderThickness="1.5"
                            Height="42" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="42"/>
                            </Grid.ColumnDefinitions>

                            <materialDesign:PackIcon Grid.Column="0"
                                                     Kind="LockOutline"
                                                     Foreground="#5D5FEF"
                                                     Width="17" Height="17"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>


                            <PasswordBox x:Name="txtContrasena"
                                         Grid.Column="1"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#333"
                                         FontSize="13"
                                         Padding="0"
                                         VerticalContentAlignment="Center"
                                         GotFocus="TxtContrasena_GotFocus"
                                         LostFocus="TxtContrasena_LostFocus"
                                         Visibility="Visible"/>

                            <TextBox x:Name="txtContrasenaVisible"
                                     Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#333"
                                     FontSize="13"
                                     Padding="0,0,10,0"
                                     VerticalContentAlignment="Center"
                                     CaretBrush="#333"
                                     Visibility="Collapsed"
                                     GotFocus="TxtContrasena_GotFocus"
                                     LostFocus="TxtContrasena_LostFocus">
                                <TextBox.Style>
                                    <Style TargetType="TextBox"
                                           BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Setter Property="materialDesign:HintAssist.Hint"
                                                Value="••••••••"/>
                                        <Setter Property="materialDesign:HintAssist.Foreground"
                                                Value="#aaa"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>


                            <Button Grid.Column="2"
                                    x:Name="btnVerContrasena"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand" Width="38" Height="38"
                                    Click="BtnVerContrasena_Click">
                                <materialDesign:PackIcon x:Name="iconOjo"
                                                         Kind="EyeOutline"
                                                         Foreground="#888"
                                                         Width="17" Height="17"/>
                            </Button>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="txtErrorContrasena" Text=""
                               Foreground="#f44336" FontSize="11"
                               Margin="4,0,0,0" Visibility="Collapsed"/>


                    <CheckBox x:Name="chkRecordar"
                              Content="Recordar"
                              Foreground="White" FontSize="11"
                              Margin="0,10,0,18">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox"
                                   BasedOn="{StaticResource MaterialDesignCheckBox}">
                                <Setter Property="materialDesign:CheckBoxAssist.CheckBoxSize"
                                        Value="15"/>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>


                    <Button Height="44"
                            FontSize="14" FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="BtnLogin_Click"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            materialDesign:ElevationAssist.Elevation="Dp0"
                            Margin="0,0,0,16">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="Background"  Value="#2563EB"/>
                                <Setter Property="Foreground"  Value="White"/>
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Iniciar Sesión" FontSize="14" FontWeight="SemiBold"/>
                    </Button>

                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>