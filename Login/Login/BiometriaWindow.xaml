<Window x:Class="InterfazClientes.VentanaBiometria"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Agregar Usuario a Biometría" Height="560" Width="820"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown"
        TextElement.Foreground="White">

    <Window.Resources>
        <DropShadowEffect x:Key="WinShadow" Color="#000000" BlurRadius="48" ShadowDepth="0" Opacity="0.75"/>
    </Window.Resources>

    <Grid>
        <Border CornerRadius="14" Effect="{StaticResource WinShadow}">
            <Border CornerRadius="14" ClipToBounds="True">
                <DockPanel LastChildFill="True" Background="#0f1117">

                    <!-- HEADER -->
                    <Border DockPanel.Dock="Top" Background="#13161f" Height="68"
                            BorderBrush="#1e2235" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0">
                            <Border Background="#1a1d35" CornerRadius="9"
                                    Width="38" Height="38" Margin="0,0,14,0"
                                    BorderBrush="#1e2235" BorderThickness="1">
                                <materialDesign:PackIcon Kind="FaceRecognition"
                                                         Foreground="#4f6ef7" Width="20" Height="20"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Biometría Facial" Foreground="White"
                                           FontSize="15" FontWeight="Bold"/>
                                <TextBlock Text="Registro de acceso por reconocimiento facial"
                                           Foreground="#505880" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- FOOTER -->
                    <Border DockPanel.Dock="Bottom" Background="#13161f"
                            BorderBrush="#1e2235" BorderThickness="0,1,0,0" Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="InformationOutline" Foreground="#353a58"
                                                         Width="14" Height="14"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Asegúrate de tener buena iluminación antes de capturar"
                                           Foreground="#353a58" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="btnCerrar" Content="Cerrar"
                                        Height="36" Padding="18,0" Margin="0,0,10,0"
                                        Cursor="Hand" Click="btnCerrar_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent"
                                                    BorderBrush="#1e2235" BorderThickness="1"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <TextBlock Text="Cerrar" Foreground="#8890b5"
                                                           FontSize="13" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="btnGuardarBiometria"
                                        Height="36" Padding="18,0"
                                        IsEnabled="False" Cursor="Hand"
                                        Click="btnGuardarBiometria_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#1a3d2b"
                                                    BorderBrush="#1a3d2b" BorderThickness="1"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ContentSave"
                                                                             Width="14" Height="14"
                                                                             Foreground="#4CAF50"
                                                                             VerticalAlignment="Center"
                                                                             Margin="0,0,6,0"/>
                                                    <TextBlock Text="Guardar Registro"
                                                               Foreground="#4CAF50"
                                                               FontSize="13"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- BODY -->
                    <Grid Margin="20,18,20,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- VISOR CÁMARA -->
                        <Border Grid.Column="0" CornerRadius="12"
                                BorderBrush="#1e2235" BorderThickness="1"
                                Background="#0d1020" ClipToBounds="True">
                            <Grid>
                                <Image x:Name="imgCamara" Stretch="UniformToFill"/>

                                <Ellipse Width="170" Height="210"
                                         Stroke="#4f6ef7" StrokeThickness="1.5"
                                         StrokeDashArray="5 3" Fill="Transparent"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <StackPanel x:Name="panelSinCamara"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="CameraOff" Width="50" Height="50"
                                                             Foreground="#1e2235"
                                                             HorizontalAlignment="Center"/>
                                    <TextBlock Text="Cámara apagada" Foreground="#353a58"
                                               FontSize="12" Margin="0,10,0,0"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <Border VerticalAlignment="Bottom" Background="#0d1020"
                                        BorderBrush="#1e2235" BorderThickness="0,1,0,0"
                                        Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon x:Name="iconDeteccion"
                                                                 Kind="CloseCircleOutline"
                                                                 Foreground="#E74C3C"
                                                                 Width="16" Height="16"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,8,0"/>
                                        <TextBlock x:Name="txtEstadoDeteccion"
                                                   Text="No se detecta rostro"
                                                   Foreground="#E74C3C"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- PANEL DERECHO -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Top">

                            <TextBlock Text="Seleccione el usuario" Foreground="#505880"
                                       FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
                            <Border Background="#1e2235" CornerRadius="8"
                                    BorderBrush="#252840" BorderThickness="1">
                                <TextBox x:Name="txtBuscarUsuario"
                                         Background="Transparent" Foreground="White"
                                         BorderThickness="0" CaretBrush="White"
                                         Height="36" VerticalContentAlignment="Center"
                                         Padding="10,0" FontSize="12"
                                         materialDesign:HintAssist.Hint="Nombre o correo..."
                                         materialDesign:HintAssist.Foreground="#505880"
                                         TextChanged="txtBuscarUsuario_TextChanged"/>
                            </Border>

                            <Border Background="#1a1d35" CornerRadius="8"
                                    BorderBrush="#1e2235" BorderThickness="1"
                                    Padding="10,9" Margin="0,8,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountCircleOutline"
                                                             Foreground="#4f6ef7"
                                                             Width="16" Height="16"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,8,0"/>
                                    <TextBlock x:Name="txtUsuarioSeleccionado"
                                               Text="Sin usuario seleccionado"
                                               Foreground="#353a58" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Activar Cámara -->
                            <Button x:Name="btnIniciarCamara"
                                    Height="36" Margin="0,0,0,8"
                                    HorizontalAlignment="Stretch" Cursor="Hand"
                                    Click="btnIniciarCamara_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent"
                                                BorderBrush="#4f6ef7" BorderThickness="1"
                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Camera"
                                                                         Width="14" Height="14"
                                                                         Foreground="#4f6ef7"
                                                                         VerticalAlignment="Center"
                                                                         Margin="0,0,6,0"/>
                                                <TextBlock Text="Activar Cámara"
                                                           Foreground="#4f6ef7"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Capturar Rostro -->
                            <Button x:Name="btnCapturar"
                                    Height="36" Margin="0,0,0,18"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="False" Cursor="Hand"
                                    Click="btnCapturar_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#1a1d35"
                                                BorderBrush="#1e2235" BorderThickness="1"
                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="CameraIris"
                                                                         Width="14" Height="14"
                                                                         Foreground="#4f6ef7"
                                                                         VerticalAlignment="Center"
                                                                         Margin="0,0,6,0"/>
                                                <TextBlock Text="Capturar Rostro"
                                                           Foreground="#4f6ef7"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Rectangle Height="1" Fill="#1e2235" Margin="0,0,0,18"/>

                            <!-- Última captura -->
                            <Border Background="#1a1d35" CornerRadius="10"
                                    BorderBrush="#1e2235" BorderThickness="1"
                                    Padding="12,12">
                                <StackPanel>
                                    <TextBlock Text="Última captura" Foreground="#505880"
                                               FontSize="10" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="46" Height="46" CornerRadius="23"
                                                Background="#0f1117" ClipToBounds="True"
                                                Margin="0,0,10,0"
                                                BorderBrush="#1e2235" BorderThickness="1">
                                            <Image x:Name="imgRostroCapturado" Stretch="UniformToFill"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="txtEstadoRegistro"
                                                       Text="Sin captura" Foreground="White"
                                                       FontSize="12" FontWeight="Medium"/>
                                            <TextBlock Text="Captura el rostro primero"
                                                       Foreground="#353a58" FontSize="10"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Eliminar -->
                            <Button x:Name="btnEliminarBiometria"
                                    Height="32" Margin="0,10,0,0"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="False" Cursor="Hand"
                                    Click="btnEliminarBiometria_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent"
                                                BorderBrush="#E74C3C" BorderThickness="1"
                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="TrashCanOutline"
                                                                         Width="13" Height="13"
                                                                         Foreground="#E74C3C"
                                                                         VerticalAlignment="Center"
                                                                         Margin="0,0,6,0"/>
                                                <TextBlock Text="Eliminar registro"
                                                           Foreground="#E74C3C"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>
                    </Grid>

                </DockPanel>
            </Border>
        </Border>
    </Grid>
</Window>