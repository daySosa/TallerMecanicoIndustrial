<Window x:Class="Contabilidad.GestiónEgresos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Contabilidad"
        Title="Gestión de Egresos" Height="640" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <DropShadowEffect x:Key="WinShadow" Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.70"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#505880"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="FieldBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Background" Value="#1e2235"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#252840"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="materialDesign:HintAssist.Foreground" Value="#505880"/>
        </Style>

        <Style x:Key="FieldBoxReadOnly" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Background" Value="#13161f"/>
            <Setter Property="Foreground" Value="#505880"/>
            <Setter Property="BorderBrush" Value="#1e2235"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="materialDesign:HintAssist.Foreground" Value="#505880"/>
        </Style>

        <Style x:Key="FieldComboBox" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
            <Setter Property="Background" Value="#1e2235"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#252840"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="materialDesign:HintAssist.Foreground" Value="#505880"/>
        </Style>
    </Window.Resources>

    <Border Effect="{StaticResource WinShadow}" CornerRadius="14">
        <Border CornerRadius="14" ClipToBounds="True" Background="#0f1117">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#13161f"
                        BorderBrush="#1e2235" BorderThickness="0,0,0,1">
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                            <Border x:Name="iconAgregar" Width="30" Height="30" CornerRadius="8"
                                    Background="#1a1d35" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="CashMinus" Foreground="#4f6ef7"
                                                         Width="16" Height="16"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <Border x:Name="iconEditar" Width="30" Height="30" CornerRadius="8"
                                    Background="#1a2b1a" Margin="0,0,12,0" Visibility="Collapsed">
                                <materialDesign:PackIcon Kind="PencilOutline" Foreground="#4CAF50"
                                                         Width="16" Height="16"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtTitulo" Text="Nuevo Gasto"
                                           Foreground="White" FontSize="14" FontWeight="Bold"/>
                                <TextBlock x:Name="txtSubtitulo" Text="Completa los datos para registrar"
                                           Foreground="#505880" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="2" x:Name="badgeModo"
                                Background="#1a1d35" CornerRadius="6" Padding="10,4" VerticalAlignment="Center">
                            <TextBlock x:Name="txtBadge" Text="NUEVO"
                                       Foreground="#4f6ef7" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="24,20,24,10">

                        <StackPanel x:Name="panelAgregar" Visibility="Visible">

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="TIPO DE GASTO" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="cmbTipoGasto"
                                          Style="{StaticResource FieldComboBox}"
                                          materialDesign:HintAssist.Hint="Selecciona un tipo">
                                    <ComboBoxItem Content="Gasto en Repuesto"/>
                                    <ComboBoxItem Content="Gasto Adicional"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="NOMBRE DEL GASTO" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txtNombreGasto"
                                         Style="{StaticResource FieldBox}"
                                         materialDesign:HintAssist.Hint="Ej: Compra de aceite, Pago de luz..."
                                         PreviewTextInput="txtNombreGasto_PreviewTextInput"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="PRECIO" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txtPrecio"
                                         Style="{StaticResource FieldBox}"
                                         Foreground="#E74C3C" FontWeight="SemiBold"
                                         materialDesign:HintAssist.Hint="L 0.00"
                                         LostFocus="txtPrecio_LostFocus"
                                         GotFocus="txtPrecio_GotFocus"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="OBSERVACIONES" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txtObservaciones"
                                         Style="{StaticResource FieldBox}"
                                         Height="100"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         VerticalContentAlignment="Top"
                                         materialDesign:HintAssist.Hint="Escribe los detalles del gasto..."/>
                            </StackPanel>

                            <Border x:Name="borderMensajeAgregar" Background="#1f0d0d" CornerRadius="8"
                                    Padding="12,10" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#E74C3C"
                                                             Width="15" Height="15"
                                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="txtMensaje" Foreground="#E74C3C"
                                               FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <StackPanel x:Name="panelEditar" Visibility="Collapsed">

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="TIPO DE GASTO" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="cmbTipoGasto_Edit"
                                              Style="{StaticResource FieldComboBox}">
                                        <ComboBoxItem Content="Gasto en Repuesto"/>
                                        <ComboBoxItem Content="Gasto Adicional"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="NOMBRE DEL GASTO" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtNombre_Edit"
                                             Style="{StaticResource FieldBox}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="PRECIO" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtPrecio_Edit"
                                             Style="{StaticResource FieldBox}"
                                             Foreground="#E74C3C" FontWeight="SemiBold"
                                             materialDesign:HintAssist.Hint="L 0.00"
                                             LostFocus="txtPrecio_Edit_LostFocus"
                                             GotFocus="txtPrecio_Edit_GotFocus"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="FECHA DE REGISTRO" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="txtFecha_Edit"
                                             Style="{StaticResource FieldBoxReadOnly}"
                                             materialDesign:HintAssist.Hint="dd/mm/aaaa"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="OBSERVACIONES" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txtObservaciones_Edit"
                                         Style="{StaticResource FieldBox}"
                                         Height="100"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         VerticalContentAlignment="Top"
                                         materialDesign:HintAssist.Hint="Escribe los detalles del gasto..."/>
                            </StackPanel>

                            <Border x:Name="borderBloqueado" Background="#2a1e00" CornerRadius="8"
                                    Padding="12,10" Margin="0,0,0,10" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="LockOutline" Foreground="#F0A500"
                                                             Width="15" Height="15"
                                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Este gasto ya no puede editarse (más de 1 día registrado)."
                                               Foreground="#F0A500" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="borderMensajeEditar" Background="#1f0d0d" CornerRadius="8"
                                    Padding="12,10" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#E74C3C"
                                                             Width="15" Height="15"
                                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="txtMensajeEditar" Foreground="#E74C3C"
                                               FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#13161f"
                        BorderBrush="#1e2235" BorderThickness="0,1,0,0"
                        Padding="24,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="btnCancelar"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="#8890b5" BorderBrush="#252840"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Height="42" Content="Cancelar"
                                Click="btnCancelar_Click"/>

                        <Button Grid.Column="2" x:Name="btnGuardar"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#4f6ef7" Foreground="White"
                                BorderBrush="#4f6ef7"
                                materialDesign:ElevationAssist.Elevation="Dp0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Height="42" FontSize="13" FontWeight="SemiBold"
                                Content="Guardar Gasto"
                                Click="btnGuardar_Click"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>