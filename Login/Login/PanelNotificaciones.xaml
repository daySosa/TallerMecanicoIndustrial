<Window x:Class="Contabilidad.PanelNotificaciones"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:Contabilidad"
        mc:Ignorable="d"
        Title="PanelNotificaciones" Height="500" Width="420"
        Background="#1F2128"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="BellOutline" Foreground="White"
                                         Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Notificaciones" Foreground="White"
                           FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
            <Border Grid.Column="1" x:Name="badgeContador"
                    Background="#FF4444" CornerRadius="10"
                    Padding="8,2" VerticalAlignment="Center"
                    Visibility="Collapsed">
                <TextBlock x:Name="txtContador" Text="0"
                           Foreground="White" FontSize="11" FontWeight="Bold"/>
            </Border>
        </Grid>

        <Rectangle Grid.Row="2" Height="1" Fill="#2A3A4D"/>

        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="panelNotificaciones"/>
        </ScrollViewer>

        <Button Grid.Row="6" x:Name="btnMarcarTodas"
                Style="{StaticResource MaterialDesignOutlinedButton}"
                Foreground="#3D7EFF" BorderBrush="#3D7EFF"
                materialDesign:ButtonAssist.CornerRadius="8"
                Height="40" FontSize="13"
                Click="btnMarcarTodas_Click">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="CheckAll" Width="18" Height="18"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Marcar todas como leídas" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

    </Grid>
</Window>