<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="Login.MainWindow"
        Title="Login" Height="680" Width="950" WindowStartupLocation="CenterScreen"
         Background="Transparent">

    <Border CornerRadius="16" ClipToBounds="True">
        <Grid>

            <!-- FONDO IMAGEN -->
            <Image Source="/fondo_login.png"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- TARJETA CENTRAL -->
            <Border Width="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="18"
                    Padding="36,30">
                <Border.Background>
                    <SolidColorBrush Color="#7A8BA0" Opacity="0.55"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.5"
                                      BlurRadius="40" ShadowDepth="0"/>
                </Border.Effect>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#ffffff" Opacity="0.15"/>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>

                <StackPanel>

                    <!-- Logo -->
                    <Image Source="/OSM_Logo_AR.png"
                           Height="90" Width="90"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="0,0,0,2"/>


                    <TextBlock Text="Opción de Inicio de Sesión"
                               Foreground="White" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Seleccione una opción para poder iniciar sesión"
                               Foreground="#dce3f0" FontSize="11"
                               TextWrapping="Wrap" TextAlignment="Center"
                               HorizontalAlignment="Center" Margin="0,0,0,22"/>

                    <TextBlock x:Name="txtErrorCorreo" Text=""
                               Foreground="#f44336" FontSize="11"
                               Margin="4,0,0,8" Visibility="Collapsed"/>

                    <TextBlock x:Name="txtErrorContrasena" Text=""
                               Foreground="#f44336" FontSize="11"
                               Margin="4,0,0,0" Visibility="Collapsed"/>

                    <!-- Botón Iniciar Sesión -->
                    <Button Height="44"
                            FontSize="14" FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="BtnLogin_Click"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            materialDesign:ElevationAssist.Elevation="Dp0"
                            Margin="0,0,0,16">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Código de Verificación" FontSize="14" FontWeight="SemiBold"/>
                    </Button>



                    <Button Height="44"
                        FontSize="14" FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="BtnLogin_Click"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        materialDesign:ElevationAssist.Elevation="Dp0">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Reconocimiento Facial" FontSize="14" FontWeight="SemiBold"/>
                    </Button>



                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>