<Window x:Class="Login.ReconocimientoFacial"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Reconocimiento Facial"
        Height="800" Width="700"
        Background="#1E1E2E"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="0,0,0,3">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Height="717">

            <TextBlock Text="Reconocimiento Facial"
                       FontSize="24" FontWeight="Bold"
                       Foreground="White" Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

            <Border Background="#2A2A3E"
                    BorderBrush="#6C63FF" BorderThickness="2"
                    CornerRadius="10" Padding="5">
                <Grid Width="500" Height="320">
                    <Image x:Name="imgCamara" Stretch="Uniform"/>
                    <TextBlock x:Name="txtSinCamara"
                               Text="Cámara no iniciada"
                               FontSize="16" Foreground="#888"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Background="#2A2A3E" CornerRadius="8"
                    Margin="0,10,0,0" Padding="10" Width="500">
                <TextBlock x:Name="txtEstado"
                           Text="Estado: En espera..."
                           Foreground="#AAA" FontSize="13"
                           HorizontalAlignment="Center"/>
            </Border>

            <TextBlock x:Name="txtNombreReconocido"
                       Text=""
                       Foreground="#27AE60" FontSize="18" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="btnModoRegistro"
                        Width="160" Height="36" Margin="8,0"
                        Background="#E67E22" Foreground="White"
                        FontSize="12" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"
                        IsEnabled="False"
                        Click="btnModoRegistro_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ClipboardEditOutline"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Modo Registro" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnModoLogin"
                        Width="160" Height="36" Margin="8,0"
                        Background="#2980B9" Foreground="White"
                        FontSize="12" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"
                        IsEnabled="False"
                        Click="btnModoLogin_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="LockOutline"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Modo Login" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="btnIniciarCamara"
                        Width="150" Height="40" Margin="8"
                        Background="#6C63FF" Foreground="White"
                        FontSize="13" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"
                        Click="btnIniciarCamara_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Camera"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Iniciar Cámara" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnDetenerCamara"
                        Width="120" Height="40" Margin="8"
                        Background="#E74C3C" Foreground="White"
                        FontSize="13" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"
                        IsEnabled="False"
                        Click="btnDetenerCamara_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Stop"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Detener" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnRegresar"
                        Width="120" Height="40" Margin="8"
                        Background="Transparent" Foreground="White"
                        FontSize="13" FontWeight="Bold"
                        BorderBrush="White" BorderThickness="1"
                        Cursor="Hand"
                        Click="btnRegresar_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft"
                                                 Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Regresar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <Border Background="#2A2A3E" CornerRadius="8"
                    Padding="15" Width="500">
                <StackPanel>
                    <TextBlock Text="Registrar nueva persona"
                               Foreground="White" FontSize="14" FontWeight="Bold"
                               Margin="0,0,0,10"/>
                    <TextBox x:Name="txtNombrePersona"
                             AutomationProperties.Name="Nombre de la persona"
                             Background="#1E1E2E" Foreground="White"
                             FontSize="13" BorderBrush="#6C63FF"
                             BorderThickness="1" Padding="8,6"
                             CaretBrush="White"
                             materialDesign:HintAssist.Hint="Nombre de la persona"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="btnCapturarFoto"
                                Width="150" Height="36" Margin="0,0,8,0"
                                Background="#27AE60" Foreground="White"
                                FontSize="12" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand"
                                IsEnabled="False"
                                Click="btnCapturarFoto_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Camera"
                                                         Width="14" Height="14"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Capturar foto" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnRegistrar"
                                Width="120" Height="36"
                                Background="#6C63FF" Foreground="White"
                                FontSize="12" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand"
                                Click="btnRegistrar_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave"
                                                         Width="14" Height="14"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Registrar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Window>