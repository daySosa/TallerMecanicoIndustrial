<Window x:Class="Login.ReconocimientoFacial"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Reconocimiento Facial"
        Height="760" Width="640"
        Background="#0f1117"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Opacity="0"
        Loaded="Window_Loaded"
        MouseDown="Window_Drag">

    <Window.Resources>
        <DropShadowEffect x:Key="WinShadow" Color="#000000" BlurRadius="48" ShadowDepth="0" Opacity="0.7"/>
        <DropShadowEffect x:Key="CamGlow" Color="#4f6ef7" BlurRadius="24" ShadowDepth="0" Opacity="0.25"/>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.28"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.62"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Foreground" Value="#7880a4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent"
                                BorderBrush="#2e3350" BorderThickness="1"
                                CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1c2035"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#3d4470"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Effect="{StaticResource WinShadow}">
        <Border.CacheMode>
            <BitmapCache/>
        </Border.CacheMode>
        <Border CornerRadius="16" ClipToBounds="True" Background="#0f1117">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#13161f"
                        BorderBrush="#1e2235" BorderThickness="0,0,0,1"
                        Padding="26,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="40" Height="40" CornerRadius="11" Margin="0,0,14,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#2a3580" Offset="0"/>
                                        <GradientStop Color="#1c2455" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <materialDesign:PackIcon Kind="FaceRecognition" Foreground="#7986f7"
                                                         Width="20" Height="20"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Verificación facial"
                                           Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Mira directamente a la cámara para identificarte"
                                           Foreground="#505880" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1" Width="30" Height="30"
                                BorderThickness="0" Background="Transparent"
                                Cursor="Hand" Click="btnCerrar_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="cb" CornerRadius="7"
                                            Background="Transparent" Width="30" Height="30">
                                        <materialDesign:PackIcon Kind="Close" Foreground="#404568"
                                                                 Width="14" Height="14"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="cb" Property="Background" Value="#1e2235"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="26,24,26,24">

                    <Border CornerRadius="13" Padding="2"
                            Effect="{StaticResource CamGlow}">
                        <Border.CacheMode>
                            <BitmapCache/>
                        </Border.CacheMode>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2a3580" Offset="0"/>
                                <GradientStop Color="#1a1e40" Offset="0.5"/>
                                <GradientStop Color="#2a3580" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border CornerRadius="11" Background="#0c0e1a" ClipToBounds="True">
                            <Grid Height="460">
                                <Image x:Name="imgCamara" Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>

                                <StackPanel x:Name="pnlSinCamara"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Border Width="60" Height="60" CornerRadius="30"
                                            HorizontalAlignment="Center" Margin="0,0,0,14">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1a1d30" Offset="0"/>
                                                <GradientStop Color="#111320" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <materialDesign:PackIcon Kind="CameraOff" Width="26" Height="26"
                                                                 Foreground="#252840"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock x:Name="txtSinCamara" Text="Cámara no iniciada"
                                               Foreground="#353a58" FontSize="13"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Presiona 'Iniciar cámara' para comenzar"
                                               Foreground="#252840" FontSize="11"
                                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>

                    <Border Background="#13161f" CornerRadius="9"
                            BorderBrush="#1e2235" BorderThickness="1"
                            Margin="0,12,0,0" Padding="16,11">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="elipseEstado" Width="8" Height="8"
                                     Fill="#2d3050" VerticalAlignment="Center" Margin="0,0,11,0"/>
                            <TextBlock x:Name="txtEstado" Grid.Column="1"
                                       Text="En espera..."
                                       Foreground="#505880" FontSize="12"
                                       VerticalAlignment="Center"/>

                            <Border x:Name="bdNombreReconocido" Grid.Column="2"
                                    Background="#0d1f15" BorderBrush="#1a4030"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="10,4" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                             Width="13" Height="13"
                                                             Foreground="#2ECC71"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,6,0"/>
                                    <TextBlock x:Name="txtNombreReconocido" Text=""
                                               Foreground="#2ECC71" FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                </StackPanel>

                <Border Grid.Row="2" Background="#0c0e17"
                        BorderBrush="#1a1e30" BorderThickness="0,1,0,0"
                        Padding="26,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="btnRegresar" Style="{StaticResource BtnGhost}"
                                HorizontalAlignment="Left"
                                Width="115" Padding="16,0"
                                Click="btnRegresar_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ArrowLeft" Width="14" Height="14"
                                                         VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="Regresar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="btnDetenerCamara" Style="{StaticResource Btn}"
                                    Width="115" Margin="0,0,9,0" Padding="16,0"
                                    Background="#7b1f1f" IsEnabled="False"
                                    Click="btnDetenerCamara_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Stop" Width="14" Height="14"
                                                             VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock Text="Detener" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="btnIniciarCamara" Style="{StaticResource Btn}"
                                    Width="148" Padding="16,0"
                                    Background="#4f6ef7"
                                    Click="btnIniciarCamara_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Camera" Width="14" Height="14"
                                                             VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock Text="Iniciar cámara" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>