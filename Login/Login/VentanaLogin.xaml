<Window x:Class="Login.VentanaLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Login" Height="850" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseDown="Window_Drag">

    <Border CornerRadius="16" ClipToBounds="True">
        <Grid>

            <Image Source="/Imagenes/fondo_login.png"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality"/>


            <Border Width="380"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="20"
                    Padding="40,36"
                    BorderThickness="1">
                <Border.Background>
                    <SolidColorBrush Color="#1E2A3A" Opacity="0.82"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.55"
                                      BlurRadius="50" ShadowDepth="0"/>
                </Border.Effect>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#ffffff" Opacity="0.12"/>
                </Border.BorderBrush>

                <StackPanel>

                    <Image Source="/Imagenes/OSM_Logo_AR.png"
                           Height="99" Width="100"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="0,0,0,6"/>

                    <TextBlock Text="Bienvenido"
                               Foreground="White" FontSize="23" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Ingresa tus credenciales para acceder"
                               Foreground="#94a3b8" FontSize="11.5"
                               TextWrapping="Wrap" TextAlignment="Center"
                               HorizontalAlignment="Center" Margin="0,0,0,28"/>

                    <TextBlock Text="Correo Electrónico"
                               Foreground="#cbd5e1" FontSize="11.5" FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <Border x:Name="borderCorreo"
                            Background="#ffffff" CornerRadius="10"
                            BorderBrush="Transparent" BorderThickness="1.5"
                            Height="44" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0"
                                                     Kind="EmailOutline" Foreground="#5D5FEF"
                                                     Width="18" Height="18"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                            <TextBox x:Name="txtCorreo"
                                     AutomationProperties.Name="Correo electrónico"
                                     Grid.Column="1"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#1e293b" FontSize="13"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,12,0" CaretBrush="#1e293b"
                                     GotFocus="TxtCorreo_GotFocus"
                                     LostFocus="TxtCorreo_LostFocus"
                                     TextChanged="txtCorreo_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox"
                                           BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Setter Property="materialDesign:HintAssist.Hint"
                                                Value="ejemplo@correo.com"/>
                                        <Setter Property="materialDesign:HintAssist.Foreground"
                                                Value="#9ca3af"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="txtErrorCorreo" Text=""
                               Foreground="#f87171" FontSize="11"
                               Margin="4,0,0,10" Visibility="Collapsed"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Contraseña"
                               Foreground="#cbd5e1" FontSize="11.5" FontWeight="SemiBold"
                               Margin="0,4,0,6"/>
                    <Border x:Name="borderContrasena"
                            Background="#ffffff" CornerRadius="10"
                            BorderBrush="Transparent" BorderThickness="1.5"
                            Height="44" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="42"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0"
                                                     Kind="LockOutline" Foreground="#5D5FEF"
                                                     Width="18" Height="18"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                            <PasswordBox x:Name="txtContrasena"
                                         AutomationProperties.Name="Contraseña"
                                         Grid.Column="1"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="#1e293b" FontSize="13"
                                         Padding="0" VerticalContentAlignment="Center"
                                         GotFocus="TxtContrasena_GotFocus"
                                         LostFocus="TxtContrasena_LostFocus"
                                         Visibility="Visible"/>
                            <TextBox x:Name="txtContrasenaVisible"
                                     AutomationProperties.Name="Contraseña visible"
                                     Grid.Column="1"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#1e293b" FontSize="13"
                                     Padding="0,0,10,0" VerticalContentAlignment="Center"
                                     CaretBrush="#1e293b" Visibility="Collapsed"
                                     GotFocus="TxtContrasena_GotFocus"
                                     LostFocus="TxtContrasena_LostFocus">
                                <TextBox.Style>
                                    <Style TargetType="TextBox"
                                           BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Setter Property="materialDesign:HintAssist.Hint"
                                                Value="••••••••"/>
                                        <Setter Property="materialDesign:HintAssist.Foreground"
                                                Value="#9ca3af"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <Button Grid.Column="2"
                                    x:Name="btnVerContrasena"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Width="38" Height="38"
                                    Click="BtnVerContrasena_Click">
                                <materialDesign:PackIcon x:Name="iconOjo"
                                                         Kind="EyeOutline" Foreground="#6b7280"
                                                         Width="18" Height="18"/>
                            </Button>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="txtErrorContrasena" Text=""
                               Foreground="#f87171" FontSize="11"
                               Margin="4,0,0,0" Visibility="Collapsed"
                               TextWrapping="Wrap"/>

                    <CheckBox x:Name="chkRecordar"
                              Content="Recordar sesión"
                              Foreground="#94a3b8" FontSize="11.5"
                              Margin="0,14,0,20">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox"
                                   BasedOn="{StaticResource MaterialDesignCheckBox}">
                                <Setter Property="materialDesign:CheckBoxAssist.CheckBoxSize"
                                        Value="16"/>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <Button Height="46"
                            FontSize="14" FontWeight="SemiBold"
                            Cursor="Hand" Click="BtnLogin_Click"
                            materialDesign:ButtonAssist.CornerRadius="10"
                            materialDesign:ElevationAssist.Elevation="Dp0">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="Background"  Value="#2563EB"/>
                                <Setter Property="Foreground"  Value="White"/>
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Login"
                                                     Width="18" Height="18"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,8,0"/>
                            <TextBlock Text="Iniciar Sesión"
                                       FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>