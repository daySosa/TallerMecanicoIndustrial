<Window x:Class="InterfazInventario.InventarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Inventario - Producto" Height="640" Width="900"
        TextElement.Foreground="White"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <DropShadowEffect x:Key="WinShadow" Color="#000000" BlurRadius="48" ShadowDepth="0" Opacity="0.75"/>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="#1e2235"/>
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="CaretBrush"               Value="White"/>
            <Setter Property="BorderBrush"              Value="#252840"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="38"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"     Value="#4f6ef7"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter TargetName="border" Property="Background"  Value="#171a26"/>
                                <Setter Property="Foreground" Value="#8890b5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBoxNoBorderLeft" TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,1,1,1"
                                CornerRadius="0,6,6,0">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4f6ef7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBoxCentered" TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="FontSize"      Value="15"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="IsReadOnly"    Value="True"/>
            <Setter Property="Focusable"     Value="False"/>
            <Setter Property="IsUndoEnabled" Value="False"/>
            <Setter Property="Cursor"        Value="Arrow"/>
        </Style>

        <Style x:Key="CounterButton" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background"  Value="#1e2235"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#252840"/>
            <Setter Property="Width"       Value="38"/>
            <Setter Property="Height"      Value="38"/>
            <Setter Property="Padding"     Value="0"/>
            <Setter Property="MinWidth"    Value="38"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="14" Effect="{StaticResource WinShadow}"
            Opacity="0" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="0.92" ScaleY="0.92"/>
        </Border.RenderTransform>

        <Border CornerRadius="14" ClipToBounds="True">
            <Grid Background="#0f1117">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#13161f" Height="68"
                        BorderBrush="#1e2235" BorderThickness="0,0,0,1">
                    <Grid Margin="24,0,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                            <Border Background="#1e2235" CornerRadius="8"
                                    Width="36" Height="36" Margin="0,0,14,0">
                                <materialDesign:PackIcon Kind="PackageVariant" Foreground="#4f6ef7"
                                                         Width="20" Height="20"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Producto" Foreground="White"
                                           FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Agrega o edita un repuesto del inventario"
                                           Foreground="#505880" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1" Width="32" Height="32"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Foreground="#505880"
                                Click="BtnCancelar_Click">
                            <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="24,20,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#13161f"
                            CornerRadius="12" BorderBrush="#1e2235" BorderThickness="1"
                            Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Background="#1e2235" CornerRadius="8"
                                            Width="34" Height="34" Margin="0,0,12,0">
                                        <materialDesign:PackIcon Kind="PackageVariant" Foreground="#4f6ef7"
                                                                 Width="18" Height="18"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Datos del Producto" Foreground="White"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Información de identificación"
                                                   Foreground="#505880" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>

                                <Rectangle Height="1" Fill="#1e2235" Margin="0,0,0,16"/>

                                <TextBlock Text="NOMBRE" Foreground="#505880"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtNombre" Style="{StaticResource DarkTextBox}" Margin="0,0,0,14"/>

                                <TextBlock Text="CATEGORÍA" Foreground="#505880"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <Border Background="#1e2235" CornerRadius="6"
                                        BorderBrush="#252840" BorderThickness="1"
                                        Height="38" Margin="0,0,0,14">
                                    <ComboBox x:Name="cmbCategoria"
                                              Background="Transparent" Foreground="White"
                                              BorderThickness="0" FontSize="13"
                                              Padding="10,0,10,0" VerticalContentAlignment="Center"
                                              Style="{StaticResource MaterialDesignComboBox}">
                                        <ComboBoxItem Content="Repuestos"/>
                                        <ComboBoxItem Content="Aceites y Lubricantes"/>
                                        <ComboBoxItem Content="Frenos"/>
                                        <ComboBoxItem Content="Filtros"/>
                                        <ComboBoxItem Content="Eléctrico"/>
                                        <ComboBoxItem Content="Suspensión"/>
                                        <ComboBoxItem Content="Motor"/>
                                        <ComboBoxItem Content="Carrocería"/>
                                        <ComboBoxItem Content="Otros"/>
                                    </ComboBox>
                                </Border>

                                <TextBlock Text="MARCA" Foreground="#505880"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtMarca" Style="{StaticResource DarkTextBox}" Margin="0,0,0,14"/>

                                <TextBlock Text="MODELO (opcional)" Foreground="#505880"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtModelo" Style="{StaticResource DarkTextBox}" Margin="0,0,0,14"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="2" Background="#13161f"
                            CornerRadius="12" BorderBrush="#1e2235" BorderThickness="1"
                            Padding="20">

                        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Background="#1e2235" CornerRadius="8"
                                            Width="34" Height="34" Margin="0,0,12,0">
                                        <materialDesign:PackIcon Kind="TagOutline" Foreground="#4f6ef7"
                                                                 Width="18" Height="18"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Detalles y Precio" Foreground="White"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Precio y cantidad del producto"
                                                   Foreground="#505880" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>

                                <Rectangle Height="1" Fill="#1e2235" Margin="0,0,0,16"/>

                                <TextBlock Text="PRECIO" Foreground="#505880"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#1e2235"
                                            BorderBrush="#252840" BorderThickness="1,1,0,1"
                                            CornerRadius="6,0,0,6" Padding="12,0" Height="38">
                                        <TextBlock Text="L" Foreground="#4f6ef7" FontSize="15"
                                                   FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBox x:Name="txtPrecio" Grid.Column="1"
                                             Style="{StaticResource DarkTextBoxNoBorderLeft}"/>
                                </Grid>

                                <TextBlock Text="STOCK ACTUAL" Foreground="#505880"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <Border Background="#0f1117" CornerRadius="6"
                                        BorderBrush="#1e2235" BorderThickness="1"
                                        Height="38" Margin="0,0,0,14" Padding="10,0">
                                    <TextBox x:Name="txtStockActual"
                                             Background="Transparent" BorderThickness="0"
                                             IsReadOnly="True" Foreground="#505880"
                                             VerticalContentAlignment="Center" FontSize="13"/>
                                </Border>

                                <TextBlock Text="CANTIDAD A AGREGAR" Foreground="#505880"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <Grid HorizontalAlignment="Stretch" Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="42"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" x:Name="btnRestar"
                                            Style="{StaticResource CounterButton}"
                                            Click="BtnRestar_Click"
                                            materialDesign:ButtonAssist.CornerRadius="6">
                                        <materialDesign:PackIcon Kind="Minus" Width="16" Height="16"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                    </Button>

                                    <TextBox x:Name="txtCantidad" Grid.Column="1"
                                             Margin="8,0" Text="0"
                                             Style="{StaticResource DarkTextBoxCentered}"/>

                                    <Button Grid.Column="2" x:Name="btnSumar"
                                            Style="{StaticResource CounterButton}"
                                            Click="BtnSumar_Click"
                                            materialDesign:ButtonAssist.CornerRadius="6">
                                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>

                                <TextBlock Text="CANTIDAD MÍNIMA EN STOCK" Foreground="#505880"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtCantidadMinima"
                                         Style="{StaticResource DarkTextBox}"
                                         Margin="0,0,0,2"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Background="#13161f" Margin="24,16,24,24"
                        CornerRadius="12" BorderBrush="#1e2235" BorderThickness="1"
                        Padding="20,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="#505880"
                                                     Width="15" Height="15"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Verifica los datos antes de guardar"
                                       Foreground="#505880" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="btnCancelar" Content="Cancelar"
                                    Height="36" Padding="20,0" Margin="0,0,10,0"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    BorderBrush="#1e2235" Foreground="#8890b5"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Click="BtnCancelar_Click"/>

                            <Button x:Name="btnActualizar" Content="Actualizar"
                                    Height="36" Padding="20,0" Margin="0,0,10,0"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    BorderBrush="#4f6ef7" Foreground="#4f6ef7"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Visibility="Visible"
                                    Click="BtnActualizar_Click"/>

                            <Button x:Name="btnAgregar"
                                    Height="36" Padding="20,0"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    materialDesign:ElevationAssist.Elevation="Dp0"
                                    Click="BtnAgregar_Click">
                                <Button.Style>
                                    <Style TargetType="Button"
                                           BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Background"  Value="#4f6ef7"/>
                                        <Setter Property="Foreground"  Value="White"/>
                                        <Setter Property="BorderBrush" Value="#4f6ef7"/>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"
                                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Agregar Producto" VerticalAlignment="Center" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>