<Window x:Class="Vehículos.VehiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Vehículos"
        Title="Vehículo" Height="660" Width="900"
        TextElement.Foreground="White"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown">
    
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.25"/>
                    <ThicknessAnimation Storyboard.TargetName="RootBorder"
                                        Storyboard.TargetProperty="Margin"
                                        From="0,18,0,0" To="0"
                                        Duration="0:0:0.28">
                        <ThicknessAnimation.EasingFunction>
                            <QuadraticEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>

        <DropShadowEffect x:Key="WinShadow" Color="#000000" BlurRadius="48" ShadowDepth="0" Opacity="0.75"/>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="#1e2235"/>
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="CaretBrush"               Value="White"/>
            <Setter Property="BorderBrush"              Value="#252840"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="38"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border"
                                                            Storyboard.TargetProperty="BorderBrush.Color"
                                                            To="#4f6ef7" Duration="0:0:0.15"/>
                                            <ThicknessAnimation Storyboard.TargetName="border"
                                                                Storyboard.TargetProperty="BorderThickness"
                                                                To="2" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border"
                                                            Storyboard.TargetProperty="BorderBrush.Color"
                                                            To="#252840" Duration="0:0:0.15"/>
                                            <ThicknessAnimation Storyboard.TargetName="border"
                                                                Storyboard.TargetProperty="BorderThickness"
                                                                To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBoxMultiline" TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}">
            <Setter Property="Height"                   Value="110"/>
            <Setter Property="TextWrapping"             Value="Wrap"/>
            <Setter Property="AcceptsReturn"            Value="True"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding"                  Value="10,8"/>
        </Style>

        <Style x:Key="AutoCompleteItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding"    Value="12,9"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="itemBorder"
                                Background="Transparent"
                                BorderBrush="#1e2235"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="itemBorder"
                                                            Storyboard.TargetProperty="Background.Color"
                                                            To="#1e2235" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="itemBorder"
                                                            Storyboard.TargetProperty="Background.Color"
                                                            To="Transparent" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#252840"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AutoCompletePopupBorder" TargetType="Border">
            <Setter Property="Opacity" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsVisible, RelativeSource={RelativeSource Self}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AnimatedToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Width"  Value="50"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="switchBg" Background="#4CAF50"
                                    CornerRadius="14" Width="50" Height="28"/>
                            <Border x:Name="switchThumb" Background="White"
                                    CornerRadius="11" Width="22" Height="22"
                                    HorizontalAlignment="Left" Margin="25,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.2"
                                                      BlurRadius="4" ShadowDepth="1"/>
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="thumbTransform" X="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="switchBg"
                                                            Storyboard.TargetProperty="Background.Color"
                                                            To="#252840" Duration="0:0:0.18"/>
                                            <DoubleAnimation Storyboard.TargetName="thumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="-22" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="switchBg"
                                                            Storyboard.TargetProperty="Background.Color"
                                                            To="#4CAF50" Duration="0:0:0.18"/>
                                            <DoubleAnimation Storyboard.TargetName="thumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="14" Effect="{StaticResource WinShadow}">
        <Border CornerRadius="14" ClipToBounds="True">
            <Grid Background="#0f1117">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#13161f" Height="68"
                        BorderBrush="#1e2235" BorderThickness="0,0,0,1">
                    <Grid Margin="24,0,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#1e2235" CornerRadius="8"
                                    Width="36" Height="36" Margin="0,0,14,0">
                                <materialDesign:PackIcon Kind="CarSportsUtilityVehicle" Foreground="#4f6ef7"
                                                          Width="20" Height="20"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Vehículo" Foreground="White"
                                           FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Registra o edita un vehículo"
                                           Foreground="#505880" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1" Width="32" Height="32"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Foreground="#505880"
                                Click="BtnCancelar_Click">
                            <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="24,20,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#13161f"
                            CornerRadius="12" BorderBrush="#1e2235" BorderThickness="1"
                            Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Background="#1e2235" CornerRadius="8"
                                            Width="34" Height="34" Margin="0,0,12,0">
                                        <materialDesign:PackIcon Kind="CarSportsUtilityVehicle" Foreground="#4f6ef7"
                                                                  Width="18" Height="18"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Datos del Vehículo" Foreground="White"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Información de identificación"
                                                   Foreground="#505880" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>

                                <Rectangle Height="1" Fill="#1e2235" Margin="0,0,0,16"/>

                                <TextBlock Text="PLACA" Foreground="#505880"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtPlaca" Style="{StaticResource DarkTextBox}"
                                         Margin="0,0,0,4" MaxLength="7"
                                         PreviewTextInput="txtPlaca_PreviewTextInput"
                                         TextChanged="txtPlaca_TextChanged"/>
                                <TextBlock x:Name="txtContadorPlaca" Foreground="#505880"
                                           FontSize="10" HorizontalAlignment="Right"
                                           Margin="0,0,0,14"/>

                                <TextBlock Text="MARCA" Foreground="#505880"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtMarca" Style="{StaticResource DarkTextBox}"
                                         Margin="0,0,0,14"/>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="MODELO" Foreground="#505880"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <TextBox x:Name="txtModelo" Style="{StaticResource DarkTextBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="AÑO" Foreground="#505880"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <TextBox x:Name="txtAnio" Style="{StaticResource DarkTextBox}"
                                                 PreviewTextInput="txtAnio_PreviewTextInput"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="TIPO DE VEHÍCULO" Foreground="#505880"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <Border Background="#1e2235" CornerRadius="6"
                                        BorderBrush="#252840" BorderThickness="1"
                                        Height="38">
                                    <ComboBox x:Name="cmbTipo"
                                              Background="Transparent" Foreground="White"
                                              BorderThickness="0" FontSize="13"
                                              Padding="10,0,10,0" VerticalContentAlignment="Center"
                                              Style="{StaticResource MaterialDesignComboBox}">
                                        <ComboBoxItem Content="Turismo"/>
                                        <ComboBoxItem Content="MotoTaxi"/>
                                        <ComboBoxItem Content="Pickup"/>
                                        <ComboBoxItem Content="Camioneta"/>
                                        <ComboBoxItem Content="Motocicleta"/>
                                        <ComboBoxItem Content="Camiones"/>
                                    </ComboBox>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="2" Background="#13161f"
                            CornerRadius="12" BorderBrush="#1e2235" BorderThickness="1"
                            Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Background="#1e2235" CornerRadius="8"
                                            Width="34" Height="34" Margin="0,0,12,0">
                                        <materialDesign:PackIcon Kind="NoteTextOutline" Foreground="#4f6ef7"
                                                                  Width="18" Height="18"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Detalles Adicionales" Foreground="White"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Observaciones y propietario"
                                                   Foreground="#505880" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>

                                <Rectangle Height="1" Fill="#1e2235" Margin="0,0,0,16"/>

                                <TextBlock Text="DNI DEL CLIENTE" Foreground="#505880"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <TextBox x:Name="txtClienteDNI"
                                                 Style="{StaticResource DarkTextBox}"
                                                 MaxLength="13"
                                                 TextChanged="txtClienteDNI_TextChanged"
                                                 PreviewTextInput="txtClienteDNI_PreviewTextInput"
                                                 LostFocus="txtClienteDNI_LostFocus"
                                                 PreviewKeyDown="txtClienteDNI_PreviewKeyDown"/>

                                        <Popup x:Name="popupAutoComplete"
                                               PlacementTarget="{Binding ElementName=txtClienteDNI}"
                                               Placement="Bottom"
                                               StaysOpen="False"
                                               AllowsTransparency="True"
                                               Focusable="False"
                                               PopupAnimation="Fade"
                                               Width="{Binding ActualWidth, ElementName=txtClienteDNI}">
                                            <Border Background="#13161f"
                                                    BorderBrush="#4f6ef7"
                                                    BorderThickness="1"
                                                    CornerRadius="0,0,8,8"
                                                    Style="{StaticResource AutoCompletePopupBorder}">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#000000" BlurRadius="16"
                                                                      ShadowDepth="4" Opacity="0.5"/>
                                                </Border.Effect>
                                                <ListBox x:Name="listAutoComplete"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         MaxHeight="180"
                                                         ItemContainerStyle="{StaticResource AutoCompleteItem}"
                                                         MouseLeftButtonUp="listAutoComplete_MouseLeftButtonUp"
                                                         PreviewKeyDown="listAutoComplete_PreviewKeyDown">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding DNI}"
                                                                           Foreground="#4f6ef7"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding NombreCompleto}"
                                                                           Foreground="White"
                                                                           FontSize="13"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                        </Popup>
                                    </Grid>

                                    <Button Grid.Column="2" Content="Buscar"
                                            x:Name="btnBuscarCliente"
                                            Height="38" Padding="14,0"
                                            materialDesign:ButtonAssist.CornerRadius="8"
                                            materialDesign:ElevationAssist.Elevation="Dp0"
                                            Click="BtnVerificarCliente_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                <Setter Property="Background" Value="#4f6ef7"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#4f6ef7"/>
                                                <Setter Property="FontSize" Value="12"/>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>

                                <Border x:Name="borderClienteInfo"
                                        Background="#0f1f15" CornerRadius="8"
                                        BorderBrush="#1a3d2b" BorderThickness="1"
                                        Padding="12,10" Margin="0,0,0,14"
                                        Visibility="Collapsed">
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Border.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0" To="1" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon x:Name="iconClienteEstado"
                                                                  Kind="AccountCheck"
                                                                  Foreground="#4CAF50"
                                                                  Width="18" Height="18"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="txtClienteNombre" Foreground="White"
                                                       FontSize="13" FontWeight="Medium"/>
                                            <TextBlock x:Name="txtClienteEstado" Foreground="#4CAF50"
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="OBSERVACIONES" Foreground="#505880"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtObservaciones"
                                         Style="{StaticResource DarkTextBoxMultiline}"
                                         Margin="0,0,0,14"/>

                                <Border Background="#1e2235" CornerRadius="10"
                                        BorderBrush="#252840" BorderThickness="1"
                                        Padding="14,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                                          x:Name="iconEstado"
                                                                          Foreground="#4CAF50"
                                                                          Width="15" Height="15"
                                                                          VerticalAlignment="Center"
                                                                          Margin="0,0,6,0"/>
                                                <TextBlock Text="Estado del Vehículo"
                                                           Foreground="White" FontSize="12" FontWeight="Medium"/>
                                            </StackPanel>
                                            <TextBlock x:Name="txtEstadoLabel"
                                                       Text="El vehículo está activo"
                                                       Foreground="#4CAF50" FontSize="11"/>
                                        </StackPanel>

                                        <ToggleButton x:Name="toggleActivo"
                                                      Grid.Column="1" IsChecked="True"
                                                      Style="{StaticResource AnimatedToggleSwitch}"
                                                      Checked="ToggleActivo_Checked"
                                                      Unchecked="ToggleActivo_Unchecked"
                                                      VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Background="#13161f" Margin="24,16,24,24"
                        CornerRadius="12" BorderBrush="#1e2235" BorderThickness="1"
                        Padding="20,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="#505880"
                                                      Width="15" Height="15"
                                                      VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Verifica el DNI del cliente antes de guardar"
                                       Foreground="#505880" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Cancelar"
                                    Height="36" Padding="20,0" Margin="0,0,10,0"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    BorderBrush="#1e2235" Foreground="#8890b5"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Click="BtnCancelar_Click"/>

                            <Button x:Name="btnActualizar" Content="Actualizar"
                                    Height="36" Padding="20,0" Margin="0,0,10,0"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    BorderBrush="#4f6ef7" Foreground="#4f6ef7"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Visibility="Visible"
                                    Click="BtnActualizar_Click"/>

                            <Button x:Name="btnGuardar"
                                    Height="36" Padding="20,0"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    materialDesign:ElevationAssist.Elevation="Dp0"
                                    Click="BtnGuardar_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Background"  Value="#4f6ef7"/>
                                        <Setter Property="Foreground"  Value="White"/>
                                        <Setter Property="BorderBrush" Value="#4f6ef7"/>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16"
                                                              VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Guardar Vehículo" VerticalAlignment="Center" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>