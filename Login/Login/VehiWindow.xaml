<Window x:Class="Vehículos.VehiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Vehículos"
        Title="MenúPrincipalVehiculos" Height="750" Width="950"
        TextElement.Foreground="#242731" WindowStyle="ThreeDBorderWindow"
        Background="#1F2128" WindowStartupLocation="CenterScreen" BorderBrush="#242731">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="30,24,30,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Grid.RowSpan="2">
                <materialDesign:Card Background="#252836" UniformCornerRadius="12"
                                     Padding="22" Margin="0,0,0,16"
                                     materialDesign:ElevationAssist.Elevation="Dp3">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#2e3250" CornerRadius="8"
                                    Width="36" Height="36" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="CarSportsUtilityVehicle"
                                                         Foreground="#4f6ef7" Width="20" Height="20"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Datos del Vehículo" Foreground="White" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Información de identificación" Foreground="#6c7293" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Placa" Foreground="#6c7293" FontSize="11" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtPlaca"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Background="#1e2130" Foreground="White"
                                 BorderBrush="#3a3f5c" CaretBrush="White"
                                 Height="40" VerticalContentAlignment="Center"
                                 Padding="10,0" Margin="0,0,0,14"
                                 TextChanged="txtPlaca_TextChanged"/>

                        <TextBlock Text="Marca" Foreground="#6c7293" FontSize="11" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtMarca"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Background="#1e2130" Foreground="White"
                                 BorderBrush="#3a3f5c" CaretBrush="White"
                                 Height="40" VerticalContentAlignment="Center"
                                 Padding="10,0" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Modelo" Foreground="#6c7293" FontSize="11" FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtModelo"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Background="#1e2130" Foreground="White"
                                         BorderBrush="#3a3f5c" CaretBrush="White"
                                         Height="40" VerticalContentAlignment="Center"
                                         Padding="10,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Año" Foreground="#6c7293" FontSize="11" FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtAnio"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Background="#1e2130" Foreground="White"
                                         BorderBrush="#3a3f5c" CaretBrush="White"
                                         Height="40" VerticalContentAlignment="Center"
                                         Padding="10,0"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Tipo de Vehículo" Foreground="#6c7293" FontSize="11" FontWeight="Medium" Margin="0,0,0,4"/>
                        <ComboBox x:Name="cmbTipo"
                                  Height="40" Margin="0,0,0,0"
                                  Background="#1e2130" Foreground="White"
                                  BorderBrush="#3a3f5c" BorderThickness="1"
                                  Padding="10,0,10,0"
                                  VerticalContentAlignment="Center">
                            <ComboBox.Resources>
                                <Style TargetType="Separator">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </ComboBox.Resources>
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Background" Value="#1e2130"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3a3f5c"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#2e3250"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                            <ComboBoxItem Content="Turismo"/>
                            <ComboBoxItem Content="MotoTaxi"/>
                            <ComboBoxItem Content="Pickup"/>
                            <ComboBoxItem Content="Camioneta"/>
                            <ComboBoxItem Content="Motocicleta"/>
                            <ComboBoxItem Content="Camiones"/>
                        </ComboBox>

                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>

            <StackPanel Grid.Column="2" Grid.RowSpan="2">
                <materialDesign:Card Background="#252836" UniformCornerRadius="12"
                                     Padding="22" Margin="0,0,0,16"
                                     materialDesign:ElevationAssist.Elevation="Dp3">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#2e3250" CornerRadius="8"
                                    Width="36" Height="36" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="NoteTextOutline"
                                                         Foreground="#4f6ef7" Width="20" Height="20"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Detalles Adicionales" Foreground="White" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="Observaciones y propietario" Foreground="#6c7293" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="DNI del Cliente (13 dígitos sin guiones)"
                                   Foreground="#6c7293" FontSize="11" FontWeight="Medium" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtClienteDNI"
                                     Grid.Column="0"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Background="#1e2130" Foreground="White"
                                     BorderBrush="#3a3f5c" CaretBrush="White"
                                     Height="40" VerticalContentAlignment="Center"
                                     Padding="10,0" MaxLength="13"
                                     TextChanged="txtClienteDNI_TextChanged"
                                     PreviewTextInput="txtClienteDNI_PreviewTextInput"/>
                            <Button Grid.Column="2"
                                    x:Name="btnBuscarCliente"
                                    Content="Buscar"
                                    Height="40" Padding="14,0"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    materialDesign:ElevationAssist.Elevation="Dp0"
                                    Click="BtnVerificarCliente_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Background" Value="#4f6ef7"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#4f6ef7"/>
                                        <Setter Property="FontSize" Value="12"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <TextBlock Text="Formato: 0801-1990-12345 → escribe 0801199012345"
                                   Foreground="#4A5568" FontSize="10" Margin="0,0,0,10"
                                   FontStyle="Italic"/>

                        <Border x:Name="borderClienteInfo"
                                Background="#1e2130" CornerRadius="8" Padding="12,10"
                                Visibility="Collapsed" Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon x:Name="iconClienteEstado"
                                                         Kind="AccountCheck"
                                                         Foreground="#4CAF50"
                                                         Width="18" Height="18"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,8,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="txtClienteNombre" Foreground="White" FontSize="13" FontWeight="Medium"/>
                                    <TextBlock x:Name="txtClienteEstado" Foreground="#4CAF50" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Observaciones" Foreground="#6c7293" FontSize="11" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtObservaciones"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Background="#1e2130" Foreground="White"
                                 BorderBrush="#3a3f5c" CaretBrush="White"
                                 Height="120" TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 Padding="10,8"
                                 Margin="0,0,0,16"/>

                        <Border Background="#1e2130" CornerRadius="10" Padding="16,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                                 x:Name="iconEstado"
                                                                 Foreground="#4CAF50"
                                                                 Width="16" Height="16"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,6,0"/>
                                        <TextBlock Text="Estado del Vehículo"
                                                   Foreground="White" FontSize="13" FontWeight="Medium"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtEstadoLabel"
                                               Text="El vehículo está activo"
                                               Foreground="#4CAF50" FontSize="11"/>
                                </StackPanel>
                                <ToggleButton x:Name="toggleActivo"
                                              Grid.Column="1" IsChecked="True"
                                              Checked="ToggleActivo_Checked"
                                              Unchecked="ToggleActivo_Unchecked"
                                              VerticalAlignment="Center">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Width" Value="54"/>
                                            <Setter Property="Height" Value="30"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Grid>
                                                            <Border x:Name="switchBg" Background="#4CAF50"
                                                                    CornerRadius="15" Width="54" Height="30"/>
                                                            <Border x:Name="switchThumb" Background="White"
                                                                    CornerRadius="12" Width="24" Height="24"
                                                                    HorizontalAlignment="Right" Margin="0,0,3,0">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="Black" Opacity="0.2"
                                                                                      BlurRadius="4" ShadowDepth="1"/>
                                                                </Border.Effect>
                                                            </Border>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="False">
                                                                <Setter TargetName="switchBg" Property="Background" Value="#3a3f5c"/>
                                                                <Setter TargetName="switchThumb" Property="HorizontalAlignment" Value="Left"/>
                                                                <Setter TargetName="switchThumb" Property="Margin" Value="3,0,0,0"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                            </Grid>
                        </Border>

                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>

            <materialDesign:Card Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1"
                     Background="#252836" UniformCornerRadius="10"
                     Padding="14,10"
                     materialDesign:ElevationAssist.Elevation="Dp3" Margin="5,270,-5,-243">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                   Foreground="#6c7293" FontSize="11">
            <Run Text="⚠ "/>
            <Run Text="Verifica el DNI del cliente antes de guardar"/>
                    </TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Cancelar"
                    Height="32" Padding="16,0" Margin="0,0,8,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    BorderBrush="#6c7293" Foreground="#6c7293"
                    materialDesign:ButtonAssist.CornerRadius="6"
                    Click="BtnCancelar_Click"/>
                        <Button Content="Actualizar"
                    Height="32" Padding="16,0" Margin="0,0,8,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    BorderBrush="#4f6ef7" Foreground="#4f6ef7"
                    materialDesign:ButtonAssist.CornerRadius="6"
                    Click="BtnActualizar_Click"/>
                        <Button x:Name="btnGuardar"
                    Height="32" Padding="16,0"
                    materialDesign:ButtonAssist.CornerRadius="6"
                    materialDesign:ElevationAssist.Elevation="Dp0"
                    Click="BtnGuardar_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                    <Setter Property="Background" Value="#4f6ef7"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#4f6ef7"/>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" Width="14" Height="14"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Guardar Vehículo" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

        </Grid>
    </ScrollViewer>
</Window>