<Window x:Class="InterfazClientes.MenúPrincipalClientes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:InterfazClientes"
        Title="MenúPrincipalClientes" Height="850" Width="1200"
        TextElement.Foreground="#242731" WindowStyle="ThreeDBorderWindow"
        Background="#1F2128" WindowStartupLocation="CenterScreen" BorderBrush="#242731">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="20*"/>
        </Grid.ColumnDefinitions>

        <materialDesign:ColorZone Grid.Column="0" CornerRadius="15 0 0 15"
                                  Background="#242731" VerticalAlignment="Stretch">
            <StackPanel Margin="15,0,15,0">
                <WrapPanel Margin="0,10,5,60" HorizontalAlignment="Center" Height="184" Width="185">
                    <Image RenderOptions.BitmapScalingMode="HighQuality"
                           Source="c:\users\dsosa\source\repos\annygiron\taller_mecanico\taller_mecanico\vehículos\osm_logo.png"
                           Height="184"/>
                </WrapPanel>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,-40,0,15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="Home" VerticalAlignment="Center"
                                                 Foreground="White" Height="25" Width="38"/>
                        <TextBlock Foreground="White" FontSize="15">Pantalla Principal</TextBlock>
                    </WrapPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="PackageVariant" VerticalAlignment="Center"
                                                 Foreground="White" Height="26" Width="38"/>
                        <TextBlock Foreground="White" FontSize="15">Inventario</TextBlock>
                    </WrapPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="CarSportsUtilityVehicle" VerticalAlignment="Center"
                                                 Foreground="White" Width="39" Height="25"/>
                        <TextBlock Foreground="White" FontSize="15">Vehículos</TextBlock>
                    </WrapPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="People" VerticalAlignment="Center"
                                                 Foreground="White" Height="25" Width="39"/>
                        <TextBlock Foreground="White" FontSize="15" FontWeight="SemiBold">Clientes</TextBlock>
                    </WrapPanel>
                </Button>
                <Expander Background="#242731" Foreground="White" FontFamily="Segoe UI" FontSize="13"
                          BorderThickness="0" Margin="0,0,0,15">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Width="250">
                            <materialDesign:PackIcon Kind="BookOpenPageVariant" VerticalAlignment="Center"
                                                     Margin="5,0,10,0" Foreground="White" Height="18" Width="35"/>
                            <TextBlock Foreground="White" FontSize="15">Contabilidad</TextBlock>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Background="#242731">
                        <Button Background="#242731" BorderThickness="0" Foreground="White"
                                FontSize="15" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Width="250">
                                <materialDesign:PackIcon Kind="CurrencyUsd" VerticalAlignment="Center"
                                                         Margin="15,0,20,0" Foreground="White"/>
                                <TextBlock Text="Egresos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Background="#242731" BorderThickness="0" Foreground="White"
                                FontSize="15" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Width="250">
                                <materialDesign:PackIcon Kind="CreditCard" VerticalAlignment="Center"
                                                         Margin="15,0,20,0" Foreground="White"/>
                                <TextBlock Text="Ingresos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Expander>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White" Margin="0,0,0,15">
                    <WrapPanel Width="250">
                        <materialDesign:PackIcon Kind="OrderBoolAscending" VerticalAlignment="Center"
                                                 Foreground="White" Height="25" Width="39"/>
                        <TextBlock Foreground="White" FontSize="15">Órdenes</TextBlock>
                    </WrapPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#242731"
                        materialDesign:ButtonAssist.CornerRadius="6" Width="Auto"
                        Height="35" materialDesign:RippleAssist.Feedback="White"
                        VerticalAlignment="Bottom" Margin="0,70,0,15">
                    <WrapPanel Width="175">
                        <materialDesign:PackIcon Kind="LogoutVariant" VerticalAlignment="Center"
                                                 Foreground="White" Width="39" Height="21"/>
                        <TextBlock Foreground="White" FontSize="15">Cerrar Sesión</TextBlock>
                    </WrapPanel>
                </Button>
            </StackPanel>
        </materialDesign:ColorZone>


        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <Border Grid.Row="0" Background="#1A1D2E" Height="80">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="25,0,20,0">
                        <TextBlock Text="Hola, Oscar Sosa" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Revisemos tu taller hoy" Foreground="#6B7280" FontSize="12"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#252836" CornerRadius="5"
                            VerticalAlignment="Center" Height="40" MaxWidth="400"
                            HorizontalAlignment="Left" Margin="20,0,0,0" Width="465">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                            <materialDesign:PackIcon Kind="Magnify" Foreground="#6B7280"
                                                     Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="txtBuscar" Background="Transparent" Foreground="#6B7280"
                                     BorderThickness="0" VerticalAlignment="Center"
                                     FontSize="13" Width="200" CaretBrush="White"
                                     TextChanged="txtBuscar_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Setter Property="materialDesign:HintAssist.Hint" Value="Buscar..."/>
                                        <Setter Property="materialDesign:HintAssist.Foreground" Value="#6B7280"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="16,0">
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                Foreground="#6B7280" Width="38" Height="38">
                            <materialDesign:PackIcon Kind="BellOutline" Width="22" Height="22"/>
                        </Button>
                        <materialDesign:Badged BadgeColorZoneMode="PrimaryMid" Badge="0"
                                               HorizontalAlignment="Right" VerticalAlignment="Top"/>
                    </Grid>
                    <Rectangle Grid.Column="3" Fill="#3D4458" Margin="0,20"/>
                    <StackPanel Grid.Column="4" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,20,0">
                        <Border Width="38" Height="38" CornerRadius="18" ClipToBounds="True"
                                Margin="0,0,10,0" BorderBrush="#3D7EFF" BorderThickness="2"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Oscar Sosa" Foreground="#3D7EFF" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Propietario" Foreground="#6B7280" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>


            <Grid Grid.Row="1" Margin="20,15,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#3D7EFF" Foreground="White"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Height="38" Padding="16,0"
                        Click="btnAgregarCliente_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Agregar Cliente" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#6B7280" BorderBrush="#3D4458"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Height="38" Padding="14,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterVariant" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Filtrar" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Grid>

            <materialDesign:Card Grid.Row="2"
                                 Background="#1E2A3A"
                                 materialDesign:ElevationAssist.Elevation="Dp4"
                                 UniformCornerRadius="10"
                                 Margin="20,0,20,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,16" BorderBrush="#2A3A4D" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Clientes Registrados" Foreground="White" FontSize="15" FontWeight="Medium"/>
                            <Border Background="#1A3050" CornerRadius="4" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="tbTotalClientes" Text="0 clientes" Foreground="#4A9EFF" FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1" x:Name="dgClientes"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserResizeRows="False" IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2A3A4D"
                              Background="Transparent" Foreground="White"
                              BorderThickness="0" RowBackground="Transparent"
                              AlternatingRowBackground="#162030"
                              ColumnHeaderHeight="40" RowHeight="52"
                              SelectionChanged="dgClientes_SelectionChanged">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#8B9BB4"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#2A3A4D"/>
                                <Setter Property="SeparatorVisibility" Value="Collapsed"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A2A3D"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2A3A4D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="{x:Type DataGridCell}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>


                            <DataGridTemplateColumn Header="Nombre" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                            <Border Width="32" Height="32" CornerRadius="16"
                                                    Background="#1A3050" Margin="0,0,10,0">
                                                <materialDesign:PackIcon Kind="Account" Foreground="#4A9EFF"
                                                                         Width="18" Height="18"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Cliente_Nombre}"
                                                       Foreground="White" FontSize="13" FontWeight="Medium"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>


                            <DataGridTextColumn Header="Apellido" Binding="{Binding Cliente_Apellido}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#C0CCDA"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                        <Setter Property="FontSize" Value="12"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>


                            <DataGridTextColumn Header="DPI / Identificación" Binding="{Binding Cliente_DPI}" Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#8B9BB4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                        <Setter Property="FontSize" Value="12"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>


                            <DataGridTemplateColumn Header="Teléfono" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                            <materialDesign:PackIcon Kind="Phone" Foreground="#4A9EFF"
                                                                     Width="14" Height="14"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Cliente_Telefono}"
                                                       Foreground="#C0CCDA" FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Correo" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                            <materialDesign:PackIcon Kind="Email" Foreground="#4A9EFF"
                                                                     Width="14" Height="14"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Cliente_Correo}"
                                                       Foreground="#C0CCDA" FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>


                            <DataGridTemplateColumn Header="Dirección" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                            <materialDesign:PackIcon Kind="MapMarker" Foreground="#4A9EFF"
                                                                     Width="14" Height="14"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Cliente_Direccion}"
                                                       Foreground="#C0CCDA" FontSize="12"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Window>
