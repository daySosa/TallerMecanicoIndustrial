<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="Login.Verificacion2FA"
        Title="Verificacion2FA" Height="680" Width="950" WindowStartupLocation="CenterScreen"
         Background="Transparent">

    <Border CornerRadius="16" ClipToBounds="True">
        <Grid>

            <!-- FONDO IMAGEN -->
            <Image Source="/fondo_login.png"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality" OpacityMask="#FF2563EB"/>

            <!-- TARJETA CENTRAL -->
            <Border Width="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="18"
                    Padding="36,30">
                <Border.Background>
                    <SolidColorBrush Color="#7A8BA0" Opacity="0.55"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.5"
                                      BlurRadius="40" ShadowDepth="0"/>
                </Border.Effect>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#ffffff" Opacity="0.15"/>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>

                <StackPanel>

                    <!-- Logo -->
                    <Image Source="/OSM_Logo_AR.png"
                           Height="90" Width="90"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="0,0,0,2"/>


                    <!-- Verificación -->
                    <TextBlock Text="Verificación"
                               Foreground="White" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock
                               Foreground="#dce3f0" FontSize="11"
                               TextWrapping="Wrap" TextAlignment="Center"
                               HorizontalAlignment="Center" Margin="0,0,0,22" Text="Ingresa el código que enviamos a tu correo"/>

                    <!-- Código de 6 Digitos -->
                    <Border x:Name="borderCodigo"
                            Background="White" CornerRadius="8"
                            BorderBrush="Transparent" BorderThickness="1.5"
                            Height="42" Margin="0,0,0,4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="7*"/>
                                <RowDefinition Height="6*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtCodigo"
                                     BorderThickness="0"
                                     Foreground="#333"
                                     FontSize="13"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,10,0"
                                     CaretBrush="#333"
                                     GotFocus="TxtCodigo_GotFocus"
                                     LostFocus="TxtCodigo_LostFocus" Grid.Column="1" Grid.RowSpan="2" Background="#00000000" Height="37" TextChanged="txtCodigo_TextChanged" HorizontalAlignment="Left" RenderTransformOrigin="0.316,0.59" Margin="43,0,0,2">
                                <TextBox.Style>
                                    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Setter Property="materialDesign:HintAssist.Hint" Value="Código de 6 dígitos"/>
                                        <Setter Property="materialDesign:HintAssist.Foreground" Value="#aaa"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="txtErrorCorreo" Text=""
                               Foreground="#f44336" FontSize="11"
                               Margin="4,0,0,8" Visibility="Collapsed"/>

                    <!-- Tiempo -->
                    <TextBlock Text="El código expira en 5 min." Foreground="White"
                               FontSize="10" FontWeight="SemiBold" Margin="0,4,0,5" Width="117" HorizontalAlignment="Center"/>

                    <!-- Botón Iniciar Sesión -->
                    <Button



                Height="42"
                            Margin="0,0,0,16" FontSize="14" FontWeight="SemiBold" materialDesign:ElevationAssist.Elevation="Dp0" Click="BtnVerificar_Click" Cursor="Hand" 
                        materialDesign:ButtonAssist.CornerRadius="8" BorderBrush="#FF2563EB" Background="#FF2563EB" Foreground="#FF2563FF">



                        <Button.Style



                >



                            <Style



                BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="{x:Type Button}">



                                <Setter



                Property="Background" Value="#2563EB"/>



                                <Setter



                Property="Foreground" Value="White"/>



                                <Setter



                Property="BorderBrush" Value="#2563EB"/>



                            </Style>



                        </Button.Style>



                        <TextBlock



                Text="Verificar código" FontSize="14" FontWeight="SemiBold" Foreground="White"/>



                    </Button>
                    <TextBlock Text="¿No recibiste tu código?" Foreground="White"
                        FontSize="11" FontWeight="SemiBold" Width="122"/>



                    <Button Height="24"
                        FontSize="10" FontWeight="SemiBold" materialDesign:ElevationAssist.Elevation="Dp0" Click="BtnReenviar_Click" 
                            Cursor="Hand" materialDesign:ButtonAssist.CornerRadius="8" BorderBrush="{x:Null}" Background="{x:Null}">



                        <Button.Style



                >



                            <Style



                                BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="{x:Type Button}">



                                <Setter



                                    Property="Background" Value="#2563EB"/>



                                <Setter



                                    Property="Foreground" Value="White"/>



                                <Setter



                                    Property="BorderBrush" Value="#2563EB"/>



                            </Style>



                        </Button.Style>



                        <TextBlock



                            Text="Reenviar código" FontSize="10" FontWeight="SemiBold" Foreground="#FF5D5FEF"/>



                    </Button>



                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
