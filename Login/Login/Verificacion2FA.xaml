<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        x:Class="Login.Verificacion2FA"
        Title="Verificacion2FA" Height="680" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="Transparent">

    <Border CornerRadius="16" ClipToBounds="True">
        <Grid>

            <Image Source="/Imagenes/fondo_login.png"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <Border Width="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="18"
                    Padding="36,30">
                <Border.Background>
                    <SolidColorBrush Color="#7A8BA0" Opacity="0.55"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.5"
                                      BlurRadius="40" ShadowDepth="0"/>
                </Border.Effect>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#ffffff" Opacity="0.15"/>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>

                <StackPanel>

                    <Image Source="/Imagenes/OSM_Logo_AR.png"
                           Height="90" Width="90"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="0,0,0,2"/>

                    <TextBlock Text="Verificación"
                               Foreground="White" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Ingresa el código que enviamos a tu correo"
                               Foreground="#dce3f0" FontSize="11"
                               TextWrapping="Wrap" TextAlignment="Center"
                               HorizontalAlignment="Center" Margin="0,0,0,22"/>

                    <Border x:Name="borderCodigo"
                            Background="White" CornerRadius="8"
                            BorderBrush="Transparent" BorderThickness="1.5"
                            Height="42" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtCodigo"
                                     Grid.Column="1"
                                     BorderThickness="0"
                                     Foreground="#333"
                                     FontSize="13"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,10,0"
                                     CaretBrush="#333"
                                     GotFocus="TxtCodigo_GotFocus"
                                     LostFocus="TxtCodigo_LostFocus"
                                     TextChanged="txtCodigo_TextChanged"
                                     Background="Transparent">
                                <TextBox.Style>
                                    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Setter Property="materialDesign:HintAssist.Hint" Value="Código de 6 dígitos"/>
                                        <Setter Property="materialDesign:HintAssist.Foreground" Value="#aaa"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="txtErrorCorreo" Text=""
                               Foreground="#f44336" FontSize="11"
                               Margin="4,0,0,8" Visibility="Collapsed"/>

                    <TextBlock Text="El código expira en 5 min."
                               Foreground="White" FontSize="10" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,4,0,5"/>

                    <Button Height="42"
                            Margin="0,0,0,16"
                            FontSize="14" FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="BtnVerificar_Click"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            materialDesign:ElevationAssist.Elevation="Dp0">
                        <Button.Style>
                            <Style BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="{x:Type Button}">
                                <Setter Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Verificar código" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                    </Button>

                    <TextBlock Text="¿No recibiste tu código?"
                               Foreground="White" FontSize="11" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>

                    <Button Height="24"
                            FontSize="10" FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="BtnReenviar_Click"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            materialDesign:ElevationAssist.Elevation="Dp0"
                            Margin="0,0,0,16">
                        <Button.Style>
                            <Style BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="{x:Type Button}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#5D5FEF"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Reenviar código" FontSize="10" FontWeight="SemiBold" Foreground="#5D5FEF"/>
                    </Button>


                    <Button Height="36"
                            FontSize="12" FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="BtnRegresar_Click"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            materialDesign:ElevationAssist.Elevation="Dp0"
                            Margin="0,0,0,0">
                        <Button.Style>
                            <Style BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="{x:Type Button}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="White"/>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="← Regresar" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                    </Button>

                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>