<Window x:Class="Login.Verificacion2FA"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Verificación de Código" Height="520" Width="440"
        Background="#0f1117" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextElement.Foreground="White"
        MouseDown="Window_Drag">

    <Window.Resources>
        <DropShadowEffect x:Key="GlowBlue" Color="#4f6ef7" BlurRadius="18" ShadowDepth="0" Opacity="0.45" RenderingBias="Performance"/>
        <DropShadowEffect x:Key="GlowSubtle" Color="#000000" BlurRadius="32" ShadowDepth="0" Opacity="0.6" RenderingBias="Performance"/>

        <Style x:Key="DigitBox" TargetType="TextBox">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="#4f6ef7"/>
            <Setter Property="Background" Value="#181b26"/>
            <Setter Property="BorderBrush" Value="#2a2f47"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="MaxLength" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#4f6ef7"/>
                                <Setter Property="Background" Value="#1e2237"/>
                                <Setter Property="Effect" Value="{StaticResource GlowBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#2e3350"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#7880a4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1c2035"/>
                                <Setter Property="BorderBrush" Value="#3d4470"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4f6ef7"/>
            <Setter Property="BorderBrush" Value="#4f6ef7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#6b84ff"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#3d5ae0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="txt" Text="{TemplateBinding Content}"
                                   Foreground="#4f6ef7" FontSize="12"
                                   FontWeight="Medium" Cursor="Hand"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="txt" Property="Foreground" Value="#7986f7"/>
                                <Setter TargetName="txt" Property="TextDecorations" Value="Underline"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="txt" Property="Foreground" Value="#353a58"/>
                                <Setter TargetName="txt" Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Effect="{StaticResource GlowSubtle}">
        <Border CornerRadius="16" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#13161f"
                        BorderBrush="#1e2235" BorderThickness="0,0,0,1"
                        Padding="28,20,28,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="40" Height="40" CornerRadius="10"
                                    Margin="0,0,14,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#2a3580" Offset="0"/>
                                        <GradientStop Color="#1c2455" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <materialDesign:PackIcon Kind="ShieldCheckOutline"
                                                         Foreground="#7986f7"
                                                         Width="20" Height="20"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Autenticación por Código"
                                           Foreground="White" FontSize="14"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Revisa tu correo electrónico"
                                           Foreground="#505880" FontSize="11"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1" Width="28" Height="28"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="BtnRegresar_Click"
                                VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="closeBg" CornerRadius="6"
                                            Background="Transparent" Width="28" Height="28"
                                            SnapsToDevicePixels="True">
                                        <materialDesign:PackIcon Kind="Close"
                                                                 Foreground="#505880"
                                                                 Width="14" Height="14"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="closeBg" Property="Background" Value="#1e2235"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="32,36,32,32">

                    <Border Background="#0d1020" CornerRadius="10"
                            BorderBrush="#1a1f35" BorderThickness="1"
                            Padding="16,12" Margin="0,0,0,32">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="EmailOutline"
                                                     Foreground="#4f6ef7"
                                                     Width="16" Height="16"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,10,0"/>
                            <TextBlock Foreground="#6470a0" FontSize="12"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap">
                                <Run Text="Enviamos un código de 6 dígitos a "/>
                                <Run Text="tu correo registrado" Foreground="#8890c0" FontWeight="Medium"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="INGRESA EL CÓDIGO"
                               Foreground="#6470a0"
                               FontSize="10" FontWeight="Medium"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                Margin="0,0,0,8">
                        <TextBox x:Name="d1" Style="{StaticResource DigitBox}" Margin="5,0"/>
                        <TextBox x:Name="d2" Style="{StaticResource DigitBox}" Margin="5,0"/>
                        <TextBox x:Name="d3" Style="{StaticResource DigitBox}" Margin="5,0"/>
                        <TextBlock Text="—" Foreground="#2a2f47" FontSize="20"
                                   VerticalAlignment="Center" Margin="4,0"/>
                        <TextBox x:Name="d4" Style="{StaticResource DigitBox}" Margin="5,0"/>
                        <TextBox x:Name="d5" Style="{StaticResource DigitBox}" Margin="5,0"/>
                        <TextBox x:Name="d6" Style="{StaticResource DigitBox}" Margin="5,0"/>
                    </StackPanel>

                    <TextBlock x:Name="txtErrorCodigo" Text=""
                               Foreground="#e05560" FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0" Visibility="Collapsed"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                Margin="0,28,0,0">
                        <materialDesign:PackIcon Kind="ClockOutline"
                                                 Foreground="#353a58" Width="13" Height="13"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Foreground="#353a58" FontSize="11" VerticalAlignment="Center">
                            <Run Text="Código expira en "/>
                            <Run x:Name="runTimer" Text="05:00" Foreground="#4f5880" FontWeight="Medium"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                Margin="0,14,0,0">
                        <TextBlock Text="¿No llegó el código?" Foreground="#353a58" FontSize="12"/>
                        <Button x:Name="btnReenviar" Content="Reenviar ahora"
                                Style="{StaticResource LinkButton}"
                                Click="BtnReenviar_Click" Margin="6,0,0,0"/>
                    </StackPanel>

                </StackPanel>

                <Border Grid.Row="2" Background="#0c0e17"
                        BorderBrush="#1a1e30" BorderThickness="0,1,0,0"
                        Padding="28,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#0d1525" CornerRadius="6"
                                    BorderBrush="#1a2540" BorderThickness="1"
                                    Padding="8,4">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="LockOutline"
                                                             Foreground="#2d5090" Width="11" Height="11"
                                                             VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Conexión segura" Foreground="#354060"
                                               FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="btnRegresar"
                                    Style="{StaticResource GhostButton}"
                                    Height="36" Padding="20,0" Margin="0,0,10,0"
                                    FontSize="13" Click="BtnRegresar_Click">
                                <TextBlock Text="Cancelar" VerticalAlignment="Center"/>
                            </Button>

                            <Button x:Name="btnVerificar"
                                    Style="{StaticResource PrimaryButton}"
                                    Height="36" Padding="22,0"
                                    Click="BtnVerificar_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ArrowRight"
                                                             Width="15" Height="15"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,7,0"/>
                                    <TextBlock Text="Verificar" VerticalAlignment="Center"
                                               FontSize="13" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>